{% set publishedModalComments = p.commentaires
  |filter(c => (c.status ?? 'published') == 'published')
  |sort((a,b) => b.dateCreation <=> a.dateCreation)
%}

<div class="modal fade" id="commentsModal-{{ p.id }}" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
    <div class="modal-content border-0 shadow-lg rounded-4">

      <!-- HEADER -->
      <div class="modal-header text-white"
           style="background: linear-gradient(90deg, #0097B2, #00BFA6);">
        <h5 class="modal-title">
          <i class="bi bi-chat-dots me-2"></i>
          Tous les commentaires ({{ publishedModalComments|length }})
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>

      <!-- BODY -->
      <div class="modal-body comments-modal-body bg-light">

        {% if publishedModalComments is empty %}
          <div class="alert alert-info m-0">Aucun commentaire.</div>
        {% else %}

          {% for c in publishedModalComments %}
  <div class="mb-3 p-3 bg-white rounded-4 shadow-sm d-flex justify-content-between align-items-start"
       data-comment-id="{{ c.id }}">

    <div class="w-100">

      <strong>
        {{ c.estAnonyme ? 'Anonyme' : (c.user ? c.user.prenom : 'Utilisateur') }}
      </strong>

      <small class="text-muted ms-2">
        {{ c.dateCreation|date('d/m/Y H:i') }}
      </small>

      <!-- TEXTE -->
      <div class="mt-2 js-comment-text">
        {{ c.contenu }}
      </div>

      <!-- ZONE INLINE EDIT -->
      <div class="js-inline-edit-area mt-2 d-none"></div>
    </div>

    {% if app.user and c.user and c.user.id == app.user.id %}
      <div class="ms-3 text-end">

        <!-- INLINE EDIT BUTTON -->
        <button type="button"
                class="btn btn-sm btn-outline-primary rounded-pill js-edit-comment"
                data-url="{{ path('commentaire_inline_edit', {id: c.id}) }}"
                data-token="{{ csrf_token('edit_commentaire_' ~ c.id) }}">
          <i class="bi bi-pencil"></i>
        </button>

        <!-- DELETE -->
        <form method="post"
              action="{{ path('commentaire_delete', {id: c.id}) }}"
              style="display:inline-block"
              onsubmit="return confirm('Supprimer ce commentaire ?');">

          <input type="hidden"
                 name="_token"
                 value="{{ csrf_token('del_commentaire_' ~ c.id) }}">

          <button type="submit"
                  class="btn btn-sm btn-outline-danger rounded-pill">
            <i class="bi bi-trash"></i>
          </button>
        </form>

      </div>
    {% endif %}

  </div>
{% endfor %}

        {% endif %}
      </div>

      <!-- FOOTER -->
      <div class="modal-footer">
        <button class="btn btn-outline-secondary rounded-pill"
                data-bs-dismiss="modal">
          Fermer
        </button>
      </div>

    </div>
  </div>
</div>