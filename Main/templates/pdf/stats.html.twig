{% extends 'base_dashboard.html.twig' %}

{% block body %}
<style>
    .page-header {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        color: white;
        padding: 32px 24px;
        border-radius: 10px;
        margin-bottom: 30px;
        box-shadow: 0 10px 30px rgba(16, 185, 129, 0.3);
    }
    .card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
        overflow: hidden;
    }
    .card:hover {
        box-shadow: 0 10px 35px rgba(0, 0, 0, 0.15);
        transform: translateY(-2px);
    }
    .card-title {
        color: #059669;
        font-weight: 700;
    }
    .badge.bg-primary {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        color: white;
        font-weight: 600;
        font-size: 1rem;
        border-radius: 20px;
        box-shadow: 0 2px 8px rgba(16, 185, 129, 0.08);
    }
    .badge.bg-danger {
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        color: white;
        font-weight: 600;
        font-size: 1rem;
        border-radius: 20px;
        box-shadow: 0 2px 8px rgba(220, 38, 38, 0.08);
    }
    .badge.bg-secondary {
        background: linear-gradient(135deg, #6b7280 0%, #4b5563 100%);
        color: white;
        font-weight: 600;
        font-size: 1rem;
        border-radius: 20px;
        box-shadow: 0 2px 8px rgba(107, 114, 128, 0.08);
    }
    .text-primary {
        color: #059669 !important;
    }
    .text-info {
        color: #10b981 !important;
    }
    .text-success {
        color: #059669 !important;
    }
    .btn-primary {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        border: none;
        border-radius: 8px;
        padding: 8px 16px;
        font-weight: 600;
        color: white;
        transition: all 0.3s ease;
    }
    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(16, 185, 129, 0.4);
        color: white;
    }
</style>
<div class="container mt-5">
    <h2 class="mb-4 text-primary"><i class="fas fa-chart-pie me-2"></i>Statistiques des Durées des Rendez-vous</h2>
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card shadow border-0">
                <div class="card-body text-center">
                    <h6 class="text-muted">Nombre de rendez-vous</h6>
                    <h2 class="text-info fw-bold">{{ count }}</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow border-0">
                <div class="card-body text-center">
                    <h6 class="text-muted">Durée moyenne</h6>
                    <h2 class="text-success fw-bold">{{ average|number_format(2) }} min</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow border-0">
                <div class="card-body text-center">
                    <h6 class="text-muted">Durée max / min</h6>
                    <h2 class="fw-bold"><span class="text-danger">{{ max|number_format(2) }}</span> / <span class="text-secondary">{{ min|number_format(2) }}</span> min</h2>
                </div>
            </div>
        </div>
    </div>
    <div class="card mb-4 shadow border-0">
        <div class="card-body">
            <h5 class="card-title mb-4">Médecin : <span class="text-primary">Dr. {{ doctor.nom }} {{ doctor.prenom }}</span></h5>
            <ul class="list-group mb-3">
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <span>Présentiel</span>
                    <span class="badge bg-primary rounded-pill">{{ modeCounts['Présentiel'] }}</span>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <span>Distanciel</span>
                    <span class="badge bg-danger rounded-pill">{{ modeCounts['Distanciel'] }}</span>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <span>Autre</span>
                    <span class="badge bg-secondary rounded-pill">{{ modeCounts['Autre'] }}</span>
                </li>
            </ul>
            <p class="mt-3 text-muted">Exporté le {{ "now"|date("d/m/Y H:i") }}</p>
        </div>
    </div>
</div>
{% endblock %}
