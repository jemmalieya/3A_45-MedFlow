{# templates/profile/modal_edit.html.twig #}

<style>
  .pf-wrap{animation:pfIn .22s ease-out both}
  @keyframes pfIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
  .pf-card{
    border-radius:18px;
    background: var(--mf-surface);
    border:1px solid var(--mf-border);
    box-shadow:0 18px 55px rgba(2,6,23,.10);
  }
  .pf-head{
    border-radius:18px 18px 0 0;
    background: linear-gradient(135deg,
      rgba(var(--mf-primary-rgb), .18),
      rgba(var(--mf-blue-rgb), .10)
    );
    border-bottom:1px solid var(--mf-border);
  }
  .form-control, .form-select{border-radius:12px}
  .pf-hint{font-size:.85rem;color:#6c757d}
  .invalid-feedback{display:block}

  .pf-ico{
    width:42px;height:42px;border-radius:999px;
    display:flex;align-items:center;justify-content:center;
    background: rgba(var(--mf-primary-rgb), .14);
    color: var(--mf-primary);
  }

  .pf-upl{
    border:1px dashed rgba(var(--mf-primary-rgb), .35);
    border-radius:16px;
    background: rgba(var(--mf-primary-rgb), .05);
  }

  .pf-upl-ico{
    width:54px;height:54px;border-radius:999px;
    display:flex;align-items:center;justify-content:center;
    background: rgba(var(--mf-primary-rgb), .12);
    color: var(--mf-primary);
  }
</style>

<div class="pf-wrap pf-card">
  <div class="pf-head p-3 p-md-4">
    <div class="d-flex align-items-center gap-2">
      <div class="pf-ico">
        <i class="bi bi-person-gear"></i>
      </div>
      <div>
        <div class="fw-bold">Modifier votre profil</div>
        <div class="pf-hint">Mettez à jour vos informations et votre photo.</div>
      </div>
    </div>
  </div>

  <div class="p-3 p-md-4">

{{ form_start(form, {
      'action': path('profile_modal_edit_submit'),
      'method': 'POST',
      'attr': {'autocomplete':'off'}
    }) }}
    
    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label fw-semibold">Prénom</label>
        {{ form_widget(form.prenom, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.prenom) }}
      </div>

      <div class="col-md-6">
        <label class="form-label fw-semibold">Nom</label>
        {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.nom) }}
      </div>

      {% if form.telephoneUser is defined %}
      <div class="col-md-6">
        <label class="form-label fw-semibold">Téléphone</label>
        {{ form_widget(form.telephoneUser, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.telephoneUser) }}
      </div>
      {% endif %}

      {% if form.adresseUser is defined %}
      <div class="col-md-6">
        <label class="form-label fw-semibold">Adresse</label>
        {{ form_widget(form.adresseUser, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.adresseUser) }}
      </div>
      {% endif %}

      {% if form.profilePictureFile is defined %}
      <div class="col-12">
        <div class="d-flex align-items-start gap-3 p-3 pf-upl">
          <div class="pf-upl-ico">
            <i class="bi bi-image fs-4"></i>
          </div>
          <div class="text-center mb-3">
  {% if app.user.profilePicture %}
    {% set pic = app.user.profilePicture %}
    {% set picUrl = (pic starts with 'http') ? pic : asset('uploads/profile/' ~ pic) %}
    <img src="{{ picUrl }}"
         class="rounded-circle shadow js-profile-preview"
         style="width:110px;height:110px;object-fit:cover;">
  {% else %}
    <img src="{{ asset('assets/img/default-avatar.png') }}"
         class="rounded-circle shadow js-profile-preview"
         style="width:110px;height:110px;object-fit:cover;">
  {% endif %}
          <div class="flex-grow-1">
            <div class="fw-bold mb-1">Photo de profil</div>
            <div class="pf-hint mb-2">Formats conseillés : JPG/PNG. Une photo carrée est idéale.</div>
            {{ form_widget(form.profilePictureFile, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.profilePictureFile) }}
          </div>
        </div>
      </div>
      {% endif %}
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
      <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
        Annuler
      </button>
      <button type="submit" class="btn btn-primary px-4">
        <i class="bi bi-check2-circle me-1"></i> Enregistrer
      </button>
    </div>
    <style>
.preview-animate {
  animation: previewZoom .35s ease;
}

@keyframes previewZoom {
  from { opacity: 0; transform: scale(.92); }
  to   { opacity: 1; transform: scale(1); }
}
</style>


    {{ form_end(form) }}

    <hr class="my-4">

    <div class="">
      <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
        <div>
          <div class="fw-bold"><i class="bi bi-shield-lock me-1"></i> Double authentification (2FA)</div>
          <div class="pf-hint">Protégez votre compte avec un code temporaire (Google Authenticator / Authy).</div>
        </div>
        <span class="badge text-bg-secondary" data-2fa-badge>Chargement…</span>
      </div>

      <div class="mt-3" data-2fa-setup hidden>
        <div class="row g-3">
          <div class="col-md-6">
            <div class="fw-semibold mb-1">QR Code (application d’authentification)</div>
            <div class="border rounded-3 p-2 d-flex align-items-center justify-content-center bg-white" style="min-height: 220px;">
              <div data-2fa-qr style="width:220px;max-width:100%;height:auto;"></div>
            </div>
            <div class="pf-hint mt-2">Ouvrez Google Authenticator / Microsoft Authenticator / Authy → Ajouter → Scanner un QR code.</div>
          </div>
          <div class="col-md-6">
            <div class="fw-semibold mb-1">Clé secrète</div>
            <input class="form-control" data-2fa-secret readonly>
            <div class="pf-hint mt-2">Si vous ne pouvez pas scanner, copiez la clé et ajoutez-la manuellement (TOTP).</div>

            <div class="fw-semibold mt-3 mb-1">Code (6 chiffres)</div>
            <input class="form-control" data-2fa-code inputmode="numeric" autocomplete="one-time-code" placeholder="123456">

            <div class="d-flex gap-2 mt-3">
              <button type="button" class="btn btn-primary" data-2fa-confirm>
                <i class="bi bi-check2-circle me-1"></i> Confirmer
              </button>
              <button type="button" class="btn btn-outline-secondary" data-2fa-cancel>Annuler</button>
            </div>

            <div class="alert alert-danger mt-3 d-none" data-2fa-error></div>
          </div>
        </div>
      </div>

      <div class="d-flex gap-2 mt-3" data-2fa-actions>
        <button type="button" class="btn btn-outline-primary" data-2fa-enable>
          Activer 2FA
        </button>
        <button type="button" class="btn btn-outline-danger" data-2fa-disable hidden>
          Désactiver 2FA
        </button>
      </div>

      <div class="mt-3" data-2fa-disable-box hidden>
        <div class="fw-semibold mb-1">Confirmer la désactivation</div>
        <div class="pf-hint mb-2">Entrez un code 2FA pour désactiver.</div>
        <div class="d-flex gap-2">
          <input class="form-control" style="max-width: 180px;" data-2fa-disable-code inputmode="numeric" autocomplete="one-time-code" placeholder="123456">
          <button type="button" class="btn btn-danger" data-2fa-disable-confirm>Désactiver</button>
          <button type="button" class="btn btn-outline-secondary" data-2fa-disable-cancel>Annuler</button>
        </div>
        <div class="alert alert-danger mt-3 d-none" data-2fa-disable-error></div>
      </div>
    </div>

    <hr class="my-4">

    <div class="">
      <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
        <div>
          <div class="fw-bold"><i class="bi bi-camera me-1"></i> Connexion par visage</div>
          <div class="pf-hint">Activez la connexion par webcam. Une empreinte (embedding) est stockée en base (pas la photo).</div>
          <div class="pf-hint" data-face-lock-hint></div>
        </div>
        <span class="badge text-bg-secondary" data-face-badge>Chargement…</span>
      </div>

      <div class="d-flex gap-2 mt-3" data-face-actions>
        <button type="button" class="btn btn-outline-primary" data-face-enroll>
          Enregistrer mon visage
        </button>
        <button type="button" class="btn btn-outline-danger" data-face-disable hidden>
          Désactiver
        </button>
      </div>

      <div class="mt-3" data-face-enroll-box hidden>
        <div class="fw-semibold mb-1">Caméra</div>
        <div class="border rounded-3 p-2 bg-white">
          <div class="rounded-3 overflow-hidden" style="height: 260px;">
            <video data-face-video class="w-100" playsinline autoplay muted style="width:100%;height:100%;object-fit:cover;"></video>
          </div>
        </div>
        <div class="d-flex gap-2 mt-2">
          <button type="button" class="btn btn-primary" data-face-capture>
            Capturer & enregistrer
          </button>
          <button type="button" class="btn btn-outline-secondary" data-face-cancel>Annuler</button>
        </div>
        <div class="pf-hint mt-2" data-face-status></div>
        <div class="alert alert-danger mt-3 d-none" data-face-error></div>
        <div class="pf-hint mt-2">Bon éclairage, visage de face, un seul visage dans le cadre.</div>
      </div>
    </div>

  </div>
</div>
