{# templates/profile/modal_password.html.twig #}

<style>
  .pf-wrap{animation:pfIn .22s ease-out both}
  @keyframes pfIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}

  .pf-card{
    border-radius:18px;
    background: var(--mf-surface);
    border:1px solid var(--mf-border);
    box-shadow:0 18px 55px rgba(2,6,23,.10);
  }

  .pf-head{
    border-radius:18px 18px 0 0;
    background: linear-gradient(135deg,
      rgba(var(--mf-primary-rgb), .18),
      rgba(var(--mf-blue-rgb), .08)
    );
    border-bottom:1px solid var(--mf-border);
  }

  .form-control{border-radius:12px}

  .pf-tip{
    border-radius:16px;
    border:1px solid var(--mf-border);
    background: rgba(var(--mf-primary-rgb), .06);
    padding:12px 14px;
    font-size:.9rem;
  }

  .pf-ico{
    width:42px;height:42px;border-radius:999px;
    display:flex;align-items:center;justify-content:center;
    background: rgba(var(--mf-primary-rgb), .14);
    color: var(--mf-primary);
  }

  .invalid-feedback{display:block}
</style>

<div class="pf-wrap pf-card">
  <div class="pf-head p-3 p-md-4">
    <div class="d-flex align-items-center gap-2">
      <div class="pf-ico">
        <i class="bi bi-shield-lock"></i>
      </div>
      <div>
        <div class="fw-bold">Changer le mot de passe</div>
        <div class="text-muted" style="font-size:.9rem;">Renforcez la sécurité de votre compte MedFlow.</div>
      </div>
    </div>
  </div>

  <div class="p-3 p-md-4">
    <div class="pf-tip mb-3">
      <div class="fw-semibold mb-1"><i class="bi bi-lightning-charge me-1"></i> Conseils rapides</div>
      <ul class="mb-0 ps-3">
        <li>8 caractères minimum</li>
        <li>Ajoutez majuscules + chiffres</li>
        <li>Évitez prénom/nom/date naissance</li>
      </ul>
    </div>

{{ form_start(form, {
      'action': path('profile_modal_password_submit'),
      'method': 'POST',
  'attr': {'autocomplete':'off', 'novalidate':'novalidate'}
    }) }}
      {% if form.plainPassword is defined %}
        <div class="mb-3">
          {{ form_label(form.currentPassword, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
          <div class="input-group">
            {{ form_widget(form.currentPassword, {'attr': {'class': 'form-control', 'placeholder':'Mot de passe actuel'}}) }}
            <button type="button" class="btn btn-outline-secondary" data-password-toggle="{{ form.currentPassword.vars.id }}" aria-label="Afficher le mot de passe">
              <i class="bi bi-eye"></i>
            </button>
          </div>
          {{ form_errors(form.currentPassword) }}
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold">Nouveau mot de passe</label>
          <div class="input-group">
            {{ form_widget(form.plainPassword.first, {'attr': {'class': 'form-control', 'placeholder':'Nouveau mot de passe'}}) }}
            <button type="button" class="btn btn-outline-secondary" data-password-toggle="{{ form.plainPassword.first.vars.id }}" aria-label="Afficher le mot de passe">
              <i class="bi bi-eye"></i>
            </button>
          </div>
          {{ form_errors(form.plainPassword.first) }}
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold">Confirmer le mot de passe</label>
          <div class="input-group">
            {{ form_widget(form.plainPassword.second, {'attr': {'class': 'form-control', 'placeholder':'Confirmer le mot de passe'}}) }}
            <button type="button" class="btn btn-outline-secondary" data-password-toggle="{{ form.plainPassword.second.vars.id }}" aria-label="Afficher le mot de passe">
              <i class="bi bi-eye"></i>
            </button>
          </div>
          {{ form_errors(form.plainPassword.second) }}
        </div>

        {{ form_errors(form.plainPassword) }}
      {% else %}
        {# fallback si ton form n'est pas repeated #}
        <div class="mb-3">
          {{ form_widget(form, {'attr': {'class': 'form-control'}}) }}
          {{ form_errors(form) }}
        </div>
      {% endif %}

      <div class="d-flex justify-content-end gap-2 mt-4">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
          Annuler
        </button>
        <button type="submit" class="btn btn-primary px-4">
          <i class="bi bi-check2-circle me-1"></i> Mettre à jour
        </button>
      </div>

    {{ form_end(form) }}
  </div>
</div>
