{# templates/reclamation/mes_reclamations.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Mes réclamations{% endblock %}

{% block body %}
{% set notificationsCount = notificationsCount|default(0) %}
{% set unreadByRec = unreadByRec|default({}) %}

<section class="section" style="padding-top: 80px;">

  <!-- BANNIÈRE -->
  <div class="row justify-content-center mb-4">
    <div class="col-md-8 col-lg-10 text-center">
      <div class="card mf-banner">
        <h3 class="fw-bold mb-1">Mes réclamations</h3>
        <p class="mb-0">Décrivez votre problème, nous vous répondrons rapidement.</p>
      </div>

      <a href="{{ path('reclamation_index') }}" class="btn mf-btn-primary mt-3">
        <i class="bi bi-plus me-2"></i> Nouvelle réclamation
      </a>
    </div>
  </div>

  <div class="container">

    <!-- FLASH MESSAGES -->
 {% if app.flashes('success') is not empty %}
<script>
document.addEventListener('DOMContentLoaded', function () {
  Swal.fire({
    icon: 'success',
    title: 'Suppression réussie',
    text: 'Réclamation supprimée avec succès.',
    timer: 2000,
    timerProgressBar: true,
    showConfirmButton: false,
    position: 'top',
    background: '#ffffff',
    color: '#0f172a',
    iconColor: '#1CA3B4',
    customClass: {
      popup: 'mf-swal-popup'
    }
  });
});
</script>
{% endif %}

    {% for message in app.flashes('danger') %}
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    {% endfor %}

    {% if reclamations|length == 0 %}
      <div class="alert alert-info text-center">
        <i class="bi bi-info-circle me-2"></i>
        Vous n'avez pas encore envoyé de réclamation.
        <a href="{{ path('reclamation_index') }}" class="alert-link">Créer une réclamation</a>
      </div>
    {% else %}

      {# ===================== TABLE CARD ===================== #}
      <div class="mf-table-card">
        <div class="mf-table-top">
          <div class="d-flex align-items-center gap-2">
            <span class="mf-dot"></span>
            <div>
              <div class="fw-bold">Historique</div>
              <div class="text-muted small">Gérez vos réclamations & suivez les réponses</div>
            </div>
          </div>

          <div class="mf-kpi">
            <div class="mf-kpi-box">
              <div class="mf-kpi-label">Total</div>
              <div class="mf-kpi-value">{{ reclamations|length }}</div>
            </div>
          </div>
        </div>

        <div class="table-responsive mf-table-wrap">
          <table class="table mf-table align-middle mb-0">
            <thead>
              <tr>
                <th style="min-width:180px;">Référence</th>
                <th>Contenu</th>
                <th style="min-width:140px;">Type</th>
                <th style="min-width:140px;">Statut</th>
                <th style="min-width:170px;">Date de création</th>
                <th class="text-end" style="min-width:220px;">Actions</th>
              </tr>
            </thead>

            <tbody>
              {% for r in reclamations %}
                <tr>
                  <td>
                    <div class="d-flex align-items-center gap-2">
                      <div class="mf-ref">
                        <div class="fw-bold">{{ r.referenceReclamation }}</div>
                        
                      </div>

                      {% set nbUnread = unreadByRec[r.idReclamation]|default(0) %}
                      {% if nbUnread > 0 %}
                        <span id="unread-badge-{{ r.idReclamation }}" class="badge mf-badge-danger ms-auto">
                          <i class="bi bi-bell-fill me-1"></i>{{ nbUnread }}
                        </span>
                      {% endif %}
                    </div>
                  </td>

                  <td>
                    <div class="mf-text-clamp" title="{{ r.contenu }}">
                      {{ r.contenu }}
                    </div>
                  </td>

                  <td>
                    <span class="badge mf-badge-soft">
                      <i class="bi bi-tag me-1"></i>{{ r.type }}
                    </span>
                  </td>

                  <td>
                    {% set s = r.statutReclamation %}
                    {% if s == 'EN_ATTENTE' %}
                      <span class="badge mf-badge-warn">
                        <i class="bi bi-clock me-1"></i> En attente
                      </span>
                    {% elseif s == 'TRAITEE' %}
                      <span class="badge mf-badge-ok">
                        <i class="bi bi-check-circle me-1"></i> Traitée
                      </span>
                    {% elseif s == 'REJETEE' %}
                      <span class="badge mf-badge-danger">
                        <i class="bi bi-x-circle me-1"></i> Rejetée
                      </span>
                    {% else %}
                      <span class="badge bg-secondary">{{ s }}</span>
                    {% endif %}
                  </td>

                  <td class="text-muted">
                    {{ r.dateCreationR ? r.dateCreationR|date('d/m/Y H:i') : '-' }}
                  </td>

                  {# ===================== ACTIONS (PLUS PRO) ===================== #}
                  <td class="text-end">
                    <div class="mf-actions">
                      {# Action principale (toujours visible) #}
                      <button type="button"
                              class="btn mf-act mf-act-primary"
                              data-bs-toggle="modal"
                              data-bs-target="#responsesModal-{{ r.idReclamation }}">
                        <i class="bi bi-chat-left-text me-1"></i>
                        Réponses
                        {% if nbUnread > 0 %}
                          <span class="mf-pill ms-2">+{{ nbUnread }}</span>
                        {% endif %}
                      </button>

                      {# Menu actions secondaires (dropdown compact) #}
                      <div class="dropdown">
                        <button class="btn mf-act mf-act-ghost dropdown-toggle"
                                type="button"
                                data-bs-toggle="dropdown"
                                aria-expanded="false"
                                title="Plus d’actions">
                          <i class="bi bi-three-dots-vertical"></i>
                        </button>

                        <ul class="dropdown-menu dropdown-menu-end mf-dropdown">
                          {% if r.pieceJointePath %}
                            <li>
                              <button type="button"
                                      class="dropdown-item"
                                      data-bs-toggle="modal"
                                      data-bs-target="#proofModal"
                                      data-preview-url="{{ path('reclamation_piece_preview', { id: r.idReclamation }) }}"
                                      data-title="Preuve - {{ r.referenceReclamation }}">
                                <i class="bi bi-image me-2"></i> Voir preuve
                              </button>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                          {% endif %}

                          <li>
                            <a class="dropdown-item"
                               href="{{ path('reclamation_edit', {'id': r.idReclamation}) }}">
                              <i class="bi bi-pencil me-2"></i> Modifier
                            </a>
                          </li>

                          <li>
                            <button type="button"
                                    class="dropdown-item text-danger"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteModal-{{ r.idReclamation }}">
                              <i class="bi bi-trash me-2"></i> Supprimer
                            </button>
                          </li>
                        </ul>
                      </div>
                    </div>

                    <!-- MODAL SUPPRESSION -->
                    <div class="modal fade" id="deleteModal-{{ r.idReclamation }}" tabindex="-1" aria-hidden="true">
                      <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                          <div class="modal-header">
                            <h5 class="modal-title">Suppression de réclamation</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                          </div>
                          <div class="modal-body">
                            <p>Voulez-vous vraiment supprimer cette réclamation ?</p>
                            <div class="card bg-light border-0 p-3">
                              <strong>{{ r.referenceReclamation }}</strong> — {{ r.contenu }}
                            </div>
                            <div class="small text-muted mt-2">
                              <i class="bi bi-exclamation-triangle me-1"></i>
                              Cette action est irréversible.
                            </div>
                          </div>
                          <div class="modal-footer">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                              Annuler
                            </button>
                            <form method="post" action="{{ path('reclamation_delete', {'id': r.idReclamation}) }}" style="display:inline;">
                              <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ r.idReclamation) }}">
                              <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash me-1"></i> Oui, supprimer
                              </button>
                            </form>
                          </div>
                        </div>
                      </div>
                    </div>

                    <!-- MODAL REPONSES (inchangé, juste gardé ton style) -->
                    <div class="modal fade"
                         id="responsesModal-{{ r.idReclamation }}"
                         data-mark-url="{{ path('reclamation_mark_read', {'id': r.idReclamation}) }}"
                         tabindex="-1" aria-hidden="true">

                      <div class="modal-dialog modal-dialog-centered modal-lg">
                        <div class="modal-content shadow-lg rounded-4 border-0">

                          <div class="modal-header text-white rounded-top-4"
                               style="background: linear-gradient(90deg, #1CA3B4, #48cae4);">
                            <h5 class="modal-title">
                              <i class="bi bi-chat-left-text me-2"></i> Réponses - {{ r.referenceReclamation }}
                            </h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                          </div>

                          <div class="modal-body" style="max-height: 60vh; overflow-y: auto; background: #f8f9fa;">
                            {% if r.reponses is empty %}
                              <div class="alert alert-info text-center m-0">
                                <i class="bi bi-info-circle me-1"></i> Aucune réponse pour le moment.
                              </div>
                            {% else %}
                              <div class="list-group">
                                {% for rep in r.reponses %}
                                  <div class="list-group-item list-group-item-action mb-2 shadow-sm rounded-3 p-3" style="background: #ffffff;">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                      <span class="badge text-white"
                                            style="background: linear-gradient(90deg, #1CA3B4, #48cae4);">
                                        {{ rep.typeReponse }}
                                      </span>
                                      <small class="text-muted">{{ rep.dateCreationRep|date('d/m/Y H:i') }}</small>
                                    </div>
                                    <div class="mt-1" style="font-size: 0.95rem; line-height: 1.4;">
                                      {{ rep.message }}
                                    </div>
                                  </div>
                                {% endfor %}
                              </div>
                            {% endif %}
                          </div>

                        </div>
                      </div>
                    </div>
                    {# /MODAL REPONSES #}

                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>

    {% endif %}

  </div>
</section>

{# ===================== STYLE (mêmes couleurs, plus propre) ===================== #}
<style>
  .mf-swal-popup {
    border-radius: 18px !important;
    box-shadow: 0 20px 60px rgba(28, 163, 180, 0.25) !important;
    border: 1px solid rgba(28, 163, 180, .25);
  }

  :root{
    --mf-teal:#1CA3B4;
    --mf-teal-2:#48cae4;
    --mf-ink:#0f172a;
    --mf-muted:#64748b;
    --mf-line:rgba(15,23,42,.08);
    --mf-soft:#e0f7fa;
    --mf-bg:#f7fbfc;
    --mf-shadow:0 18px 48px rgba(2, 32, 71, .08);
  }

  /* Banner + primary button */
  .mf-banner{
    background: var(--mf-teal);
    color:#fff;
    padding:40px;
    border-radius:20px;
    border:none;
    box-shadow: 0 16px 38px rgba(28,163,180,.22);
  }
  .mf-btn-primary{
    border:none;
    color:#fff;
    font-weight:800;
    padding:12px 18px;
    border-radius:14px;
    background: linear-gradient(90deg, var(--mf-teal), var(--mf-teal-2));
    box-shadow: 0 10px 24px rgba(28,163,180,.25);
    transition: transform .18s ease, box-shadow .18s ease, filter .18s ease;
  }
  .mf-btn-primary:hover{
    transform: translateY(-2px);
    filter: brightness(1.02);
    box-shadow: 0 14px 30px rgba(28,163,180,.28);
  }

  /* Table container (card) */
  .mf-table-card{
    background:#fff;
    border:1px solid var(--mf-line);
    border-radius:18px;
    overflow:hidden;
    box-shadow: var(--mf-shadow);
  }
  .mf-table-top{
    padding:16px 18px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:12px;
    background: linear-gradient(135deg, rgba(28,163,180,.10), rgba(72,202,228,.06));
    border-bottom:1px solid var(--mf-line);
  }
  .mf-dot{
    width:12px;height:12px;border-radius:50%;
    background: linear-gradient(90deg, var(--mf-teal), var(--mf-teal-2));
    box-shadow: 0 0 0 6px rgba(28,163,180,.12);
  }
  .mf-kpi-box{
    background:#fff;
    border:1px solid var(--mf-line);
    border-radius:14px;
    padding:10px 14px;
    min-width:120px;
    text-align:right;
  }
  .mf-kpi-label{ color:var(--mf-muted); font-size:.78rem; }
  .mf-kpi-value{ font-weight:900; font-size:1.25rem; color:var(--mf-ink); }

  .mf-table-wrap{ background: #fff; }
  .mf-table{
    margin:0;
  }
  .mf-table thead th{
    position: sticky;
    top: 0;
    z-index: 2;
    background: var(--mf-soft);
    color: #0b3b43;
    font-weight: 800;
    border-bottom: 1px solid var(--mf-line);
    padding: 14px 14px;
    white-space: nowrap;
  }
  .mf-table tbody td{
    border-top: 1px solid rgba(15,23,42,.06);
    padding: 14px 14px;
    vertical-align: middle;
  }

  /* Zebra + hover */
  .mf-table tbody tr:nth-child(even){ background: rgba(224,247,250,.35); }
  .mf-table tbody tr{
    transition: transform .12s ease, box-shadow .12s ease, background .12s ease;
  }
  .mf-table tbody tr:hover{
    background: rgba(224,247,250,.75);
  }

  /* Reference block */
  .mf-ref{ line-height:1.15; }
  .mf-text-clamp{
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    color: var(--mf-ink);
  }

  /* Badges (cohérents avec teal) */
  .mf-badge-soft{
    background: rgba(28,163,180,.12);
    border: 1px solid rgba(28,163,180,.22);
    color: #0b4f58;
    border-radius: 999px;
    padding: .45rem .7rem;
    font-weight: 800;
  }
  .mf-badge-warn{
    background: rgba(245,158,11,.18);
    border: 1px solid rgba(245,158,11,.28);
    color:#8a5a00;
    border-radius: 999px;
    padding: .45rem .7rem;
    font-weight: 800;
  }
  .mf-badge-ok{
    background: rgba(16,185,129,.16);
    border: 1px solid rgba(16,185,129,.25);
    color:#0b6b4a;
    border-radius: 999px;
    padding: .45rem .7rem;
    font-weight: 800;
  }
  .mf-badge-danger{
    background: rgba(239,68,68,.15);
    border: 1px solid rgba(239,68,68,.25);
    color:#9b1c1c;
    border-radius: 999px;
    padding: .45rem .7rem;
    font-weight: 800;
  }

  /* Actions: 1 bouton principal + menu propre */
  .mf-actions{
    display:flex;
    justify-content:flex-end;
    align-items:center;
    gap:.5rem;
    flex-wrap:wrap;
  }
  .mf-act{
    border-radius: 12px;
    height: 40px;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    font-weight: 900;
    letter-spacing: .1px;
    transition: transform .15s ease, box-shadow .15s ease, filter .15s ease;
    border: 1px solid transparent;
    padding: 0 14px;
    white-space: nowrap;
  }
  .mf-act:hover{ transform: translateY(-1px); filter: brightness(1.01); }

  .mf-act-primary{
    color:#fff;
    background: linear-gradient(90deg, var(--mf-teal), var(--mf-teal-2));
    box-shadow: 0 10px 22px rgba(28,163,180,.22);
  }
  .mf-act-ghost{
    background: #fff;
    border: 1px solid rgba(28,163,180,.22);
    color: #0b4f58;
    width: 44px;
    padding: 0;
    box-shadow: 0 8px 18px rgba(2,32,71,.06);
  }

  .mf-pill{
    background: rgba(255,255,255,.22);
    border: 1px solid rgba(255,255,255,.30);
    padding: 2px 8px;
    border-radius: 999px;
    font-size: .80rem;
    font-weight: 900;
  }

  /* Dropdown */
  .mf-dropdown{
    border-radius: 14px;
    border: 1px solid var(--mf-line);
    box-shadow: 0 18px 48px rgba(2,32,71,.12);
    overflow:hidden;
  }
  .mf-dropdown .dropdown-item{
    padding: 10px 14px;
    font-weight: 800;
  }
  .mf-dropdown .dropdown-item:hover{
    background: rgba(224,247,250,.75);
  }

  /* Responsive: actions prennent toute la largeur sur mobile */
  @media (max-width: 576px){
    .mf-actions{ justify-content: center; }
    .mf-act-primary{ width: 100%; }
    .mf-act-ghost{ width: 100%; }
    td.text-end{ text-align:center !important; }
  }
</style>

{# ===================== NOTIF SWEETALERT ===================== #}
{% if notificationsCount > 0 %}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
  Swal.fire({
    icon: 'info',
    title: 'Nouvelle réponse',
    text: 'Vous avez {{ notificationsCount }} nouvelle(s) réponse(s).',
    confirmButtonColor: '#1CA3B4'
  });
});
</script>
{% endif %}

{# ===================== MARK READ (inchangé) ===================== #}
<script>
document.addEventListener('DOMContentLoaded', function () {
  document.querySelectorAll('.modal[id^="responsesModal-"]').forEach(modal => {
    modal.addEventListener('shown.bs.modal', async function () {
      const url = this.getAttribute('data-mark-url');
      if (!url) return;

      try {
        const res = await fetch(url, {
          method: 'POST',
          headers: { 'X-Requested-With': 'XMLHttpRequest' }
        });

        const data = await res.json();
        if (!data.ok) return;

        const recId = this.id.replace('responsesModal-', '');
        const badge = document.getElementById('unread-badge-' + recId);
        if (badge) badge.remove();

      } catch (e) {
        console.error(e);
      }
    });
  });
});
</script>

{# ===================== PROOF MODAL JS (inchangé) ===================== #}
<script>
document.addEventListener('DOMContentLoaded', function () {
  const proofModal = document.getElementById('proofModal');
  if (!proofModal) return;

  const titleEl = document.getElementById('proofModalTitle');
  const loadingEl = document.getElementById('proofLoading');
  const errorEl = document.getElementById('proofError');
  const imgEl = document.getElementById('proofImg');
  const openNewTabEl = document.getElementById('proofOpenNewTab');
  const viewport = document.getElementById('proofViewport');

  let scale = 1;

  function setZoom(newScale) {
    scale = Math.min(4, Math.max(1, newScale));
    imgEl.style.transform = `scale(${scale})`;
    imgEl.style.cursor = (scale > 1) ? 'zoom-out' : 'zoom-in';
  }

  imgEl.addEventListener('click', () => setZoom(scale === 1 ? 2 : 1));
  imgEl.addEventListener('dblclick', (e) => {
    e.preventDefault();
    setZoom(1);
    viewport.scrollTop = 0;
    viewport.scrollLeft = 0;
  });

  viewport.addEventListener('wheel', (e) => {
    if (!e.ctrlKey) return;
    e.preventDefault();
    const delta = Math.sign(e.deltaY);
    setZoom(scale + (delta > 0 ? -0.2 : 0.2));
  }, { passive: false });

  proofModal.addEventListener('show.bs.modal', async function (event) {
    const btn = event.relatedTarget;
    if (!btn) return;

    const previewUrl = btn.getAttribute('data-preview-url');
    const title = btn.getAttribute('data-title') || 'Preuve';

    titleEl.textContent = title;
    errorEl.classList.add('d-none');
    errorEl.textContent = '';
    loadingEl.style.display = 'block';
    imgEl.src = '';
    openNewTabEl.href = '#';
    setZoom(1);

    try {
      const res = await fetch(previewUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' }});
      const data = await res.json();

      if (!data.ok) throw new Error(data.message || 'Impossible de charger la preuve.');

      imgEl.src = data.url;
      openNewTabEl.href = data.url;
    } catch (err) {
      errorEl.textContent = err.message || 'Erreur lors du chargement.';
      errorEl.classList.remove('d-none');
    } finally {
      loadingEl.style.display = 'none';
    }
  });

  proofModal.addEventListener('hidden.bs.modal', function () {
    imgEl.src = '';
    setZoom(1);
  });
});
</script>

{# ===================== PROOF MODAL HTML (inchangé) ===================== #}
<div class="modal fade" id="proofModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-xl">
    <div class="modal-content shadow-lg rounded-4 border-0">
      <div class="modal-header text-white rounded-top-4"
           style="background: linear-gradient(90deg, #1CA3B4, #48cae4);">
        <h5 class="modal-title" id="proofModalTitle">
          <i class="bi bi-image me-2"></i> Preuve
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="modal-body" style="background:#f8f9fa;">
        <div id="proofLoading" class="text-center py-5">
          <div class="spinner-border" role="status"></div>
          <div class="mt-2 text-muted">Chargement de l’image...</div>
        </div>

        <div id="proofError" class="alert alert-danger d-none"></div>

        <div class="d-flex justify-content-center">
          <div id="proofViewport"
               style="max-height:70vh; overflow:auto; border-radius:16px; background:#fff; padding:10px; box-shadow:0 10px 30px rgba(0,0,0,.08);">
            <img id="proofImg"
                 src=""
                 alt="Preuve"
                 style="max-width:100%; height:auto; border-radius:12px; cursor: zoom-in; transform-origin: center center; transition: transform .15s ease;">
          </div>
        </div>

        <div class="text-center mt-3 text-muted small">
          Cliquez pour zoomer • Double-cliquez pour réinitialiser • Ctrl + molette pour zoom
        </div>
      </div>

      <div class="modal-footer">
        <a id="proofOpenNewTab" href="#" target="_blank" class="btn btn-outline-primary">
          <i class="bi bi-box-arrow-up-right me-1"></i> Ouvrir dans un nouvel onglet
        </a>
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
          Fermer
        </button>
      </div>
    </div>
  </div>
</div>

{% endblock %}