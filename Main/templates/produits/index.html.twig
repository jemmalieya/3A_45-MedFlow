</div>

{# =========================
   RECO RAILS
   ========================= #}
<div class="container mw-1120 mb-4">
  <section class="reco-zone">
    <div class="reco-head">
      <div>
        <h2 class="reco-title">🔥 Best Sellers</h2>
        <p class="reco-sub">Produits les plus achetés</p>
      </div>
      <div class="reco-chip">Auto</div>
    </div>
    <div class="reco-track" id="bestTrack"></div>
    <div class="reco-empty" id="bestEmpty" style="display:none;">Aucun best-seller</div>
  </section>

  <section class="reco-zone mt-4">
    <div class="reco-head">
      <div>
        <h2 class="reco-title">🤖 Recommandés pour vous</h2>
        <p class="reco-sub" id="aiBasedOnText">Basé sur votre historique</p>
      </div>
      <div class="reco-chip ai">IA</div>
    </div>
    <div class="reco-track" id="aiTrack"></div>
    <div class="reco-empty" id="aiEmpty" style="display:none;">Recommandations indisponibles</div>
  </section>
</div>

{# =========================
   PRODUITS
   ========================= #}
<div class="container mw-1120 mb-5">
  <div class="search-filter-section mb-4">
    <div class="row g-3">

      <div class="col-md-5">
        <div class="search-box">
          <i class="bi bi-search"></i>
          <input type="text" id="searchInput" class="form-control"
                 placeholder="Rechercher (nom, catégorie, description...)">

          <button id="voiceSearchBtn" class="btn-voice" type="button" title="Recherche vocale">
            <i class="bi bi-mic-fill"></i>
          </button>

          <button id="clearSearch" class="btn-clear" style="display:none;" type="button">
            <i class="bi bi-x-circle-fill"></i>
          </button>
        </div>
      </div>

      <div class="col-md-2">
        <select id="sortPrice" class="form-select">
          <option value="">Trier prix</option>
          <option value="asc">Prix ↑</option>
          <option value="desc">Prix ↓</option>
        </select>
      </div>

      <div class="col-md-2">
        <select id="sortStock" class="form-select">
          <option value="">Trier stock</option>
          <option value="desc">Stock ↓</option>
          <option value="asc">Stock ↑</option>
        </select>
      </div>

      <div class="col-md-3">
        <select id="filterCategory" class="form-select">
          <option value="">Toutes catégories</option>
          {% set categories = [] %}
          {% for produit in produits %}
            {% if produit.categorieProduit not in categories %}
              {% set categories = categories|merge([produit.categorieProduit]) %}
            {% endif %}
          {% endfor %}
          {% for categorie in categories|sort %}
            <option value="{{ categorie }}">{{ categorie }}</option>
          {% endfor %}
        </select>
      </div>
    </div>

    <div class="mt-3">
      <span id="resultCount" class="text-muted">
        <i class="bi bi-bag"></i>
        <span id="count">{{ produits|length }}</span> produit(s) trouvé(s)
      </span>
    </div>
  </div>

  {% if produits is not empty %}
    <div class="row g-4" id="produitsContainer">
      {% for produit in produits %}
        <div class="col-lg-3 col-md-4 col-sm-6 produit-item"
             data-nom="{{ produit.nomProduit|lower }}"
             data-categorie="{{ produit.categorieProduit|lower }}"
             data-prix="{{ produit.prixProduit }}"
             data-stock="{{ produit.quantiteProduit }}"
             data-description="{{ produit.descriptionProduit|lower }}">

          <div class="produit-card {% if produit.statusProduit != 'Disponible' %}unavailable{% endif %}">
            <div class="produit-image-container">
              {% if produit.statusProduit != 'Disponible' %}
                <div class="badge-indisponible">{{ produit.statusProduit }}</div>
              {% else %}
                <div class="price-badge">{{ produit.prixProduit }} DT</div>
              {% endif %}

              <img
                src="{% if produit.imageProduit %}
                       {% if produit.imageProduit starts with 'http' %}
                         {{ produit.imageProduit }}
                       {% else %}
                         {{ asset('uploads/produits/' ~ produit.imageProduit) }}
                       {% endif %}
                     {% else %}
                       {{ asset('assets/images/no-image.png') }}
                     {% endif %}"
                class="produit-img {% if produit.statusProduit != 'Disponible' %}img-grayscale{% endif %}"
                alt="{{ produit.nomProduit }}"
                loading="lazy">
            </div>

            <div class="card-body">
              <h5 class="card-title">{{ produit.nomProduit }}</h5>

              <span class="card-category">
                <i class="bi bi-tag"></i> {{ produit.categorieProduit }}
              </span>

              <div class="card-stock">
                <i class="bi bi-box-seam"></i>
                <span>{{ produit.quantiteProduit }} en stock</span>
              </div>

              <span class="status-badge {% if produit.statusProduit == 'Disponible' %}available{% else %}unavailable{% endif %}">
                <i class="bi bi-{% if produit.statusProduit == 'Disponible' %}check{% else %}x{% endif %}-circle"></i>
                {{ produit.statusProduit }}
              </span>

              <div class="card-actions">
                {% if produit.statusProduit == 'Disponible' %}
                  <button class="btn-add-cart"
                          data-id="{{ produit.id_produit }}"
                          data-stock="{{ produit.quantiteProduit }}">
                    <i class="bi bi-cart-plus"></i>
                    <span>Ajouter</span>
                  </button>
                {% else %}
                  <button class="btn-unavailable" disabled>
                    <i class="bi bi-cart-x"></i>
                    <span>Indisponible</span>
                  </button>
                {% endif %}

                <button type="button"
                        class="btn-tts"
                        data-tts-title="{{ produit.nomProduit|e('html_attr') }}"
                        data-tts-desc="{{ produit.descriptionProduit|e('html_attr') }}"
                        data-tts-price="{{ produit.prixProduit }}"
                        data-tts-stock="{{ produit.quantiteProduit }}"
                        data-tts-status="{{ produit.statusProduit|e('html_attr') }}"
                        aria-label="Lire les détails">
                  <i class="bi bi-volume-up-fill"></i>
                </button>

                <button class="btn-details" type="button" data-bs-toggle="modal" data-bs-target="#modal-{{ produit.id_produit }}">
                  <i class="bi bi-info-circle"></i>
                </button>
              </div>
            </div>
          </div>
        </div>

        {# Modal #}
        <div class="modal fade" id="modal-{{ produit.id_produit }}" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title">{{ produit.nomProduit }}</h5>

                <div class="d-flex align-items-center gap-2">
                  <button type="button"
                          class="btn-tts btn-tts-modal"
                          data-tts-title="{{ produit.nomProduit|e('html_attr') }}"
                          data-tts-desc="{{ produit.descriptionProduit|e('html_attr') }}"
                          data-tts-price="{{ produit.prixProduit }}"
                          data-tts-stock="{{ produit.quantiteProduit }}"
                          data-tts-status="{{ produit.statusProduit|e('html_attr') }}">
                    <i class="bi bi-volume-up-fill"></i>
                    <span class="d-none d-md-inline">Lire</span>
                  </button>

                  <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
              </div>

              <div class="modal-body">
                <div class="row">
                  <div class="col-md-5 text-center mb-4 mb-md-0">
                    <img
                      src="{% if produit.imageProduit %}
                             {% if produit.imageProduit starts with 'http' %}
                               {{ produit.imageProduit }}
                             {% else %}
                               {{ asset('uploads/produits/' ~ produit.imageProduit) }}
                             {% endif %}
                           {% else %}
                             {{ asset('assets/images/no-image.png') }}
                           {% endif %}"
                      class="img-fluid"
                      style="max-height:300px;"
                      alt="{{ produit.nomProduit }}">
                  </div>

                  <div class="col-md-7">
                    <div class="detail-row">
                      <span class="detail-label">Description</span>
                      <span class="detail-value">{{ produit.descriptionProduit }}</span>
                    </div>
                    <div class="detail-row">
                      <span class="detail-label">Prix</span>
                      <span class="detail-value fw-bold" style="color: var(--primary-dark)">{{ produit.prixProduit }} DT</span>
                    </div>
                    <div class="detail-row">
                      <span class="detail-label">Quantité</span>
                      <span class="detail-value">{{ produit.quantiteProduit }}</span>
                    </div>
                    <div class="detail-row">
                      <span class="detail-label">Catégorie</span>
                      <span class="detail-value">{{ produit.categorieProduit }}</span>
                    </div>
                    <div class="detail-row">
                      <span class="detail-label">Statut</span>
                      <span class="badge {% if produit.statusProduit == 'Disponible' %}bg-success{% else %}bg-danger{% endif %}">
                        {{ produit.statusProduit }}
                      </span>
                    </div>
                  </div>
                </div>
              </div>

            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    <div id="noResults" class="empty-state" style="display:none;">
      <i class="bi bi-search"></i>
      <h3>Aucun produit trouvé</h3>
      <p>Essayez d'autres mots-clés</p>
    </div>
  {% else %}
    <div class="empty-state">
      <i class="bi bi-inbox"></i>
      <h3>Aucun produit disponible</h3>
    </div>
  {% endif %}
</div>

{# =========================
   MODAL QR CONTACT
   ========================= #}
<div class="modal fade" id="contactQrModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg rounded-4">
      <div class="modal-header">
        <h5 class="modal-title text-white fw-bold">
          <i class="bi bi-person-vcard me-2"></i>Ajouter la pharmacie
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body p-4 text-center">
        <div id="contactQrLoading" class="py-3">
          <div class="spinner-border" role="status"></div>
          <p class="text-muted mt-3 mb-0">Chargement du QR…</p>
        </div>

        <div id="contactQrContent" class="d-none">
          <img id="contactQrImg" src="" alt="QR Contact"
               class="shadow rounded-4"
               style="width:260px;height:260px;">
          <div class="small text-muted mt-3">Scannez avec votre caméra</div>
        </div>

        <div id="contactQrError" class="d-none">
          <i class="bi bi-x-circle-fill text-danger" style="font-size:2rem;"></i>
          <p class="mt-2 mb-0 fw-bold">Impossible d'afficher le QR</p>
          <p class="text-muted mb-0" id="contactQrErrorMsg"></p>
        </div>
      </div>

      <div class="modal-footer bg-light">
        <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Fermer</button>
      </div>
    </div>
  </div>
</div>

{# =========================
   AI Assistant Groq (Pharmacie)
   ========================= #}
<div id="aiFab" class="ai-fab" title="Assistant Pharmacie">
  <i class="bi bi-stars"></i>
</div>

<div id="aiPanel" class="ai-panel d-none">
  <div class="ai-head">
    <div class="ai-title"><span class="ai-dot"></span> Assistant Pharmacie</div>
    <button type="button" id="aiClose" class="ai-x">×</button>
  </div>

  <div id="aiBody" class="ai-body">
    <div class="ai-msg ai-bot">
      Salut 👋 Pose-moi une question sur les produits, précautions, utilisation générale.
    </div>
  </div>

  <div class="ai-foot">
    <input id="aiInput" class="ai-input" placeholder="Ex: Que faire contre la toux ?" maxlength="600">
    <button id="aiSend" class="ai-send"><i class="bi bi-send-fill"></i></button>
  </div>
</div>

{% endblock %}

