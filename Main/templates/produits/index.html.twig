{% extends 'base.html.twig' %}

{% block title %}Pharmacie{% endblock %}

{% block body %}

<style>
/* ======================================================
   ✅ CHARTE (SOLID COLORS - NO GRADIENT)
   Dark Turquoise: #0097B2
   Vivid Turquoise: #00BFA6
   White: #FFFFFF
   Black: #000000
   Red: #BC0B09
   ====================================================== */
:root{
  --primary: #00BFA6;       /* vivid turquoise */
  --primary-dark: #0097B2;  /* dark turquoise */
  --danger: #BC0B09;
  --success: #10b981;
  --warning: #f59e0b;

  --gray-50:#f9fafb;
  --gray-100:#f3f4f6;
  --gray-200:#e5e7eb;
  --gray-700:#374151;
  --gray-800:#1f2937;

  --shadow-sm:0 2px 10px rgba(0,0,0,.06);
  --shadow-md:0 10px 26px rgba(0,0,0,.10);
  --shadow-lg:0 18px 42px rgba(0,0,0,.14);

  --ring: 0 0 0 .22rem rgba(0,151,178,.18);
}

/* Base page */
body{
  background: #f6fbfb !important;
}

/* Container max width for nice layout */
.mw-1120{ max-width:1120px; }

/* ======================================================
   HEADER (SOLID)
   ====================================================== */
.page-header{
  background: var(--primary-dark);
  color:#fff;
  padding: 42px 0;
  margin: 26px auto 18px auto;
  border-radius: 20px;
  box-shadow: 0 18px 40px rgba(0,151,178,.22);
  overflow:hidden;
  position:relative;
}
.page-header::after{
  content:"";
  position:absolute;
  inset:-2px;
  background:
    radial-gradient(900px 240px at 18% 10%, rgba(255,255,255,.16), transparent 55%),
    radial-gradient(900px 240px at 80% 0%, rgba(255,255,255,.10), transparent 55%);
  pointer-events:none;
}
.page-header h1{
  font-size: 2.6rem;
  font-weight: 900;
  margin:0 0 8px 0;
  position:relative;
  z-index:1;
}
.page-header p{
  margin:0;
  opacity:.92;
  font-size: 1.05rem;
  position:relative;
  z-index:1;
}

/* ======================================================
   QUICK ACTIONS BAR (Mes commandes + Contact)
   ====================================================== */
.quick-actions{
  background:#fff;
  border-radius: 18px;
  box-shadow: var(--shadow-sm);
  border: 1px solid rgba(0,151,178,.10);
  padding: 14px 16px;
}

.btn-orders{
  display:inline-flex; align-items:center; gap:10px;
  padding: 12px 16px;
  border-radius: 14px;
  border: none;
  background: var(--primary-dark);
  color:#fff;
  font-weight: 900;
  text-decoration:none;
  box-shadow: 0 12px 26px rgba(0,151,178,.18);
  transition:.2s ease;
}
.btn-orders:hover{
  transform: translateY(-1px);
  color:#fff;
  box-shadow: 0 16px 34px rgba(0,151,178,.26);
}

.btn-contact{
  display:inline-flex; align-items:center; gap:10px;
  padding: 12px 16px;
  border-radius: 14px;
  border: 2px solid rgba(0,151,178,.25);
  background: #fff;
  color: var(--primary-dark);
  font-weight: 900;
  transition:.2s ease;
}
.btn-contact:hover{
  transform: translateY(-1px);
  background: rgba(0,191,166,.10);
  box-shadow: 0 12px 28px rgba(0,151,178,.12);
}

/* ======================================================
   FLASH MESSAGES
   ====================================================== */
#flash-messages-container{
  position: fixed;
  top: 20px;
  right: 20px;
  z-index: 2000;
  max-width: 420px;
}
.alert-custom{
  display:flex; align-items:center; gap:12px;
  padding: 14px 18px;
  border-radius: 14px;
  margin-bottom: 12px;
  box-shadow: var(--shadow-md);
  opacity: 0;
  transform: translateX(100px);
  transition: all .25s ease;
}
.alert-custom.show{ opacity: 1; transform: translateX(0); }
.alert-success{ background: #d1fae5; color:#065f46; border-left:5px solid var(--success); }
.alert-error{ background: #fee2e2; color:#991b1b; border-left:5px solid var(--danger); }
.btn-close-custom{
  margin-left:auto;
  background:none; border:none;
  font-size: 1.35rem;
  cursor:pointer;
  color: inherit;
  opacity:.6;
}
.btn-close-custom:hover{ opacity:1; }

/* ======================================================
   RECO RAILS (Best Sellers / Recommandés) — PRO + SOLID
   ====================================================== */
.reco-zone{
  background:#fff;
  border-radius: 18px;
  box-shadow: var(--shadow-sm);
  border: 1px solid rgba(0,151,178,.10);
  padding: 16px;
}
.reco-head{
  display:flex; align-items:flex-start; justify-content:space-between;
  gap: 12px; flex-wrap:wrap;
  margin-bottom: 12px;
}
.reco-title{
  margin:0;
  font-weight: 1000;
  font-size: 1.25rem;
  color: var(--gray-800);
}
.reco-sub{
  margin: 4px 0 0 0;
  color: #6b7280;
}
.reco-chip{
  display:inline-flex;
  align-items:center;
  padding: 6px 12px;
  border-radius: 999px;
  font-weight: 900;
  font-size: .8rem;
  background: rgba(0,191,166,.14);
  color: var(--primary-dark);
}
.reco-chip.ai{
  background: rgba(0,151,178,.14);
  color: var(--primary-dark);
}

.reco-track{
  display:flex;
  gap: 12px;
  overflow:auto;
  padding-bottom: 6px;
  scroll-behavior:smooth;
}
.reco-track::-webkit-scrollbar{ height:8px; }
.reco-track::-webkit-scrollbar-thumb{
  background: rgba(0,151,178,.18);
  border-radius: 20px;
}

.reco-card{
  min-width: 210px;
  background:#fff;
  border-radius: 14px;
  border: 1px solid #e5e7eb;
  padding: 12px;
  transition: .2s ease;
}
.reco-card:hover{
  transform: translateY(-3px);
  box-shadow: 0 12px 26px rgba(0,0,0,.10);
  border-color: rgba(0,151,178,.22);
}
.reco-img{
  width:100%;
  height: 140px;
  object-fit: contain;
  border-radius: 12px;
  background: #f8fafc;
  padding: 8px;
}
.reco-body{ margin-top: 10px; }
.reco-cat{
  display:inline-block;
  font-size: .75rem;
  font-weight: 800;
  color: var(--primary-dark);
  background: rgba(0,191,166,.12);
  padding: 4px 10px;
  border-radius: 999px;
  margin-bottom: 8px;
}
.reco-name{
  font-weight: 900;
  font-size: .95rem;
  color: #111827;
  margin:0 0 8px 0;
  display:-webkit-box;
  -webkit-line-clamp:2;
  -webkit-box-orient:vertical;
  overflow:hidden;
}
.reco-price{
  font-weight: 1000;
  color: var(--primary-dark);
  font-size: 1.1rem;
  margin: 0 0 10px 0;
}
.reco-add{
  width:100%;
  border:none;
  border-radius: 12px;
  padding: 10px 12px;
  background: var(--primary-dark);
  color:#fff;
  font-weight: 1000;
  display:flex; align-items:center; justify-content:center; gap:8px;
  transition:.2s ease;
}
.reco-add:hover{ transform: translateY(-1px); box-shadow: 0 12px 26px rgba(0,151,178,.20); }

/* ======================================================
   SEARCH / FILTERS
   ====================================================== */
.search-filter-section{
  background:#fff;
  padding: 18px;
  border-radius: 18px;
  box-shadow: var(--shadow-sm);
  border: 1px solid rgba(0,151,178,.10);
}
.search-box{ position:relative; }
.search-box i.bi-search{
  position:absolute;
  left:15px; top:50%;
  transform: translateY(-50%);
  color:#6c757d;
  font-size: 18px;
}
.search-box input{
  padding-left:45px;
  padding-right:86px;
  height: 46px;
  border:2px solid #e9ecef;
  border-radius: 12px;
  transition:.2s ease;
}
.search-box input:focus{
  border-color: var(--primary-dark);
  box-shadow: var(--ring);
}
.form-select{
  height:46px;
  border:2px solid #e9ecef;
  border-radius: 12px;
}
.form-select:focus{
  border-color: var(--primary-dark);
  box-shadow: var(--ring);
}
#resultCount #count{ color: var(--primary-dark); font-weight: 1000; }

.btn-clear{
  position:absolute;
  right:10px; top:50%;
  transform: translateY(-50%);
  background:none; border:none;
  color:#6c757d;
  cursor:pointer;
  padding:5px;
}
.btn-clear:hover{ color: var(--danger); }

.btn-voice{
  position:absolute;
  right:44px;
  top:50%;
  transform: translateY(-50%);
  width:34px; height:34px;
  border-radius: 12px;
  border:2px solid rgba(0,151,178,.22);
  background:#fff;
  color: var(--primary-dark);
  display:flex; align-items:center; justify-content:center;
  cursor:pointer;
  transition:.2s ease;
}
.btn-voice:hover{ background: rgba(0,191,166,.10); }
.btn-voice.listening{
  background: var(--primary-dark);
  color:#fff;
  border-color: transparent;
  box-shadow: 0 12px 26px rgba(0,151,178,.18);
}

/* ======================================================
   PRODUCT CARDS
   ====================================================== */
.produit-card{
  background:#fff;
  border-radius: 20px;
  overflow:hidden;
  border: 1px solid #eef2f7;
  height:100%;
  display:flex;
  flex-direction:column;
  transition:.25s ease;
}
.produit-card:hover{
  transform: translateY(-6px);
  box-shadow: var(--shadow-lg);
  border-color: rgba(0,151,178,.25);
}
.produit-image-container{
  position:relative;
  width:100%;
  height: 240px;
  background: #f7fafc;  /* ✅ SOLID (no gradient) */
  overflow:hidden;
}
.produit-img{
  width:100%; height:100%;
  object-fit: contain;
  padding: 18px;
  transition: transform .25s ease;
}
.produit-card:hover .produit-img:not(.img-grayscale){ transform: scale(1.06); }
.img-grayscale{ filter: grayscale(100%) opacity(.5); }

.price-badge{
  position:absolute;
  top:14px; right:14px;
  background: var(--primary-dark); /* ✅ SOLID */
  color:#fff;
  padding: 8px 14px;
  border-radius: 999px;
  font-weight: 1000;
  font-size: 1rem;
  box-shadow: 0 12px 26px rgba(0,151,178,.18);
  z-index:10;
}
.badge-indisponible{
  position:absolute;
  top:14px; left:14px;
  background: var(--danger); /* ✅ SOLID */
  color:#fff;
  padding: 8px 14px;
  border-radius: 999px;
  font-weight: 900;
  font-size: .8rem;
  text-transform: uppercase;
  letter-spacing: .4px;
  box-shadow: 0 12px 26px rgba(188,11,9,.18);
  z-index:10;
}

.card-body{
  padding: 20px;
  display:flex;
  flex-direction:column;
  flex-grow:1;
}
.card-title{
  font-size: 1.12rem;
  font-weight: 1000;
  color: var(--gray-800);
  margin: 0 0 10px 0;
  line-height: 1.35;
  display:-webkit-box;
  -webkit-line-clamp:2;
  -webkit-box-orient:vertical;
  overflow:hidden;
}
.card-category{
  display:inline-flex;
  align-items:center;
  gap:6px;
  padding: 6px 12px;
  background: rgba(0,191,166,.12);
  color: var(--primary-dark);
  border-radius: 999px;
  font-size: .82rem;
  font-weight: 900;
  margin-bottom: 10px;
}
.card-stock{
  display:flex; align-items:center; gap:8px;
  font-size: .9rem;
  color: #6b7280;
  margin-bottom: 12px;
}

/* status */
.status-badge{
  padding: 8px 14px;
  border-radius: 999px;
  font-weight: 900;
  font-size: .82rem;
  margin-bottom: 14px;
  display:inline-flex;
  align-items:center;
  gap:6px;
}
.status-badge.available{
  background: rgba(0,191,166,.14);
  color: #065f46;
}
.status-badge.unavailable{
  background:#fee2e2;
  color:#991b1b;
}

.card-actions{
  display:flex;
  gap:10px;
  margin-top:auto;
}

/* ✅ AJOUTER (SOLID + texte blanc forcé) */
.btn-add-cart{
  flex:1;
  padding: 12px;
  background: var(--primary-dark);  /* ✅ SOLID */
  color:#fff !important;
  border:none;
  border-radius: 14px;
  font-weight: 1000;
  cursor:pointer;
  transition:.2s ease;
  display:flex;
  align-items:center;
  justify-content:center;
  gap:8px;
  opacity: 1 !important;
}
.btn-add-cart i,
.btn-add-cart span{ color:#fff !important; opacity: 1 !important; }

.btn-add-cart:hover{
  transform: translateY(-1px);
  box-shadow: 0 14px 30px rgba(0,151,178,.22);
}

.btn-details{
  padding: 12px 16px;
  background:#fff;
  color: var(--primary-dark);
  border:2px solid rgba(0,151,178,.25);
  border-radius: 14px;
  font-weight: 1000;
  cursor:pointer;
  transition:.2s ease;
}
.btn-details:hover{
  background: rgba(0,191,166,.10);
}

.btn-unavailable{
  flex:1;
  padding: 12px;
  background: var(--gray-200);
  color:#6b7280;
  border:none;
  border-radius: 14px;
  font-weight: 900;
  cursor:not-allowed;
  display:flex; align-items:center; justify-content:center; gap:8px;
}

/* TTS */
.btn-tts{
  width: 46px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  border-radius: 14px;
  border:2px solid rgba(0,151,178,.22);
  background:#fff;
  color: var(--primary-dark);
  font-weight: 1000;
  cursor:pointer;
  transition:.2s ease;
}
.btn-tts:hover{
  background: rgba(0,191,166,.10);
  transform: translateY(-1px);
}
.btn-tts.is-speaking{
  background: var(--primary-dark);
  color:#fff;
  border-color: transparent;
}
.btn-tts-modal{
  width:auto;
  padding: 10px 14px;
  gap:8px;
  display:inline-flex; align-items:center;
}

/* Empty state */
.empty-state{ text-align:center; padding: 70px 20px; }
.empty-state i{ font-size: 4.5rem; color: #d1d5db; margin-bottom: 18px; }
.empty-state h3{ color: var(--gray-800); margin-bottom: 8px; font-weight: 1000; }
.empty-state p{ color:#6b7280; }

/* Modal */
.modal-content{ border-radius: 20px; border:none; overflow:hidden; }
.modal-header{
  background: var(--primary-dark); /* ✅ SOLID */
  color:#fff;
  border:none;
  padding: 20px;
}
.modal-title{ font-weight: 1000; font-size: 1.2rem; }
.modal-body{ padding: 26px; }
.modal-body img{ border-radius: 14px; box-shadow: var(--shadow-md); }

.detail-row{
  display:flex;
  justify-content:space-between;
  gap:12px;
  padding: 10px 0;
  border-bottom: 1px solid var(--gray-200);
}
.detail-row:last-child{ border-bottom:none; }
.detail-label{ font-weight: 1000; color: var(--gray-800); }
.detail-value{ color:#6b7280; }

/* QR modal */
#contactQrModal .modal-header{
  background: var(--primary-dark) !important;
}
#contactQrModal .spinner-border{ color: var(--primary-dark) !important; }

/* AI fab */
.ai-fab{
  position: fixed;
  right: 22px;
  bottom: 22px;
  width: 56px; height: 56px;
  border-radius: 18px;
  display:flex; align-items:center; justify-content:center;
  cursor:pointer;
  z-index: 9999;
  color:#fff;
  background: var(--primary-dark); /* ✅ SOLID */
  box-shadow: 0 18px 40px rgba(0,151,178,.22);
  transition:.2s ease;
}
.ai-fab:hover{ transform: translateY(-1px); }

.ai-panel{
  position: fixed;
  right: 22px;
  bottom: 90px;
  width: 360px;
  max-width: calc(100vw - 44px);
  background:#fff;
  border-radius: 18px;
  box-shadow: 0 20px 60px rgba(15,23,42,.25);
  overflow:hidden;
  z-index: 9999;
  border: 1px solid rgba(0,151,178,.18);
}
.ai-panel.d-none{ display:none; }
.ai-head{
  padding: 12px 14px;
  background: var(--primary-dark); /* ✅ SOLID */
  color:#fff;
  display:flex; align-items:center; justify-content:space-between;
}
.ai-title{ font-weight: 1000; display:flex; align-items:center; gap:10px; }
.ai-dot{ width:10px; height:10px; border-radius:50%; background:#22c55e; box-shadow:0 0 0 4px rgba(34,197,94,.18); }
.ai-x{
  background: rgba(255,255,255,.18);
  border: 1px solid rgba(255,255,255,.28);
  color:#fff;
  width:34px; height:34px;
  border-radius: 12px;
  font-size: 20px;
  line-height:1;
  cursor:pointer;
}
.ai-body{
  padding: 14px;
  height: 320px;
  overflow:auto;
  background: #f6fbfb; /* ✅ SOLID */
}
.ai-msg{
  padding: 10px 12px;
  border-radius: 14px;
  margin: 10px 0;
  max-width: 92%;
  font-size: .95rem;
  line-height: 1.35;
  box-shadow: 0 10px 20px rgba(15,23,42,.08);
}
.ai-user{
  margin-left:auto;
  background: var(--primary-dark);
  color:#fff;
  border-bottom-right-radius: 6px;
}
.ai-bot{
  background:#fff;
  color:#0f172a;
  border-bottom-left-radius: 6px;
  border: 1px solid rgba(0,151,178,.12);
}
.ai-foot{
  padding: 12px;
  display:flex; gap:10px;
  border-top: 1px solid rgba(0,151,178,.12);
  background:#fff;
}
.ai-input{
  flex:1;
  border: 2px solid rgba(0,151,178,.18);
  border-radius: 14px;
  padding: 10px 12px;
  outline:none;
}
.ai-input:focus{ border-color: rgba(0,151,178,.55); box-shadow: 0 0 0 4px rgba(0,151,178,.12); }
.ai-send{
  width:44px; height:44px;
  border-radius: 14px;
  border:none;
  color:#fff;
  background: var(--primary-dark); /* ✅ SOLID */
  box-shadow: 0 12px 26px rgba(0,151,178,.18);
  cursor:pointer;
  transition:.2s ease;
}
.ai-send:hover{ transform: translateY(-1px); }

@media (max-width:768px){
  .page-header h1{ font-size: 2rem; }
  .produit-image-container{ height: 200px; }
  .card-actions{ flex-direction:column; }
}
/* ================================
   ✅ SOLID THEME (NO GRADIENT)
   (ne touche pas au caroussel)
   ================================ */

:root{
  --primary: #00BFA6 !important;
  --primary-dark: #0097B2 !important;
}

/* Header solid */
.page-header{
  background: var(--primary-dark) !important;
}

/* Boutons solid */
.btn-orders,
.btn-add-cart,
.ai-fab,
.ai-head,
.ai-send{
  background: var(--primary-dark) !important;
  background-image: none !important;
}

/* Price badge solid */
.price-badge{
  background: var(--primary-dark) !important;
  background-image: none !important;
}

/* Modal header solid */
.modal-header{
  background: var(--primary-dark) !important;
  background-image: none !important;
}

/* ✅ Texte Ajouter bien BLANC (pas faded) */
.btn-add-cart,
.btn-add-cart *{
  color: #fff !important;
  opacity: 1 !important;
}

/* ✅ Focus turquoise */
.search-box input:focus,
.form-select:focus{
  border-color: var(--primary-dark) !important;
  box-shadow: 0 0 0 .2rem rgba(0,151,178,.18) !important;
}

/* ======================================================
   ✅ UPGRADE DESIGN — CARDS RECOMMANDÉS (CARROUSEL)
   (ne change pas la logique du carrousel)
   ====================================================== */

/* Carte reco plus premium */
.reco-card{
  position: relative;
  min-width: 230px;              /* un peu + large */
  border-radius: 18px;
  padding: 14px;
  border: 1px solid rgba(0,151,178,.14);
  box-shadow: 0 10px 24px rgba(0,0,0,.06);
  overflow: hidden;
}

.reco-card:hover{
  transform: translateY(-4px);
  box-shadow: 0 18px 34px rgba(0,0,0,.10);
  border-color: rgba(0,151,178,.28);
}

/* Ligne badges en haut (Recommandé / Même catégorie)
   👉 marche même si ce sont juste des textes dans un "premier div" du card */
.reco-card > :first-child{
  display:flex;
  align-items:center;
  gap:8px;
  flex-wrap:wrap;
  font-weight: 900;
  font-size: .82rem;
  color: var(--primary-dark);
  margin-bottom: 10px;
}

/* Style “pill” sur les 2 textes (Recommandé / Même catégorie)
   Si ton JS les met dans des <span>, c’est encore mieux (voir plus bas) */
.reco-card > :first-child span,
.reco-card > :first-child .badge,
.reco-card > :first-child .tag,
.reco-card > :first-child .chip{
  display:inline-flex;
  align-items:center;
  gap:6px;
  padding: 6px 10px;
  border-radius: 999px;
  background: rgba(0,191,166,.12);
  color: var(--primary-dark);
  border: 1px solid rgba(0,151,178,.18);
}

/* Image : cadre propre + centrage */
.reco-img{
  height: 150px;
  border-radius: 14px;
  background: #f7fafc;
  border: 1px solid rgba(0,151,178,.10);
  padding: 10px;
  object-fit: contain;
}

/* Corps : alignement plus propre */
.reco-body{
  margin-top: 12px;
  display:flex;
  flex-direction:column;
  gap:8px;
}

/* Catégorie : plus clean */
.reco-cat{
  font-weight: 900;
  font-size: .78rem;
  padding: 5px 10px;
  border-radius: 999px;
  background: rgba(0,191,166,.10);
  color: var(--primary-dark);
  border: 1px solid rgba(0,151,178,.14);
  width: fit-content;
}

/* Nom : meilleur rendu + hauteur stable */
.reco-name{
  font-size: 1rem;
  line-height: 1.35;
  min-height: 44px;             /* stabilise les cartes */
  margin: 0;
}

/* Prix : plus visible */
.reco-price{
  font-size: 1.15rem;
  font-weight: 1000;
  color: var(--primary-dark);
  margin: 0;
}

/* Bouton ajouter : full width + plus premium */
.reco-add{
  margin-top: 6px;
  border-radius: 14px;
  padding: 11px 12px;
  font-weight: 1000;
  letter-spacing: .2px;
  box-shadow: 0 10px 22px rgba(0,151,178,.14);
}
.reco-add:hover{
  box-shadow: 0 14px 30px rgba(0,151,178,.22);
}


</style>

{# =========================
   FLASH MESSAGES
   ========================= #}
<div id="flash-messages-container">
  {% for label, messages in app.flashes %}
    {% for message in messages %}
      <div class="alert-custom alert-{{ label }} show" role="alert">
        <i class="bi bi-{% if label == 'success' %}check{% else %}x{% endif %}-circle-fill"></i>
        <span>{{ message }}</span>
        <button type="button" class="btn-close-custom" onclick="this.parentElement.remove()">×</button>
      </div>
    {% endfor %}
  {% endfor %}
</div>

{# =========================
   HEADER
   ========================= #}
<div class="container mw-1120">
  <div class="page-header">
    <div class="container text-center">
      <h1><i class="bi bi-shop me-3"></i>Notre Pharmacie</h1>
      <p>Découvrez notre sélection de produits de santé et bien-être</p>
    </div>
  </div>
  <button id="themeToggle" class="btn-contact" type="button">
  <i class="bi bi-moon-stars"></i> Mode sombre
</button>
</div>

{# =========================
   QUICK ACTIONS
   ========================= #}
<div class="container mw-1120 mb-4">
  <div class="quick-actions d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div class="text-muted">
      <i class="bi bi-info-circle me-1"></i>
      Retrouvez toutes vos commandes ici.
    </div>

    <div class="d-flex gap-2">
      <a href="{{ path('mes_commandes') }}" class="btn-orders">
        <i class="bi bi-bag-check-fill"></i> Mes commandes
      </a>

      <button type="button" class="btn-contact" id="btnContactQr">
        <i class="bi bi-person-vcard"></i> Contact
