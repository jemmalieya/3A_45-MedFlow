{% extends 'base_admin.html.twig' %}

{% block title %}Liste consultations{% endblock %}
{% block page_title %}Gestion des Consultations{% endblock %}


{% block body %}
<style>
    .card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
        overflow: hidden;
    }
    .card-header {
        background: linear-gradient(135deg, #058096 0%, #058096 100%);
        color: white;
        border: none;
        padding: 20px 24px;
        font-weight: 600;
    }
    .card-body {
        padding: 25px;
    }
    .badge {
        padding: 8px 12px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.85rem;
        letter-spacing: 0.3px;
    }
    .badge-info {
        background: linear-gradient(135deg, #058096 0%, #058096 100%);
        color: white;
    }
    .badge-secondary {
        background: linear-gradient(135deg, #6b7280 0%, #4b5563 100%);
        color: white;
    }
    .btn-primary, .btn-success {
        background: linear-gradient(135deg, #058096 0%, #058096 100%);
        border: none;
        border-radius: 8px;
        padding: 8px 16px;
        font-weight: 600;
        color: white;
        transition: all 0.3s ease;
    }
    .btn-primary:hover, .btn-success:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(5, 128, 150, 0.4);
        color: white;
    }
    .btn-light {
        background: #f5f7fa;
        color: #058096;
        border-radius: 8px;
        border: none;
        font-weight: 600;
        transition: all 0.3s ease;
    }
    .btn-light:hover {
        background: #e0f2f1;
        color: #058096;
    }
    .table-primary, .table-info, .table-success {
        background: linear-gradient(135deg, #e0f2f1 0%, #f5f7fa 100%);
        color: #058096;
    }
    .table-bordered th, .table-bordered td {
        border-color: #e2e8f0;
    }
    .table thead th {
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.4px;
        font-size: 0.9rem;
    }
    .table tbody tr:hover {
        background-color: #e0f2f1;
    }
    .alert-info {
        background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%);
        border-left-color: #058096;
        color: #058096;
        border-radius: 10px;
        border-left: 4px solid #058096;
        font-weight: 600;
    }
    .bg-light {
        background: #e0f2f1 !important;
    }
    .text-primary {
        color: #058096 !important;
    }
</style>


{# ========== STATISTIQUES RENDEZ-VOUS ========== #}
<div class="row g-4 mb-4">
    <div class="col-lg-3 col-md-6">
        <div class="card stretch stretch-full">
            <div class="card-body text-center">
                <div class="avatar-text avatar-lg bg-soft-primary text-primary mx-auto mb-3">
                    <i class="feather-calendar"></i>
                </div>
                <h3 class="mb-0 fw-bold">{{ totalRendezVous }}</h3>
                <p class="text-muted mb-0 fs-12">Total Rendez-vous</p>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6">
        <div class="card stretch stretch-full">
            <div class="card-body text-center">
                <div class="avatar-text avatar-lg bg-soft-warning text-warning mx-auto mb-3">
                    <i class="feather-clock"></i>
                </div>
                <h3 class="mb-0 fw-bold">{{ rdvDemande }}</h3>
                <p class="text-muted mb-0 fs-12">Demande</p>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6">
        <div class="card stretch stretch-full">
            <div class="card-body text-center">
                <div class="avatar-text avatar-lg bg-soft-info text-info mx-auto mb-3">
                    <i class="feather-check"></i>
                </div>
                <h3 class="mb-0 fw-bold">{{ rdvConfirme }}</h3>
                <p class="text-muted mb-0 fs-12">Confirmé</p>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6">
        <div class="card stretch stretch-full">
            <div class="card-body text-center">
                <div class="avatar-text avatar-lg bg-soft-success text-success mx-auto mb-3">
                    <i class="feather-check-circle"></i>
                </div>
                <h3 class="mb-0 fw-bold">{{ rdvTerminee }}</h3>
                <p class="text-muted mb-0 fs-12">Terminée</p>
            </div>
        </div>
    </div>
</div>

<main class="container-fluid py-4">
        <h1 class="mb-4 text-primary">Supervision des Médecins & Activités</h1>
        <div class="mb-5">
            <div class="row">
                {% for doctor in doctors %}
                <div class="col-12 mb-4">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                            <div>
                                <strong>Dr. {{ doctor.nom }} {{ doctor.prenom }}</strong>
                                <span class="badge bg-info ms-2">{{ doctor.typeStaff }}</span>
                                <span class="badge bg-secondary ms-2">ID: {{ doctor.id }}</span>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <span class="text-light small">Téléphone: {{ doctor.telephoneUser }}</span>
                                <span class="text-light small ms-3">Email: {{ doctor.emailUser }}</span>
                                <button class="btn btn-light btn-sm ms-3" type="button" data-bs-toggle="collapse" data-bs-target="#doctorCardBody-{{ doctor.id }}" aria-expanded="true" aria-controls="doctorCardBody-{{ doctor.id }}">
                                    <span class="collapsed"><i class="feather-chevron-down"></i></span>
                                    <span class="not-collapsed"><i class="feather-chevron-up"></i></span>
                                </button>
                            </div>
                        </div>
                        <div id="doctorCardBody-{{ doctor.id }}" class="collapse show">
                            <div class="card-body bg-light">
                                <ul class="nav nav-tabs mb-3" id="doctorTabs-{{ doctor.id }}" role="tablist">
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link active" id="rdv-tab-{{ doctor.id }}" data-bs-toggle="tab" data-bs-target="#rdv-{{ doctor.id }}" type="button" role="tab" aria-controls="rdv-{{ doctor.id }}" aria-selected="true">Rendez-vous</button>
                                    </li>
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link" id="fiche-tab-{{ doctor.id }}" data-bs-toggle="tab" data-bs-target="#fiche-{{ doctor.id }}" type="button" role="tab" aria-controls="fiche-{{ doctor.id }}" aria-selected="false">Fiches médicales</button>
                                    </li>
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link" id="presc-tab-{{ doctor.id }}" data-bs-toggle="tab" data-bs-target="#presc-{{ doctor.id }}" type="button" role="tab" aria-controls="presc-{{ doctor.id }}" aria-selected="false">Prescriptions</button>
                                    </li>
                                </ul>
                                <div class="tab-content" id="doctorTabsContent-{{ doctor.id }}">
                                    <!-- Rendez-vous Tab -->
                                    <div class="tab-pane fade show active" id="rdv-{{ doctor.id }}" role="tabpanel" aria-labelledby="rdv-tab-{{ doctor.id }}">
                                        {% if doctor.rendezvous|length > 0 %}
                                        <div class="table-responsive">
                                            <table class="table table-bordered table-sm align-middle">
                                                <thead class="table-primary">
                                                    <tr>
                                                        <th>ID</th>
                                                        <th>Date & Heure</th>
                                                        <th>Statut</th>
                                                        <th>Patient</th>
                                                        <th>Motif</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    {% for rdv in doctor.rendezvous %}
                                                    <tr>
                                                        <td>{{ rdv.id }}</td>
                                                        <td>{{ rdv.datetime ? rdv.datetime|date('d/m/Y H:i') : '—' }}</td>
                                                        <td>{{ rdv.statut }}</td>
                                                        <td>{{ rdv.getPatient ? rdv.getPatient().nom ~ ' ' ~ rdv.getPatient().prenom : '—' }}</td>
                                                        <td>{{ rdv.motif }}</td>
                                                    </tr>
                                                    {% endfor %}
                                                </tbody>
                                            </table>
                                        </div>
                                        {% else %}
                                            <div class="alert alert-info">Aucun rendez-vous trouvé.</div>
                                        {% endif %}
                                    </div>
                                    <!-- Fiches Médicales Tab -->
                                    <div class="tab-pane fade" id="fiche-{{ doctor.id }}" role="tabpanel" aria-labelledby="fiche-tab-{{ doctor.id }}">
                                        {% if doctor.fiches|length > 0 %}
                                        <div class="table-responsive">
                                            <table class="table table-bordered table-sm align-middle">
                                                <thead class="table-info">
                                                    <tr>
                                                        <th>ID</th>
                                                        <th>Patient</th>
                                                        <th>Diagnostic</th>
                                                        <th>Date</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    {% for fiche in doctor.fiches %}
                                                    <tr>
                                                        <td>{{ fiche.id }}</td>
                                                        <td>{{ fiche.getRendezVous and fiche.getRendezVous() and fiche.getRendezVous().getPatient ? fiche.getRendezVous().getPatient().nom ~ ' ' ~ fiche.getRendezVous().getPatient().prenom : '—' }}</td>
                                                        <td>{{ fiche.diagnostic|default('—') }}</td>
                                                        <td>{{ fiche.createdAt ? fiche.createdAt|date('d/m/Y H:i') : '—' }}</td>
                                                    </tr>
                                                    {% endfor %}
                                                </tbody>
                                            </table>
                                        </div>
                                        {% else %}
                                            <div class="alert alert-info">Aucune fiche médicale trouvée.</div>
                                        {% endif %}
                                    </div>
                                    <!-- Prescriptions Tab -->
                                    <div class="tab-pane fade" id="presc-{{ doctor.id }}" role="tabpanel" aria-labelledby="presc-tab-{{ doctor.id }}">
                                        {% if doctor.prescriptions|length > 0 %}
                                        <div class="table-responsive">
                                            <table class="table table-bordered table-sm align-middle">
                                                <thead class="table-success">
                                                    <tr>
                                                        <th>ID</th>
                                                        <th>Médicament</th>
                                                        <th>Patient</th>
                                                        <th>Date</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    {% for presc in doctor.prescriptions %}
                                                    <tr>
                                                        <td>{{ presc.id }}</td>
                                                        <td>{{ presc.nomMedicament|default('—') }}</td>
                                                        <td>{{ presc.ficheMedicale and presc.ficheMedicale.getRendezVous and presc.ficheMedicale.getRendezVous() and presc.ficheMedicale.getRendezVous().getPatient ? presc.ficheMedicale.getRendezVous().getPatient().nom ~ ' ' ~ presc.ficheMedicale.getRendezVous().getPatient().prenom : '—' }}</td>
                                                        <td>{{ presc.createdAt ? presc.createdAt|date('d/m/Y') : '—' }}</td>
                                                    </tr>
                                                    {% endfor %}
                                                </tbody>
                                            </table>
                                        </div>
                                        {% else %}
                                            <div class="alert alert-info">Aucune prescription trouvée.</div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </main>
{% endblock %}
