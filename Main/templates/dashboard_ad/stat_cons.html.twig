{% extends 'base_admin.html.twig' %}

{% block title %}Liste consultations{% endblock %}
{% block page_title %}Gestion des Consultations{% endblock %}


{% block body %}









<style>
        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
            transition: all 0.3s ease;
            overflow: hidden;
        }
        .card-header {
            background: linear-gradient(135deg, #058096 0%, #058096 100%);
            color: white;
            border: none;
            padding: 20px 24px;
            font-weight: 600;
        }
        .card-body {
            padding: 25px;
        }
        .badge {
            padding: 8px 12px;
            border-radius: 20px;
            font-weight: 600;
            font-size: 0.85rem;
            letter-spacing: 0.3px;
        }
        .badge-info {
            background: linear-gradient(135deg, #058096 0%, #058096 100%);
            color: white;
        }
        .badge-secondary {
            background: linear-gradient(135deg, #6b7280 0%, #4b5563 100%);
            color: white;
        }
        .btn-primary, .btn-success {
            background: linear-gradient(135deg, #058096 0%, #058096 100%);
            border: none;
            border-radius: 8px;
            padding: 8px 16px;
            font-weight: 600;
            color: white;
            transition: all 0.3s ease;
        }
        .btn-primary:hover, .btn-success:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(5, 128, 150, 0.4);
            color: white;
        }
        .btn-light {
            background: #f5f7fa;
            color: #058096;
            border-radius: 8px;
            border: none;
            font-weight: 600;
            transition: all 0.3s ease;
        }
        .btn-light:hover {
            background: #e0f2f1;
            color: #058096;
        }
        .table-primary, .table-info, .table-success {
            background: linear-gradient(135deg, #e0f2f1 0%, #f5f7fa 100%);
            color: #058096;
        }
        .table-bordered th, .table-bordered td {
            border-color: #e2e8f0;
        }
        .table thead th {
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            font-size: 0.9rem;
        }
        .table tbody tr:hover {
            background-color: #e0f2f1;
        }
        .alert-info {
            background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%);
            border-left-color: #058096;
            color: #058096;
            border-radius: 10px;
            border-left: 4px solid #058096;
            font-weight: 600;
        }
        .bg-light {
            background: #e0f2f1 !important;
        }
        .text-primary {
            color: #058096 !important;
        }
    </style>
    <main class="container py-4">
        <h1 class="mb-4 text-primary">Statistiques des Médecins & Consultations</h1>
        <div class="row mb-4">
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm border-0">
                    <div class="card-body text-center">
                        <h5 class="card-title text-success">Total Médecins</h5>
                        <h2 class="display-5 fw-bold">{{ totalDoctors }}</h2>
                        <p class="text-muted">Médecins actifs dans le système</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm border-0">
                    <div class="card-body text-center">
                        <h5 class="card-title text-primary">Total Rendez-vous</h5>
                        <h2 class="display-5 fw-bold">{{ totalRendezVous }}</h2>
                        <p class="text-muted">Rendez-vous enregistrés</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm border-0">
                    <div class="card-body text-center">
                        <h5 class="card-title text-info">Total Fiches Médicales</h5>
                        <h2 class="display-5 fw-bold">{{ totalFiches }}</h2>
                        <p class="text-muted">Fiches médicales créées</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="row mb-4">
            <div class="col-md-6 mb-3">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-primary text-white">Répartition des Rendez-vous par Statut</div>
                    <div class="card-body">
                        <div id="pieRdvStatut" style="height:300px;"></div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-3">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-success text-white">Répartition des Fiches Médicales par Diagnostic</div>
                    <div class="card-body">
                        <div id="pieFicheDiagnostic" style="height:300px;"></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row mb-4">
            <div class="col-md-12 mb-3">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-info text-white">Consultations par Médecin</div>
                    <div class="card-body">
                        <div id="barDoctorsConsultations" style="height:350px;"></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row mb-4">
            <div class="col-md-6 mb-3">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-warning text-white">Rendez-vous par Jour</div>
                    <div class="card-body">
                        <div id="lineRdvDay" style="height:300px;"></div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-3">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-secondary text-white">Fiches Médicales par Jour</div>
                    <div class="card-body">
                        <div id="lineFicheDay" style="height:300px;"></div>
                    </div>
                </div>
            </div>
        </div>
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                // Pie chart for rendez-vous status
                var pieRdvStatut = new ApexCharts(document.querySelector("#pieRdvStatut"), {
                    chart: { type: 'pie', height: 300 },
                    series: {{ rdvStatutCounts|json_encode|raw }},
                    labels: {{ rdvStatutLabels|json_encode|raw }},
                    colors: ['#0d6efd', '#198754', '#ffc107', '#dc3545'],
                    legend: { position: 'bottom' }
                });
                pieRdvStatut.render();
                // Pie chart for fiche diagnostics
                var pieFicheDiagnostic = new ApexCharts(document.querySelector("#pieFicheDiagnostic"), {
                    chart: { type: 'pie', height: 300 },
                    series: {{ ficheDiagnosticCounts|json_encode|raw }},
                    labels: {{ ficheDiagnosticLabels|json_encode|raw }},
                    colors: ['#17a2b8', '#6610f2', '#fd7e14', '#20c997'],
                    legend: { position: 'bottom' }
                });
                pieFicheDiagnostic.render();
                // Bar chart for consultations per doctor
                var barDoctorsConsultations = new ApexCharts(document.querySelector("#barDoctorsConsultations"), {
                    chart: { type: 'bar', height: 350 },
                    series: [{ name: 'Consultations', data: {{ doctorsConsultationsCounts|json_encode|raw }} }],
                    xaxis: { categories: {{ doctorsConsultationsLabels|json_encode|raw }} },
                    colors: ['#0dcaf0'],
                    legend: { position: 'top' }
                });
                barDoctorsConsultations.render();
                // Line chart for rendez-vous per day
                var lineRdvDay = new ApexCharts(document.querySelector("#lineRdvDay"), {
                    chart: { type: 'line', height: 300 },
                    series: [{ name: 'Rendez-vous', data: {{ rdvDayCounts|json_encode|raw }} }],
                    xaxis: { categories: {{ rdvDayLabels|json_encode|raw }} },
                    colors: ['#ffc107'],
                    legend: { position: 'top' }
                });
                lineRdvDay.render();
                // Line chart for fiches médicales per day
                var lineFicheDay = new ApexCharts(document.querySelector("#lineFicheDay"), {
                    chart: { type: 'line', height: 300 },
                    series: [{ name: 'Fiches Médicales', data: {{ ficheDayCounts|json_encode|raw }} }],
                    xaxis: { categories: {{ ficheDayLabels|json_encode|raw }} },
                    colors: ['#6c757d'],
                    legend: { position: 'top' }
                });
                lineFicheDay.render();
            });
        </script>
    </main>



  
{% endblock %}