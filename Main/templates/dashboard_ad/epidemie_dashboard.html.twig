{% extends 'base_admin.html.twig' %}

{% block title %}Détection Épidémique{% endblock %}
{% block page_title %}Détection Épidémique — Signaux Santé{% endblock %}

{% block breadcrumb %}
  <li class="breadcrumb-item">Analytics</li>
  <li class="breadcrumb-item active">Épidémie</li>
{% endblock %}

{% block stylesheets %}
<style>
  /* ── réutilise patterns admin ── */
  .kpi-card {
    border: 1px solid rgba(15,23,42,.08);
    border-radius: 18px; overflow: hidden;
    box-shadow: 0 14px 40px rgba(16,24,40,.06);
  }
  .kpi-card .card-body { padding: 18px; }
  .kpi-sub   { font-size: 12px; color: rgba(100,116,139,.9); }
  .kpi-value { font-size: 26px; font-weight: 800; letter-spacing: -.5px; }
  .kpi-icon  { width: 46px; height: 46px; border-radius: 14px; display: flex; align-items: center; justify-content: center; }

  .panel-card {
    border: 1px solid rgba(15,23,42,.08);
    border-radius: 18px; overflow: hidden;
    box-shadow: 0 14px 40px rgba(16,24,40,.06);
  }
  .panel-card .card-header {
    background: transparent;
    border-bottom: 1px solid rgba(15,23,42,.06);
    padding: 14px 18px;
  }
  .panel-card .card-body { padding: 16px 18px; }

  .chip {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 8px 10px; border-radius: 999px;
    border: 1px solid rgba(15,23,42,.08);
    background: rgba(248,250,252,.7);
    font-weight: 700; font-size: 12px; color: #0f172a;
  }
  .badge-soft { background: rgba(15,23,42,.06); color: #0f172a; border: 1px solid rgba(15,23,42,.08); font-weight: 700; }

  /* ── SIGNAL CARDS ── */
  .signal-card {
    border-radius: 14px; padding: 14px 16px;
    border: 1px solid; border-left-width: 4px;
    display: flex; align-items: center; gap: 12px;
    transition: .18s; margin-bottom: 10px;
  }
  .signal-card:last-child { margin-bottom: 0; }
  .signal-card:hover { transform: translateX(4px); }
  .signal-card.fort   { background: #fef2f2; border-color: rgba(239,68,68,.20); border-left-color: #ef4444; }
  .signal-card.modere { background: #fffbeb; border-color: rgba(245,158,11,.20); border-left-color: #f59e0b; }
  .signal-card.normal { background: #f0fdf4; border-color: rgba(34,197,94,.20); border-left-color: #22c55e; }

  .signal-ico { font-size: 26px; flex-shrink: 0; }
  .signal-label { font-weight: 900; font-size: 14px; color: #111827; }
  .signal-sub   { font-size: 12px; color: #6b7280; margin-top: 2px; }
  .signal-right { margin-left: auto; text-align: right; flex-shrink: 0; }
  .signal-var   { font-size: 15px; font-weight: 900; }
  .fort   .signal-var { color: #dc2626; }
  .modere .signal-var { color: #d97706; }
  .normal .signal-var { color: #16a34a; }
  .signal-ratio { font-size: 11px; color: #6b7280; font-weight: 700; }

  /* ── METEO CARD ── */
  .meteo-box {
    background: linear-gradient(135deg, #1e3a8a, #1d4ed8);
    border-radius: 16px; color: #fff;
    padding: 20px; text-align: center;
  }
  .meteo-icon { width: 60px; }
  .meteo-temp { font-size: 42px; font-weight: 900; }
  .meteo-desc { font-size: 14px; opacity: .85; }
  .meteo-risk-pill {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 14px; border-radius: 999px;
    font-size: 12px; font-weight: 900; margin-top: 10px;
  }
  .meteo-risk-pill.Élevé   { background: rgba(239,68,68,.25); color: #fca5a5; }
  .meteo-risk-pill.Modéré  { background: rgba(245,158,11,.25); color: #fde68a; }
  .meteo-risk-pill.Faible  { background: rgba(34,197,94,.25); color: #86efac; }

  /* ── WHO OUTBREAKS ── */
  .who-row {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 10px 0; border-bottom: 1px solid rgba(15,23,42,.06);
  }
  .who-row:last-child { border-bottom: none; }
  .who-dot { width: 8px; height: 8px; border-radius: 50%; background: #ef4444; flex-shrink: 0; margin-top: 5px; }
  .who-title { font-weight: 800; font-size: 13px; color: #111827; }
  .who-sub   { font-size: 11px; color: #6b7280; font-weight: 700; margin-top: 2px; }
  .who-date  { font-size: 11px; color: #9ca3af; margin-left: auto; flex-shrink: 0; }

  /* ── TOP PRODUITS ── */
  .top-maladie-block { margin-bottom: 18px; }
  .top-maladie-head  {
    display: flex; align-items: center; gap: 8px;
    font-weight: 900; font-size: 13px; color: #111827;
    margin-bottom: 8px;
  }
  .top-produit-pill {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 5px 12px; border-radius: 999px;
    font-size: 12px; font-weight: 700;
    border: 1px solid rgba(15,23,42,.10);
    background: rgba(15,23,42,.04);
    margin-right: 6px; margin-bottom: 6px;
  }

  /* ── SCORE JAUGE ── */
  .score-bar {
    height: 10px; border-radius: 999px; background: #e5e7eb; overflow: hidden; margin-top: 8px;
  }
  .score-bar-fill {
    height: 100%; border-radius: 999px;
    background: linear-gradient(90deg, #22c55e, #f59e0b, #ef4444);
    transition: width .8s ease;
  }

  .table thead th {
    font-size: 12px; text-transform: uppercase; letter-spacing: .04em;
    color: rgba(71,85,105,.9); background: rgba(248,250,252,.7);
    border-bottom: 1px solid rgba(15,23,42,.06) !important;
  }
  .table td { vertical-align: middle; }
  .chart-wrap    { min-height: 280px; }
  .chart-wrap-sm { min-height: 220px; }
</style>
{% endblock %}

{% block body %}

{# ========== FILTRES ========== #}
<div class="card panel-card mb-4">
  <div class="card-body">
    <form class="row g-3 align-items-end" method="get">
      <div class="col-md-3">
        <label class="form-label fw-bold fs-13">Pays (corrélation météo)</label>
        <input type="text" class="form-control" name="country" value="{{ country }}" placeholder="Tunisia, France...">
      </div>
      <div class="col-md-2">
        <label class="form-label fw-bold fs-13">Latitude</label>
        <input type="number" step="0.01" class="form-control" name="lat" value="{{ app.request.query.get('lat', '36.8') }}">
      </div>
      <div class="col-md-2">
        <label class="form-label fw-bold fs-13">Longitude</label>
        <input type="number" step="0.01" class="form-control" name="lon" value="{{ app.request.query.get('lon', '10.18') }}">
      </div>
      <div class="col-md-3">
        <label class="form-label fw-bold fs-13">Fenêtre analyse (jours)</label>
<input type="number" min="7" max="90" class="form-control" name="days" value="{{ app.request.query.get('days', 60) }}">      </div>
      <div class="col-md-2">
        <button class="btn btn-primary w-100">
          <i class="feather-refresh-cw me-2"></i>Actualiser
        </button>
      </div>
    </form>
  </div>
</div>

{# ========== KPI GLOBAUX ========== #}
<div class="row g-4 mb-4">

  {# Risque global #}
  <div class="col-lg-3 col-md-6">
    <div class="card kpi-card">
      <div class="card-body d-flex align-items-center justify-content-between">
        <div>
          <div class="kpi-sub">Risque épidémique</div>
          <div class="kpi-value text-{{ risqueColor }}">{{ localChart.risk }}</div>
          <div class="score-bar">
            <div class="score-bar-fill" style="width: {{ (localChart.score / localChart.maxScore * 100)|round }}%"></div>
          </div>
          <div class="kpi-sub mt-1">Score {{ localChart.score }}/{{ localChart.maxScore }}</div>
        </div>
        <div class="kpi-icon bg-soft-{{ risqueColor }} text-{{ risqueColor }}">
          <i class="feather-alert-triangle"></i>
        </div>
      </div>
    </div>
  </div>

  {# Maladies surveillées #}
  <div class="col-lg-3 col-md-6">
    <div class="card kpi-card">
      <div class="card-body d-flex align-items-center justify-content-between">
        <div>
          <div class="kpi-sub">Maladies surveillées</div>
          <div class="kpi-value">{{ localChart.meta|length }}</div>
          <div class="kpi-sub">catégories analysées</div>
        </div>
        <div class="kpi-icon bg-soft-primary text-primary">
          <i class="feather-activity"></i>
        </div>
      </div>
    </div>
  </div>

  {# Signaux forts #}
  <div class="col-lg-3 col-md-6">
    <div class="card kpi-card">
      <div class="card-body d-flex align-items-center justify-content-between">
        <div>
          <div class="kpi-sub">Signaux forts</div>
          <div class="kpi-value text-danger">
            {{ localChart.meta|filter(m => m.level == 'fort')|length }}
          </div>
          <div class="kpi-sub">pics détectés ce mois</div>
        </div>
        <div class="kpi-icon bg-soft-danger text-danger">
          <i class="feather-zap"></i>
        </div>
      </div>
    </div>
  </div>

  {# Météo / Risque grippal #}
  <div class="col-lg-3 col-md-6">
    <div class="card kpi-card">
      <div class="card-body d-flex align-items-center justify-content-between">
        <div>
          <div class="kpi-sub">Risque grippal météo</div>
          <div class="kpi-value {% if meteoCorrel.risqueGrippe == 'Élevé' %}text-danger{% elseif meteoCorrel.risqueGrippe == 'Modéré' %}text-warning{% else %}text-success{% endif %}">
            {{ meteoCorrel.risqueGrippe ?? '—' }}
          </div>
          <div class="kpi-sub">
            {% if meteoCorrel.temperature is defined and meteoCorrel.temperature is not null %}
              {{ meteoCorrel.temperature }}°C — {{ meteoCorrel.humidity }}% humidité
            {% else %}
              API météo indisponible
            {% endif %}
          </div>
        </div>
        <div class="kpi-icon bg-soft-info text-info">
          <i class="feather-cloud"></i>
        </div>
      </div>
    </div>
  </div>

</div>

{# ========== SIGNAUX + WHO ========== #}
<div class="row g-4 mb-4">

  {# SIGNAUX LOCAUX #}
  <div class="col-lg-7">
    <div class="card panel-card stretch stretch-full">
      <div class="card-header d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-2">
          <i class="feather-bar-chart-2 text-primary"></i>
          <h5 class="card-title mb-0">Signaux Locaux — Ventes 7j vs Baseline</h5>
        </div>
        <div class="d-flex gap-2">
          <a href="{{ path('admin_epidemie_export_csv') }}" class="chip">
            <i class="feather-download"></i> Export CSV
          </a>
          <span class="chip"><i class="feather-database"></i> Ta BDD</span>
        </div>
      </div>
      <div class="card-body">
        {% for m in localChart.meta %}
        <div class="signal-card {{ m.level }}">
          <div class="signal-ico">{{ m.icon }}</div>
          <div class="flex-grow-1 min-w-0">
            <div class="signal-label">{{ m.label }}</div>
            <div class="signal-sub">
              {{ m.last }} unités vendues · baseline {{ m.baseline }}
            </div>
          </div>
          <div class="signal-right">
            <div class="signal-var">
              {% if m.variation > 0 %}↑{% elseif m.variation < 0 %}↓{% else %}→{% endif %}
              {{ m.variation|abs }}%
            </div>
            <div class="signal-ratio">ratio {{ m.ratio }}</div>
          </div>
          <span class="badge bg-soft-{{ m.level == 'fort' ? 'danger' : (m.level == 'modere' ? 'warning' : 'success') }} text-{{ m.level == 'fort' ? 'danger' : (m.level == 'modere' ? 'warning' : 'success') }}">
            {{ m.level == 'fort' ? '🔴 Critique' : (m.level == 'modere' ? '🟡 Modéré' : '🟢 Normal') }}
          </span>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>

  {# WHO + MÉTÉO #}
  <div class="col-lg-5">
    <div class="row g-4 h-100">

      {# Météo locale #}
      <div class="col-12">
        <div class="card panel-card">
          <div class="card-header d-flex align-items-center gap-2">
            <i class="feather-cloud text-primary"></i>
            <h5 class="card-title mb-0">Corrélation Météo / Santé</h5>
            <span class="chip ms-auto fs-11">OpenWeatherMap API</span>
          </div>
          <div class="card-body">
            {% if meteoCorrel.ok is defined and meteoCorrel.ok %}
              <div class="meteo-box">
                {% if meteoCorrel.icon %}<img src="{{ meteoCorrel.icon }}" class="meteo-icon" alt="">{% endif %}
                <div class="meteo-temp">{{ meteoCorrel.temperature|default('—') }}°C</div>
                <div class="meteo-desc">{{ meteoCorrel.description|capitalize }} · {{ meteoCorrel.ville }}</div>
                <div class="meteo-desc mt-1">💧 Humidité : {{ meteoCorrel.humidity }}%</div>
                <div class="meteo-risk-pill {{ meteoCorrel.risqueGrippe }}">
                  🤧 Risque grippal : {{ meteoCorrel.risqueGrippe }}
                </div>
              </div>
            {% else %}
              <div class="alert alert-warning mb-0">
                <i class="feather-alert-circle me-2"></i>
                API météo indisponible.
                {% if meteoCorrel.error is defined %}<br><small class="text-muted">{{ meteoCorrel.error }}</small>{% endif %}
                <br><small>Ajoute <code>OPENWEATHER_API_KEY</code> dans ton <code>.env</code></small>
              </div>
            {% endif %}
          </div>
        </div>
      </div>

      {# WHO alertes #}
      <div class="col-12">
        <div class="card panel-card">
          <div class="card-header d-flex align-items-center gap-2">
            <i class="feather-globe text-danger"></i>
            <h5 class="card-title mb-0">Alertes OMS Mondiales</h5>
            <span class="chip ms-auto fs-11">WHO API</span>
          </div>
          <div class="card-body" style="max-height: 240px; overflow-y:auto;">
            {% if whoOutbreaks.ok and whoOutbreaks.outbreaks is not empty %}
              {% for o in whoOutbreaks.outbreaks %}
              <div class="who-row">
                <div class="who-dot"></div>
                <div class="flex-grow-1 min-w-0">
                  <div class="who-title">{{ o.titre }}</div>
                  <div class="who-sub">📍 {{ o.pays }}</div>
                </div>
                {% if o.date %}<div class="who-date">{{ o.date|date('d/m/Y') }}</div>{% endif %}
              </div>
              {% endfor %}
            {% else %}
              <div class="text-center text-muted py-3">
                <i class="feather-check-circle text-success fs-3 d-block mb-2"></i>
                Aucune alerte OMS disponible<br>
                <small>{{ whoOutbreaks.error ?? '' }}</small>
              </div>
            {% endif %}
          </div>
        </div>
      </div>

    </div>
  </div>

</div>

{# ========== GRAPHIQUES ========== #}
<div class="row g-4 mb-4">

  {# Tendances 6 mois #}
  <div class="col-lg-8">
    <div class="card panel-card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-2">
          <i class="feather-trending-up text-primary"></i>
          <h5 class="card-title mb-0">Évolution Ventes par Maladie (6 mois)</h5>
        </div>
        <span class="chip"><i class="feather-calendar"></i> {{ "now"|date('Y') }}</span>
      </div>
      <div class="card-body">
        <div id="chart-tendances" class="chart-wrap"></div>
      </div>
    </div>
  </div>

  {# Historique météo (Open-Meteo) #}
  <div class="col-lg-4">
    <div class="card panel-card">
      <div class="card-header d-flex align-items-center gap-2">
        <i class="feather-thermometer text-primary"></i>
        <h5 class="card-title mb-0">Météo 30j (Open-Meteo)</h5>
        <span class="chip ms-auto fs-11">Sans clé API</span>
      </div>
      <div class="card-body">
        {% if meteoHisto.ok %}
          <div id="chart-meteo" class="chart-wrap-sm"></div>
        {% else %}
          <div class="alert alert-warning mb-0">
            <i class="feather-wifi-off me-2"></i>Open-Meteo indisponible
          </div>
        {% endif %}
      </div>
    </div>
  </div>

</div>

{# ========== TOP PRODUITS PAR MALADIE ========== #}
<div class="row g-4">
  <div class="col-12">
    <div class="card panel-card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-2">
          <i class="feather-award text-primary"></i>
          <h5 class="card-title mb-0">Top Produits par Maladie Détectée (30j)</h5>
        </div>
        <span class="chip"><i class="feather-filter"></i> Ventes réelles BDD</span>
      </div>
      <div class="card-body">
        {% if topParMaladie is not empty %}
          <div class="row g-3">
            {% for bloc in topParMaladie %}
            <div class="col-lg-4 col-md-6">
              <div class="top-maladie-block">
                <div class="top-maladie-head">
                  <span>{{ bloc.icon }}</span>
                  <span>{{ bloc.maladie }}</span>
                  <span class="ms-auto badge badge-soft">{{ bloc.produits|length }} produits</span>
                </div>
                {% for p in bloc.produits %}
                  <span class="top-produit-pill">
                    💊 {{ p.nom }} <strong class="ms-1">{{ p.total }}</strong>
                  </span>
                {% endfor %}
              </div>
            </div>
            {% endfor %}
          </div>
        {% else %}
          <div class="text-center text-muted py-4">
            <i class="feather-inbox fs-3 d-block mb-2"></i>
            Aucune vente enregistrée dans les catégories surveillées.
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function () {

  /* ── Données Twig → JS ── */
  const tendances = {{ tendances|json_encode|raw }};
  const meteoHisto = {{ meteoHisto|json_encode|raw }};

  /* ── CHART TENDANCES (ApexCharts multi-ligne) ── */
  (function () {
    const el = document.querySelector('#chart-tendances');
    if (!el || !window.ApexCharts) return;

    new ApexCharts(el, {
      chart: { type: 'line', height: 300, toolbar: { show: false }, zoom: { enabled: false } },
      stroke: { curve: 'smooth', width: 2.5 },
      dataLabels: { enabled: false },
      fill: { type: 'gradient', gradient: { opacityFrom: .35, opacityTo: .02 } },
      xaxis: { categories: tendances.categories },
      yaxis: { labels: { formatter: v => Math.round(v) + ' cmd' } },
      tooltip: { y: { formatter: v => v + ' unités vendues' } },
      legend: { position: 'top' },
      colors: tendances.series.map(s => s.color),
      series: tendances.series.map(s => ({ name: s.name, data: s.data })),
    }).render();
  })();

  /* ── CHART MÉTÉO 30j (Open-Meteo) ── */
  (function () {
    const el = document.querySelector('#chart-meteo');
    if (!el || !window.ApexCharts || !meteoHisto.ok) return;

    new ApexCharts(el, {
      chart: { type: 'line', height: 240, toolbar: { show: false }, zoom: { enabled: false } },
      stroke: { curve: 'smooth', width: [2.5, 2] },
      dataLabels: { enabled: false },
      xaxis: {
        categories: meteoHisto.dates,
        tickAmount: 6,
        labels: { rotate: -25 }
      },
      yaxis: [
        { title: { text: '°C' }, labels: { formatter: v => v + '°' } },
        { opposite: true, title: { text: 'mm' }, labels: { formatter: v => v + 'mm' } },
      ],
      tooltip: { shared: true },
      colors: ['#6366f1', '#06b6d4'],
      series: [
        { name: 'Température (°C)', data: meteoHisto.temperatures },
        { name: 'Précipitations (mm)', data: meteoHisto.precipitations },
      ],
    }).render();
  })();

});
</script>
{% endblock %}
