<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light dark">

  <title>{% block title %}MedFlow{% endblock %}</title>

  {% block stylesheets %}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

    <script>
      (function () {
        var storageKey = 'medflow-theme';
        var saved = null;
        try { saved = localStorage.getItem(storageKey); } catch (e) { saved = null; }
        var prefersDark = false;
        try { prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches; } catch (e) { prefersDark = false; }
        var theme = saved || (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-bs-theme', theme);
      })();
    </script>

    <style>
      :root{
        --mf-primary: #0097B2;
        --mf-primary-rgb: 0, 151, 178;
        --mf-blue: #003399;
        --mf-blue-rgb: 0, 51, 153;

        --bs-primary: var(--mf-primary);
        --bs-primary-rgb: var(--mf-primary-rgb);
        --bs-link-color: var(--mf-primary);
        --bs-link-hover-color: rgba(var(--mf-primary-rgb), .88);
      }

      :root[data-bs-theme="dark"]{
        --auth-bg: #0b1220;
        --auth-card-bg: rgba(15, 23, 42, 0.85);
        --auth-card-border: rgba(255,255,255,.12);
        --auth-card-shadow: 0 30px 90px rgba(0,0,0,.45);
        --auth-input-bg: rgba(255,255,255,.08);
        --auth-input-border: rgba(255,255,255,.18);
        --auth-input-color: #fff;
        --auth-placeholder: rgba(255,255,255,.45);
        --auth-btn-shadow: 0 18px 55px rgba(var(--bs-primary-rgb), .35);
      }

      :root[data-bs-theme="light"]{
        --auth-bg: var(--bs-body-bg);
        --auth-card-bg: rgba(255,255,255,.92);
        --auth-card-border: rgba(0,0,0,.10);
        --auth-card-shadow: 0 20px 60px rgba(0,0,0,.12);
        --auth-input-bg: rgba(0,0,0,.02);
        --auth-input-border: rgba(0,0,0,.14);
        --auth-input-color: var(--bs-body-color);
        --auth-placeholder: rgba(0,0,0,.45);
        --auth-btn-shadow: 0 14px 45px rgba(var(--bs-primary-rgb), .22);
      }

      .auth-page{
        min-height: 100vh;
        display: flex;
        align-items: center;
        background:
          radial-gradient(1100px circle at 12% 12%, rgba(var(--mf-primary-rgb), .18), transparent 48%),
          radial-gradient(900px circle at 88% 18%, rgba(var(--mf-blue-rgb), .12), transparent 42%),
          var(--auth-bg);
      }

      .glass-card{
        background: var(--auth-card-bg);
        border: 1px solid var(--auth-card-border);
        box-shadow: var(--auth-card-shadow);
        backdrop-filter: blur(10px);
        border-radius: 18px;
        color: var(--bs-body-color);
      }

      @media (prefers-reduced-motion: no-preference){
        .glass-card{ animation: authEnter .55s ease both; }
        @keyframes authEnter{
          from{ opacity: 0; transform: translateY(10px) scale(.985); }
          to{ opacity: 1; transform: translateY(0) scale(1); }
        }
      }

      .brand-pill{
        display:inline-flex;
        align-items:center;
        gap:.55rem;
        padding:.45rem .8rem;
        border-radius: 999px;
        background: rgba(var(--bs-body-color-rgb), .08);
        border: 1px solid rgba(var(--bs-body-color-rgb), .15);
        color: var(--bs-body-color);
        font-weight: 800;
        letter-spacing:.2px;
      }

      .help-text{ color: var(--bs-secondary-color); }
      .form-label{ color: var(--bs-body-color); }

      .form-control, .form-select{
        background: var(--auth-input-bg) !important;
        border: 1px solid var(--auth-input-border) !important;
        color: var(--auth-input-color) !important;
        border-radius: 12px;
        padding: .85rem .95rem;
        transition: all .25s ease;
      }
      .form-control::placeholder{ color: var(--auth-placeholder); }
      .form-control:focus, .form-select:focus{
        box-shadow: 0 0 0 .2rem rgba(var(--bs-primary-rgb), .25);
        border-color: rgba(var(--bs-primary-rgb), .60) !important;
        color: var(--auth-input-color) !important;
      }

      .small-link{ color: var(--bs-link-color); }
      .small-link:hover{ color: var(--bs-link-hover-color); text-decoration: underline; }

      .btn-glow{
        border-radius: 12px;
        padding: .85rem 1rem;
        font-weight: 800;
        box-shadow: var(--auth-btn-shadow);
      }
      .btn-primary{
        background: linear-gradient(135deg, rgba(var(--bs-primary-rgb), 1), rgba(var(--bs-primary-rgb), .82));
        border: none;
      }
      .btn-primary:hover{ filter: brightness(1.05); }

      .btn-google{
        border-radius: 12px;
        padding: .85rem 1rem;
        font-weight: 700;
        --bs-btn-color: var(--bs-body-color);
        --bs-btn-border-color: rgba(var(--bs-body-color-rgb), .25);
        --bs-btn-hover-bg: rgba(var(--bs-body-color-rgb), .08);
        --bs-btn-hover-border-color: rgba(var(--bs-body-color-rgb), .35);
      }

      .btn-outline-primary{
        border-radius: 12px;
        padding: .85rem 1rem;
        font-weight: 800;
        --bs-btn-color: var(--mf-primary);
        --bs-btn-border-color: rgba(var(--mf-primary-rgb), .45);
        --bs-btn-hover-bg: rgba(var(--mf-primary-rgb), .10);
        --bs-btn-hover-border-color: rgba(var(--mf-primary-rgb), .70);
        --bs-btn-active-bg: rgba(var(--mf-primary-rgb), .16);
        --bs-btn-active-border-color: rgba(var(--mf-primary-rgb), .80);
      }

      .btn-outline-secondary{
        border-radius: 12px;
        padding: .85rem 1rem;
        font-weight: 800;
      }

      #themeToggle{
        border-radius: 999px;
        padding: .35rem .55rem;
        line-height: 1;
        --bs-btn-color: var(--bs-body-color);
        --bs-btn-border-color: rgba(var(--bs-body-color-rgb), .25);
        --bs-btn-hover-bg: rgba(var(--bs-body-color-rgb), .08);
        --bs-btn-hover-border-color: rgba(var(--bs-body-color-rgb), .35);
      }

      .auth-brand{
        display: flex;
        align-items: center;
        gap: .75rem;
        margin-bottom: 1.25rem;
      }
      .auth-brand__logo{
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: rgba(var(--bs-body-color-rgb), .06);
        border: 1px solid rgba(var(--bs-body-color-rgb), .12);
        display: grid;
        place-items: center;
        overflow: hidden;
        flex: 0 0 auto;
      }
      .auth-brand__logo img{
        width: 32px;
        height: 32px;
        object-fit: contain;
      }
      .auth-brand__title{
        font-weight: 900;
        letter-spacing: .2px;
        line-height: 1.1;
        margin: 0;
      }
      .auth-brand__subtitle{
        margin: 0;
        font-size: .92rem;
        color: var(--bs-secondary-color);
      }

      .err{
        color: var(--bs-danger);
        font-size: .9rem;
        margin-top:.35rem;
      }

      .form-control.is-invalid, .form-select.is-invalid{
        border-color: rgba(220, 53, 69, .9) !important;
        box-shadow: 0 0 0 .15rem rgba(220, 53, 69, .15);
      }

      .alert-glass{
        background: rgba(var(--bs-danger-rgb), .10);
        border: 1px solid rgba(var(--bs-danger-rgb), .35);
        color: var(--bs-body-color);
        border-radius: 14px;
      }

      .auth-surface{
        background: rgba(var(--bs-body-bg-rgb), .72);
        border: 1px solid rgba(var(--bs-body-color-rgb), .14);
      }

      .auth-form-has-sticky{
        padding-bottom: 96px;
      }

      .auth-sticky-actions{
        position: sticky;
        bottom: 12px;
        z-index: 20;
        margin-top: 1rem;
        padding: .75rem;
        border-radius: 14px;
        background: rgba(var(--bs-body-bg-rgb), .78);
        border: 1px solid rgba(var(--bs-body-color-rgb), .14);
        backdrop-filter: blur(10px);
        box-shadow: 0 22px 70px rgba(0,0,0,.22);
      }

      .btn-auth-compact{
        padding: .65rem .9rem;
      }
    </style>

    {% block page_styles %}{% endblock %}
  {% endblock %}
</head>
<body>
  {% block body %}{% endblock %}

  {% block javascripts %}
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      (function () {
        var storageKey = 'medflow-theme';
        var root = document.documentElement;

        function setIcons(theme) {
          var sun = document.getElementById('themeIconSun');
          var moon = document.getElementById('themeIconMoon');
          if (!sun || !moon) return;
          if (theme === 'dark') {
            sun.classList.remove('d-none');
            moon.classList.add('d-none');
          } else {
            sun.classList.add('d-none');
            moon.classList.remove('d-none');
          }
        }

        function applyTheme(theme) {
          root.setAttribute('data-bs-theme', theme);
          setIcons(theme);
          try { localStorage.setItem(storageKey, theme); } catch (e) {}
        }

        var current = root.getAttribute('data-bs-theme') || 'dark';
        setIcons(current);

        var toggle = document.getElementById('themeToggle');
        if (toggle) {
          toggle.addEventListener('click', function () {
            var theme = root.getAttribute('data-bs-theme') === 'dark' ? 'light' : 'dark';
            applyTheme(theme);
          });
        }
      })();
    </script>

    <script>
      (function () {
        function fillPasswords(form, value) {
          if (!form) return;
          var inputs = form.querySelectorAll('input[autocomplete="new-password"]');
          if (!inputs || !inputs.length) {
            inputs = form.querySelectorAll('input[type="password"]');
          }
          inputs.forEach(function (el) {
            el.value = value;
            try { el.dispatchEvent(new Event('input', { bubbles: true })); } catch (e) {}
            try { el.dispatchEvent(new Event('change', { bubbles: true })); } catch (e) {}
          });
        }

        document.addEventListener('click', function (e) {
          var btn = e.target && e.target.closest ? e.target.closest('[data-password-suggest]') : null;
          if (!btn) return;
          e.preventDefault();

          var apiUrl = btn.getAttribute('data-password-api') || '/api/password/suggest';
          var form = btn.closest('form');
          var prev = btn.innerHTML;

          btn.disabled = true;
          btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Génération…';

          fetch(apiUrl, { method: 'GET', credentials: 'same-origin', headers: { 'Accept': 'application/json' } })
            .then(function (r) { return r.json(); })
            .then(function (data) {
              var pwd = data && data.password ? String(data.password) : '';
              if (!pwd) throw new Error('Mot de passe manquant');
              fillPasswords(form, pwd);
            })
            .catch(function () {
              // silently ignore; user can still type manually
            })
            .finally(function () {
              btn.disabled = false;
              btn.innerHTML = prev;
            });
        });
      })();
    </script>

    <script>
      (function () {
        function setBtnState(btn, isVisible) {
          if (!btn) return;
          btn.setAttribute('aria-pressed', isVisible ? 'true' : 'false');
          btn.setAttribute('aria-label', isVisible ? 'Masquer le mot de passe' : 'Afficher le mot de passe');

          var icon = btn.querySelector('i');
          if (!icon) return;
          icon.classList.toggle('bi-eye', !isVisible);
          icon.classList.toggle('bi-eye-slash', isVisible);
        }

        function getInput(btn) {
          var targetId = btn.getAttribute('data-password-toggle');
          if (!targetId) return null;
          return document.getElementById(targetId);
        }

        document.addEventListener('click', function (e) {
          var btn = e.target && e.target.closest ? e.target.closest('[data-password-toggle]') : null;
          if (!btn) return;
          e.preventDefault();

          var input = getInput(btn);
          if (!input) return;

          var isVisible = input.type === 'text';
          input.type = isVisible ? 'password' : 'text';
          setBtnState(btn, !isVisible);
        });

        document.addEventListener('DOMContentLoaded', function () {
          document.querySelectorAll('[data-password-toggle]').forEach(function (btn) {
            var input = getInput(btn);
            if (!input) return;
            setBtnState(btn, input.type === 'text');
          });
        });
      })();
    </script>
    {% block page_scripts %}{% endblock %}
  {% endblock %}
</body>
</html>
