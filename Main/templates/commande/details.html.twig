{% extends 'base.html.twig' %}

{% block title %}Commande #{{ commande.idCommande }}{% endblock %}

{% block body %}
<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-lg-11">

      {# Flash messages #}
      {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
          <i class="bi bi-check-circle-fill me-2"></i>{{ message }}
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      {% endfor %}
      {% for message in app.flashes('warning') %}
        <div class="alert alert-warning alert-dismissible fade show shadow-sm" role="alert">
          <i class="bi bi-exclamation-triangle-fill me-2"></i>{{ message }}
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      {% endfor %}
      {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
          <i class="bi bi-x-circle-fill me-2"></i>{{ message }}
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      {% endfor %}

      {# Header card #}
      <div class="card border-0 shadow-lg overflow-hidden mb-4">
        <div class="card-header text-white header-grad p-4">
          <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
            <div>
              <div class="d-flex align-items-center gap-2 mb-1">
                <span class="chip"><i class="bi bi-receipt"></i></span>
                <h3 class="m-0 fw-bold">Commande #{{ commande.idCommande }}</h3>
              </div>
              <div class="opacity-75">
                <i class="bi bi-calendar2-week me-1"></i>
                {{ commande.dateCreationCommande|date('d/m/Y à H:i') }}
              </div>
            </div>

            <div class="text-end">
              <div class="small opacity-75 mb-1">Statut</div>
              <span id="statutBadge" class="badge rounded-pill px-4 py-2 fs-6 statut-badge">
                {{ commande.statutCommande }}
              </span>
              <button id="themeToggle" class="btn btn-outline-light btn-sm ms-2">
  <i class="bi bi-moon-stars"></i> Mode sombre
</button>
            </div>
          </div>
        </div>

        <div class="card-body p-4">

          {# Produits #}
          <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
            <h5 class="m-0"><i class="bi bi-box-seam me-2"></i>Produits commandés</h5>

            <a class="btn btn-success"
               href="{{ path('commande_facture_pdf', {id: commande.idCommande}) }}">
              <i class="bi bi-download me-1"></i> Télécharger facture
            </a>
          </div>

          <div class="table-responsive">
            <table class="table align-middle table-hover">
              <thead class="table-light">
                <tr>
                  <th>Produit</th>
                  <th class="text-center">Quantité</th>
                  <th class="text-end">Prix</th>
                  <th class="text-end">Sous-total</th>
                </tr>
              </thead>

              <tbody>
                {% for ligne in commande.ligneCommandes %}

                  {# ✅ Construction robuste du src image :
                     - si imageProduit est une URL http(s) -> on l’utilise
                     - sinon -> on suppose fichier local dans uploads/produits/
                     - si vide -> image fallback
                  #}
                  {% set img = ligne.produit.imageProduit %}
                  {% set isUrl = img and (img starts with 'http://' or img starts with 'https://') %}
                  {% set srcImg = isUrl
                    ? img
                    : (img ? asset('uploads/produits/' ~ img) : asset('assets/img/placeholder-product.png'))
                  %}

                  <tr>
                    <td>
                      <div class="d-flex align-items-center">
                        <img
                          src="{{ srcImg }}"
                          alt="{{ ligne.produit.nomProduit }}"
                          class="thumb me-3"
                          loading="lazy"
                          onerror="this.src='{{ asset('assets/img/placeholder-product.png') }}'"
                        >
                        <div>
                          <div class="fw-semibold">{{ ligne.produit.nomProduit }}</div>
                          <div class="text-muted small">{{ ligne.produit.categorieProduit }}</div>
                        </div>
                      </div>
                    </td>

                    <td class="text-center">
                      <span class="badge bg-primary rounded-pill fs-6">{{ ligne.quantite_commandee }}</span>
                    </td>

                    <td class="text-end">
                      {{ ligne.produit.prixProduit|number_format(2, '.', '') }} Dt
                    </td>

                    <td class="text-end fw-bold text-success">
                      {{ (ligne.produit.prixProduit * ligne.quantite_commandee)|number_format(2, '.', '') }} Dt
                    </td>
                  </tr>
                {% endfor %}
              </tbody>

              <tfoot class="table-light">
                <tr class="fw-bold fs-5">
                  <td colspan="3" class="text-end">Total :</td>
                  <td class="text-end text-success">
                    {{ commande.montantTotal|number_format(2, '.', '') }} Dt
                  </td>
                </tr>
              </tfoot>
            </table>
          </div>

          <hr class="my-4">

          {# Livraison (grid propre) #}
          <div class="row g-3">
            <div class="col-md-6">
              <div class="card border-0 shadow-sm h-100 soft-card">
                <div class="card-body">
                  <h6 class="fw-bold mb-3">
                    <i class="bi bi-truck me-2"></i>Informations de livraison
                  </h6>

                  <div class="row g-2">
                    <div class="col-6">
                      <div class="meta">Nom</div>
                      <div class="val">{{ commande.nomLivraison ?? '—' }}</div>
                    </div>
                    <div class="col-6">
                      <div class="meta">Prénom</div>
                      <div class="val">{{ commande.prenomLivraison ?? '—' }}</div>
                    </div>
                    <div class="col-12">
                      <div class="meta">Adresse</div>
                      <div class="val">{{ commande.adresseLivraison ?? '—' }}</div>
                    </div>
                    <div class="col-6">
                      <div class="meta">Ville</div>
                      <div class="val">{{ commande.villeLivraison ?? '—' }}</div>
                    </div>
                    <div class="col-6">
                      <div class="meta">Téléphone</div>
                      <div class="val">{{ commande.telLivraison ?? '—' }}</div>
                    </div>
                  </div>

                  <div class="mt-3 text-muted small">
                    <i class="bi bi-info-circle me-1"></i>
                    La livraison sera traitée selon le statut de la commande.
                  </div>
                </div>
              </div>
            </div>

            <div class="col-md-6">
              <div class="card border-0 shadow-sm h-100 soft-card">
                <div class="card-body">
                  <h6 class="fw-bold mb-3">
                    <i class="bi bi-shield-check me-2"></i>Résumé
                  </h6>

                  <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Statut actuel</span>
                    <span class="fw-semibold">{{ commande.statutCommande }}</span>
                  </div>

                  <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Montant</span>
                    <span class="fw-bold text-success">{{ commande.montantTotal|number_format(2, '.', '') }} Dt</span>
                  </div>

                  <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Articles</span>
                    <span class="fw-semibold">{{ commande.ligneCommandes|length }}</span>
                  </div>

                  <div class="mt-3 p-3 rounded-4 bg-light">
                    <div class="small text-muted">Prochaine étape</div>
                    <div class="fw-semibold">
                      {% if commande.statutCommande == 'En attente' %}
                        En attente de confirmation.
                      {% elseif commande.statutCommande == 'En cours' %}
                        Préparation de votre commande.
                      {% elseif commande.statutCommande == 'Expédiée' %}
                        Votre commande est en route.
                      {% elseif commande.statutCommande == 'Livrée' %}
                        Commande livrée ✅
                      {% elseif commande.statutCommande == 'Annulée' %}
                        Commande annulée.
                      {% else %}
                        Suivi en cours.
                      {% endif %}
                    </div>
                  </div>

                </div>
              </div>
            </div>
          </div>

          <div class="d-flex gap-3 justify-content-between flex-wrap mt-4">
            <a href="{{ path('mes_commandes') }}" class="btn btn-outline-primary">
              <i class="bi bi-arrow-left me-1"></i> Mes commandes
            </a>
            <a href="{{ path('front_produit_index') }}" class="btn btn-primary">
              <i class="bi bi-shop me-1"></i> Continuer mes achats
            </a>
          </div>

        </div>
      </div>

    </div>
  </div>
</div>

<style>
:root{
  --primary:#00BFA6;
  --primary-dark:#0097B2;
  --danger:#BC0B09;

  --bg:#f6fbfb;
  --gray-50:#f9fafb;
  --gray-100:#f3f4f6;
  --gray-200:#e5e7eb;
  --gray-600:#4b5563;
  --gray-800:#1f2937;

  --shadow-sm:0 2px 10px rgba(0,0,0,.06);
  --shadow-md:0 12px 28px rgba(0,0,0,.10);
  --shadow-lg:0 20px 46px rgba(0,0,0,.14);

  --ring: 0 0 0 .22rem rgba(0,151,178,.18);
}

/* ✅ Header (SOLID) */
.header-grad{
  background: var(--primary-dark) !important;
  position: relative;
  overflow: hidden;
}
.header-grad::after{
  content:"";
  position:absolute;
  inset:-2px;
  background:
    radial-gradient(900px 240px at 16% 15%, rgba(255,255,255,.18), transparent 58%),
    radial-gradient(900px 240px at 85% 0%, rgba(255,255,255,.12), transparent 60%);
  pointer-events:none;
}

/* ✅ Chip icon */
.chip{
  width: 42px; height: 42px;
  border-radius: 16px;
  display:flex; align-items:center; justify-content:center;
  background: rgba(255,255,255,.16);
  border: 1px solid rgba(255,255,255,.26);
  box-shadow: 0 10px 22px rgba(0,0,0,.10);
}

/* ✅ Badge statut (base glass) */
.statut-badge{
  background: rgba(255,255,255,.18) !important;
  border: 1px solid rgba(255,255,255,.28) !important;
  color:#fff !important;
  font-weight: 900;
  letter-spacing: .2px;
}

/* ✅ Badge statut (couleur auto via classes ajoutées en JS) */
.statut-badge.is-waiting{ background: rgba(255,255,255,.18) !important; }
.statut-badge.is-progress{ background: rgba(0,191,166,.22) !important; }
.statut-badge.is-shipped{ background: rgba(0,151,178,.30) !important; }
.statut-badge.is-delivered{ background: rgba(16,185,129,.26) !important; }
.statut-badge.is-canceled{ background: rgba(188,11,9,.22) !important; }

/* ✅ Thumb produit */
.thumb{
  width: 60px;
  height: 60px;
  object-fit: cover;
  border-radius: 16px;
  border: 1px solid rgba(0,151,178,.14);
  background: #fff;
  box-shadow: 0 10px 22px rgba(15,23,42,.08);
  transition: transform .22s ease, box-shadow .22s ease, border-color .22s ease;
}
.thumb:hover{
  transform: scale(1.08) rotate(1deg);
  border-color: rgba(0,151,178,.35);
  box-shadow: 0 16px 32px rgba(0,151,178,.18);
}

/* ✅ Table look */
.table{
  border-radius: 16px;
  overflow:hidden;
  background:#fff;
}
.table thead th{
  font-weight: 900;
  color: var(--gray-800);
}
.table-hover tbody tr{
  transition: background .15s ease, transform .15s ease;
}
.table-hover tbody tr:hover{
  background: rgba(0,191,166,.06);
}

/* ✅ Quantité badge (turquoise) */
.badge.bg-primary{
  background: var(--primary-dark) !important;
  border: 1px solid rgba(255,255,255,.25);
  font-weight: 900;
}

/* ✅ Sous-total / Total */
.text-success{
  color: var(--primary-dark) !important;
}

/* ✅ Cards “Livraison / Résumé” */
.soft-card{
  border-radius: 18px;
  background:#fff;
  border: 1px solid rgba(0,151,178,.12);
  box-shadow: var(--shadow-sm);
}
.soft-card .card-body h6{
  font-weight: 1000;
  color: var(--gray-800);
}

/* ✅ meta/value */
.meta{
  font-size: .82rem;
  color: rgba(0,0,0,.55);
  margin-bottom: 2px;
}
.val{
  font-weight: 800;
  color: var(--gray-800);
}

/* ✅ Buttons (solid turquoise) */
.btn:focus{ box-shadow: var(--ring) !important; }

.btn-success{
  background: var(--primary) !important;
  color:#003b3a !important;
  border: none !important;
  font-weight: 1000;
  box-shadow: 0 12px 26px rgba(0,191,166,.20);
}
.btn-success:hover{
  background: #00a892 !important;
  transform: translateY(-1px);
  box-shadow: 0 16px 34px rgba(0,191,166,.28);
}

.btn-primary{
  background: var(--primary-dark) !important;
  border: none !important;
  font-weight: 1000;
  box-shadow: 0 12px 26px rgba(0,151,178,.18);
}
.btn-primary:hover{
  background: #00849b !important;
  transform: translateY(-1px);
  box-shadow: 0 16px 34px rgba(0,151,178,.26);
}

.btn-outline-primary{
  background: #fff !important;
  border: 2px solid rgba(0,151,178,.30) !important;
  color: var(--primary-dark) !important;
  font-weight: 1000;
  box-shadow: 0 10px 22px rgba(15,23,42,.06);
}
.btn-outline-primary:hover{
  background: rgba(0,191,166,.10) !important;
  border-color: rgba(0,151,178,.45) !important;
  transform: translateY(-1px);
}

/* ✅ pulse animation (si statut change) */
.pulse { animation: pulse .65s ease-in-out; }
@keyframes pulse {
  0% { transform: scale(1); box-shadow: 0 0 0 rgba(255,255,255,0); }
  50% { transform: scale(1.06); box-shadow: 0 0 30px rgba(255,255,255,.35); }
  100% { transform: scale(1); box-shadow: 0 0 0 rgba(255,255,255,0); }
}
/* =========================
   🌙 DARK MODE — DÉTAIL COMMANDE
   ========================= */
body.dark{
  background:#0b1220 !important;
  color:#e5e7eb !important;
}

body.dark .card,
body.dark .soft-card,
body.dark .table,
body.dark .table thead,
body.dark .table tfoot,
body.dark .modal-content,
body.dark .alert{
  background:#0f172a !important;
  color:#e5e7eb !important;
  border-color: rgba(0,151,178,.35) !important;
}

body.dark .header-grad{
  background:#0097B2 !important;
}

body.dark .text-muted{
  color:#94a3b8 !important;
}

body.dark .meta{ color:#94a3b8 !important; }
body.dark .val{ color:#e5e7eb !important; }

body.dark .badge.bg-primary{
  background: rgba(0,151,178,.65) !important;
}

body.dark .btn-outline-primary,
body.dark .btn-outline-light{
  background: transparent !important;
  color:#7dd3fc !important;
  border-color: rgba(0,151,178,.45) !important;
}

body.dark .table-hover tbody tr:hover{
  background: rgba(0,151,178,.15) !important;
}
</style>


<script>
document.addEventListener("DOMContentLoaded", () => {
  const badge = document.getElementById("statutBadge");
  if (!badge) return;

  const current = badge.innerText.trim();
  const key = "last_status_cmd_{{ commande.idCommande }}";
  const old = localStorage.getItem(key);

  // ✅ Pulse si changement
  if (old && old !== current) {
    badge.classList.add("pulse");
    setTimeout(() => badge.classList.remove("pulse"), 900);
  }
  localStorage.setItem(key, current);

  // ✅ Couleur selon statut (sans toucher ton HTML)
  badge.classList.remove("is-waiting","is-progress","is-shipped","is-delivered","is-canceled");

  const norm = current.toLowerCase();
  if (norm.includes("attente")) badge.classList.add("is-waiting");
  else if (norm.includes("en cours") || norm.includes("préparation")) badge.classList.add("is-progress");
  else if (norm.includes("expédi")) badge.classList.add("is-shipped");
  else if (norm.includes("livr")) badge.classList.add("is-delivered");
  else if (norm.includes("annul")) badge.classList.add("is-canceled");
});

document.addEventListener('DOMContentLoaded', () => {
  const btn = document.getElementById("themeToggle");

  // Charger thème sauvegardé
  if (localStorage.getItem("theme") === "dark") {
    document.body.classList.add("dark");
  }

  if (btn) {
    btn.addEventListener("click", () => {
      document.body.classList.toggle("dark");
      localStorage.setItem(
        "theme",
        document.body.classList.contains("dark") ? "dark" : "light"
      );
    });
  }
});
</script>

{% endblock %}