{% extends 'base.html.twig' %}
{% set patientId = app.session.get('patient_id') %}
{% block body %}
<style>
    :root {
        --mf-vivid-blue:#003399;
        --mf-dark-turquoise:#0097B2;
        --mf-vivid-turquoise:#00BFA6;
        --mf-pastel-blue:#6797FF;
        --mf-pastel-azure:#8FD5FF;
        --mf-light-blue:#B3D5FF;
        --mf-white:#FFFFFF;
        --mf-black:#000000;
        --mf-vivid-red:#BC0B09;
        --mf-text:#101828;
        --mf-muted:#6c757d;
        --shadow-sm:0 10px 26px rgba(16,24,40,.06);
        --shadow-md:0 16px 40px rgba(16,24,40,.08);
        --shadow-lg:0 24px 56px rgba(16,24,40,.12);
    }
    .rv-list-page {
        min-height: 100vh;
        background: var(--mf-white);
        padding: 2rem 0 4rem;
        font-family: 'Inter', 'Segoe UI', Arial, sans-serif;
    }
    .mf-rect-hero {
        border-radius: 24px;
        background: var(--mf-dark-turquoise);
        box-shadow: var(--shadow-md);
        border: 1px solid rgba(0,0,0,.08);
        padding: 40px 24px;
        text-align: center;
        margin-bottom: 2.5rem;
    }
    .mf-rect-title {
        font-size: 2.25rem;
        font-weight: 900;
        color: var(--mf-white);
        margin-bottom: 0.5rem;
        letter-spacing: -.02em;
    }
    .mf-rect-sub {
        color: var(--mf-pastel-azure);
        font-size: 1.1rem;
        font-weight: 500;
        opacity: 0.95;
    }
    .mf-card {
        background: var(--mf-light-blue);
        border-radius: 24px;
        box-shadow: var(--shadow-md);
        border: 1.5px solid var(--mf-dark-turquoise);
        padding: 2.5rem 2.5rem 2rem 2.5rem;
        margin-bottom: 2.5rem;
        width: 100%;
        max-width: 100%;
        box-sizing: border-box;
    }
    .mf-table {
        margin: 0;
        width: 100%;
        background: var(--mf-light-blue);
        border-radius: 18px;
        overflow: hidden;
        font-size: 1.01rem;
    }
    .mf-table thead th {
        background: linear-gradient(135deg, #0097B2 0%, #38bdf8 100%);
        color: #fff;
        font-weight: 700;
        font-size: 0.93rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 1rem 0.85rem;
        border: none;
    }
    .mf-table tbody td {
        padding: 0.9rem 0.85rem;
        vertical-align: middle;
        border-color: #0097B233;
        background: #f0f9ff;
        color: #0097B2;
    }
    .mf-table tbody tr { transition: background 0.2s; }
    .mf-table tbody tr:nth-child(even) { background: #e0f2fe; }
    .mf-table tbody tr:hover { background: #bae6fd !important; }
    .mf-table .edit-row td { background: #dbeafe !important; padding: 1.25rem; border-top: 2px solid #0097B2; }
    .mf-table .edit-row .form-control, .mf-table .edit-row .form-select {
        border: 2px solid #0097B2; border-radius: 10px; padding: 0.5rem 0.75rem;
    }
    .mf-table .edit-row .form-control:focus, .mf-table .edit-row .form-select:focus {
        border-color: #0097B2; box-shadow: 0 0 0 3px #0097B233; outline: none;
    }
    .btn-mf {
        background: var(--mf-dark-turquoise);
        border-color: var(--mf-dark-turquoise);
        color: #fff !important;
        border-radius: 999px !important;
        padding: 0.5rem 1.3rem;
        font-weight: 700;
        font-size: 1.05rem;
        letter-spacing: 0.02em;
        transition: transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 2px 8px #0097B222;
    }
    .btn-mf:hover {
        background: #007E94;
        border-color: #007E94;
        color: #fff !important;
        transform: translateY(-2px);
        box-shadow: 0 12px 28px rgba(0,151,178,0.25);
    }
    .btn-mf-outline {
        background: #fff;
        border: 2px solid var(--mf-dark-turquoise);
        color: var(--mf-dark-turquoise);
        border-radius: 999px !important;
        padding: 0.5rem 1.3rem;
        font-weight: 700;
        font-size: 1.05rem;
        letter-spacing: 0.02em;
        transition: background 0.2s, color 0.2s, box-shadow 0.2s;
        box-shadow: 0 2px 8px #0097B222;
    }
    .btn-mf-outline:hover {
        background: rgba(0,151,178,.08);
        border-color: var(--mf-dark-turquoise);
        color: var(--mf-dark-turquoise);
    }
    .btn-pill {
        border-radius: 999px !important;
        padding-left: 14px !important;
        padding-right: 14px !important;
    }
    .alert-mf {
        border: none;
        border-radius: 14px;
        padding: 1rem 1.25rem;
        font-weight: 500;
    }
    .alert-mf.alert-danger { background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%); color: #991b1b; }
    .alert-mf.alert-success { background: linear-gradient(135deg, #dbeafe 0%, #bae6fd 100%); color: #0097B2; }
    .alert-mf.alert-info { background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%); color: #0097B2; }
    .badge-mf { padding: 0.35rem 0.65rem; border-radius: 9999px; font-size: 0.8rem; font-weight: 600; }
    .badge-mf-success { background: #dbeafe; color: #0097B2; }
    .badge-mf-warning { background: #fef3c7; color: #0097B2; }
    .badge-mf-danger { background: #fee2e2; color: #991b1b; }
</style>
</style>

<main class="main rv-list-page">
    <div class="container py-4">
                <div class="mf-rect-hero mb-4">
                    <div class="mf-rect-inner">
                        <h1 class="mf-rect-title">📋 Liste des rendez-vous</h1>
                        <p class="mf-rect-sub">Consultez, modifiez ou supprimez vos rendez-vous.</p>
                    </div>
                </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-mf alert-{{ label == 'error' ? 'danger' : 'success' }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        {% if rendezvous is empty %}
            <div class="alert alert-mf alert-info">Aucun rendez-vous trouvé.</div>
        {% else %}
            <div class="mf-card">
                <div class="table-responsive">
                    <div class="mb-3 d-flex justify-content-end align-items-center">
                        <div class="search-sort-group">
                            <input type="text" id="searchRendezvous" class="stylish-search me-2" placeholder="🔍 Recherche">
                            <button id="sortRendezvousDate" class="btn btn-sort-date" data-asc="true">
                                <i class="fas fa-sort-up"></i> Trier par date
                            </button>
                        </div>
                    </div>
                    <table class="table mf-table mb-0" id="rendezvousTable">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Date & Heure</th>
                                <th>Statut</th>
                                <th>Mode</th>
                                <th>Motif</th>
                                <th>Patient</th>
                                <th>Staff</th>
                                <th>Créé le</th>
                                <th>Modifier</th>
                                <th>Supprimer</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for r in rendezvous %}
                                <tr>
                                    <td><strong>{{ r.id }}</strong></td>
                                    <td>{{ r.datetime ? r.datetime|date('Y-m-d H:i') : '—' }}</td>
                                    <td>
                                        <span class="badge-mf badge-mf-{% if r.statut == 'approuvé' or r.statut == 'Confirmé' %}success{% elseif r.statut == 'rejeté' %}danger{% else %}warning{% endif %}">{{ r.statut }}</span>
                                    </td>
                                    <td>{{ r.mode }}</td>
                                    <td>{{ r.motif }}</td>
                                    <td>
                                      {% if r.getPatient and r.getPatient() %}
                                        {% if r.getPatient().id == patientId %}
                                          <strong>Moi ({{ r.getPatient().nom }} {{ r.getPatient().prenom }})</strong>
                                        {% else %}
                                          {{ r.getPatient().nom }} {{ r.getPatient().prenom }}
                                        {% endif %}
                                      {% else %}
                                        —
                                      {% endif %}
                                    </td>
                                    <td>
                                      {% if r.getStaff and r.getStaff() %}
                                        {{ r.getStaff().nom }} {{ r.getStaff().prenom }}
                                      {% else %}
                                        —
                                      {% endif %}
                                    </td>
                                    <td>{{ r.createdAt ? r.createdAt|date('Y-m-d H:i') : '—' }}</td>
                                    <!-- Edit button removed -->
                                    <td>
                                        <a href="{{ path('modify_rendezvous', {'id': r.id}) }}" class="btn btn-mf-outline btn-pill" title="Modifier ce rendez-vous">
                                            📝
                                        </a>
                                    </td>
                                    <td>
                                        <form method="post" action="{{ path('rendezvous_delete', {'id': r.id}) }}" onsubmit="return confirm('Supprimer ce rendez-vous ?');" style="display:inline;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ r.id) }}">
                                            <button class="btn btn-mf-outline btn-pill" style="color:#dc2626; border-color:#dc2626;" type="submit">🗑️</button>
                                        </form>
                                    </td>
                                </tr>
                                <!-- Edit row removed -->
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}
    </div>

    {# ============================= #}
    {# Fiche Médicale Table Section #}
    {# ============================= #}
    <div class="container py-4">
                <div class="mf-rect-hero mb-4" style="background: var(--mf-dark-turquoise);">
                    <div class="mf-rect-inner">
                        <h1 class="mf-rect-title">🩺 Ma fiche médicale</h1>
                        <p class="mf-rect-sub">Consultez vos informations médicales enregistrées.</p>
                    </div>
                </div>
        {% if fiches_medicales is defined and fiches_medicales|length > 0 %}
            <div class="mf-card mb-4">
                <div class="table-responsive">
                    <div class="mb-3 d-flex justify-content-end align-items-center">
                        <div class="search-sort-group">
                            <input type="text" id="searchFiche" class="stylish-search me-2" placeholder="🔍 Recherche">
                            <button id="sortFicheDate" class="btn btn-sort-date" data-asc="true">
                                <i class="fas fa-sort-up"></i> Trier par date
                            </button>
                        </div>
                    </div>
                    <table class="table mf-table mb-0" id="ficheTable">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Rendez-vous</th>
                                <th>Diagnostic</th>
                                <th>Observations</th>
                                <th>Résultats Examens</th>
                                <th>Début</th>
                                <th>Fin</th>
                                <th>Durée (min)</th>
                                <th>Date de création</th>
                                <th>PDF</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% set foundFiche = false %}
                            {% for fiche in fiches_medicales %}
                                {% if fiche.getRendezVous and fiche.getRendezVous() and fiche.getRendezVous().getPatient and fiche.getRendezVous().getPatient() and fiche.getRendezVous().getPatient().id == patientId %}
                                    {% set foundFiche = true %}
                                    <tr>
                                        <td>{{ fiche.id }}</td>
                                        <td>{{ fiche.getRendezVous and fiche.getRendezVous() ? fiche.getRendezVous().id : '—' }}</td>
                                        <td>{{ fiche.diagnostic|default('—') }}</td>
                                        <td>{{ fiche.observations|default('—') }}</td>
                                        <td>{{ fiche.resultatsExamens is defined ? fiche.resultatsExamens|default('—') : (fiche.resultats_examens is defined ? fiche.resultats_examens|default('—') : '—') }}</td>
                                        <td>{{ fiche.startTime is defined and fiche.startTime ? fiche.startTime|date('Y-m-d H:i') : (fiche.start_time is defined and fiche.start_time ? fiche.start_time|date('Y-m-d H:i') : '—') }}</td>
                                        <td>{{ fiche.endTime is defined and fiche.endTime ? fiche.endTime|date('Y-m-d H:i') : (fiche.end_time is defined and fiche.end_time ? fiche.end_time|date('Y-m-d H:i') : '—') }}</td>
                                        <td>{{ fiche.dureeMinutes is defined and fiche.dureeMinutes is not null ? fiche.dureeMinutes : (fiche.duree_minutes is defined and fiche.duree_minutes is not null ? fiche.duree_minutes : '—') }}</td>
                                        <td>{{ fiche.createdAt ? fiche.createdAt|date('Y-m-d H:i') : (fiche.created_at is defined and fiche.created_at ? fiche.created_at|date('Y-m-d H:i') : '—') }}</td>
                                        <td>
                                            <a href="{{ path('fiche_medicale_export_pdf', {'id': fiche.id}) }}" class="btn btn-mf-outline btn-pill btn-sm" title="Exporter en PDF" download>PDF</a>
                                        </td>
                                    </tr>
                                {% endif %}
                            {% endfor %}
                            {% if not foundFiche %}
                                <tr><td colspan="9">Aucune fiche médicale trouvée.</td></tr>
                            {% endif %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% else %}
            <div class="alert alert-mf alert-info">Aucune fiche médicale trouvée.</div>
        {% endif %}
    </div>

    {# ============================= #}
    {# Prescriptions Table Section  #}
    {# ============================= #}
    <div class="container py-4">
                <div class="mf-rect-hero mb-4" style="background: var(--mf-dark-turquoise);">
                    <div class="mf-rect-inner">
                        <h1 class="mf-rect-title">💊 Mes prescriptions</h1>
                        <p class="mf-rect-sub">Consultez vos prescriptions médicales.</p>
                    </div>
                </div>
        {% if prescriptions is defined and prescriptions|length > 0 %}
            <div class="mf-card mb-4" style="background: var(--mf-light-blue); border: 1.5px solid var(--mf-dark-turquoise);">
                <div class="table-responsive">
                    <div class="mb-3 d-flex justify-content-end align-items-center">
                        <div class="search-sort-group">
                            <input type="text" id="searchPrescription" class="stylish-search me-2" placeholder="🔍 Recherche">
                            <button id="sortPrescriptionDate" class="btn btn-sort-date" data-asc="true">
                                <i class="fas fa-sort-up"></i> Trier par date
                            </button>
                        </div>
                    </div>
                    <table class="table mf-table mb-0" id="prescriptionTable" style="background: var(--mf-light-blue);">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Date</th>
                                <th>Médicament</th>
                                <th>Dosage</th>
                                <th>Fréquence</th>
                                <th>Durée</th>
                                <th>Instructions</th>
                                <th>Fiche Médicale</th>
                                <th>PDF</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% set foundPrescription = false %}
                            {% for prescription in prescriptions %}
                                {% set fiche = prescription.ficheMedicale is defined ? prescription.ficheMedicale : (prescription.getFicheMedicale is defined ? prescription.getFicheMedicale() : null) %}
                                {% if fiche and fiche.getRendezVous and fiche.getRendezVous() and fiche.getRendezVous().getPatient and fiche.getRendezVous().getPatient() and fiche.getRendezVous().getPatient().id == patientId %}
                                    {% set foundPrescription = true %}
                                    <tr>
                                        <td>{{ prescription.id }}</td>
                                        <td>{{ prescription.createdAt ? prescription.createdAt|date('Y-m-d') : '—' }}</td>
                                        <td>{{ prescription.nomMedicament|default('—') }}</td>
                                        <td>{{ prescription.dose|default('—') }}</td>
                                        <td>{{ prescription.frequence|default('—') }}</td>
                                        <td>{{ prescription.duree|default('—') }}</td>
                                        <td>{{ prescription.instructions|default('—') }}</td>
                                        <td>{{ fiche.id }}</td>
                                        <td>
                                            <a href="{{ path('prescription_export_pdf', {'id': prescription.id}) }}" class="btn btn-mf-outline btn-pill btn-sm" title="Exporter en PDF" download>PDF</a>
                                        </td>
                                    </tr>
                                {% endif %}
                            {% endfor %}
                            {% if not foundPrescription %}
                                <tr><td colspan="5">Aucune prescription trouvée.</td></tr>
                            {% endif %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% else %}
            <div class="alert alert-mf alert-info">Aucune prescription trouvée.</div>
        {% endif %}
    </div>

    <style>
        .search-sort-group {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            background: #f0fdfa;
            border-radius: 2rem;
            padding: 0.35rem 0.7rem 0.35rem 1rem;
            box-shadow: 0 2px 12px #38bdf822, 0 1.5px 4px #2563eb11;
            border: 2px solid #38bdf8;
            margin-bottom: 0;
        }
        .stylish-search {
            border-radius: 2rem;
            border: none;
            font-size: 1.08em;
            padding: 0.5em 1.2em 0.5em 2.2em;
            background: linear-gradient(90deg, #f0fdfa 0%, #ecfeff 100%);
            box-shadow: none;
            color: #2563eb;
            width: 220px;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
            background-image: url('data:image/svg+xml;utf8,<svg fill="%2338bdf8" height="18" viewBox="0 0 24 24" width="18" xmlns="http://www.w3.org/2000/svg"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99c.41.41 1.09.41 1.5 0s.41-1.09 0-1.5l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>');
            background-repeat: no-repeat;
            background-position: 0.7em center;
        }
        .stylish-search:focus {
            border: none;
            box-shadow: 0 0 0 3px #2563eb33;
        }
        .btn-sort-date {
            border-radius: 2rem;
            font-size: 1em;
            font-weight: 600;
            background: linear-gradient(90deg, #ecfeff 0%, #38bdf8 100%);
            color: #2563eb;
            border: none;
            box-shadow: 0 2px 8px #38bdf822;
            padding: 0.5em 1.2em;
            transition: background 0.2s, color 0.2s, box-shadow 0.2s;
            display: flex;
            align-items: center;
            gap: 0.5em;
        }
        .btn-sort-date:hover {
            background: linear-gradient(90deg, #38bdf8 0%, #2563eb 100%);
            color: #fff;
            box-shadow: 0 4px 16px #2563eb33;
        }
        @media (max-width: 600px) {
            .search-sort-group {
                flex-direction: column;
                align-items: stretch;
                padding: 0.5rem 0.7rem;
            }
            .stylish-search {
                width: 100%;
                margin-bottom: 0.5rem;
            }
            .btn-sort-date {
                width: 100%;
            }
        }
    </style>
    <script>
                // Sort by date utility
                function setupDateSort(tableId, btnId, dateColIdx) {
                    const table = document.getElementById(tableId);
                    const btn = document.getElementById(btnId);
                    if (!table || !btn) return;
                    btn.addEventListener('click', function() {
                        const asc = btn.dataset.asc === 'true';
                        const rows = Array.from(table.tBodies[0].rows).filter(row => row.cells.length > dateColIdx);
                        rows.sort((a, b) => {
                            // Robust date parsing: fallback to 0 if invalid
                            const aText = a.cells[dateColIdx].textContent.trim();
                            const bText = b.cells[dateColIdx].textContent.trim();
                            const aDate = Date.parse(aText) || 0;
                            const bDate = Date.parse(bText) || 0;
                            return asc ? aDate - bDate : bDate - aDate;
                        });
                        rows.forEach(row => table.tBodies[0].appendChild(row));
                        btn.dataset.asc = (!asc).toString();
                        btn.innerHTML = `<i class="fas fa-sort-${asc ? 'down' : 'up'}"></i> Trier par date`;
                    });
                }
            setupDateSort('rendezvousTable', 'sortRendezvousDate', 1); // Date & Heure col
            setupDateSort('ficheTable', 'sortFicheDate', 8); // Date de création col
            setupDateSort('prescriptionTable', 'sortPrescriptionDate', 1); // Date col


        // Table search and sort utility
        function setupTableSearch(tableId, searchId) {
            const table = document.getElementById(tableId);
            const search = document.getElementById(searchId);
            if (!table || !search) return;
            search.addEventListener('input', function() {
                const filter = search.value.toLowerCase();
                Array.from(table.tBodies[0].rows).forEach(row => {
                    const text = row.textContent.toLowerCase();
                    row.style.display = text.includes(filter) ? '' : 'none';
                });
            });
        }

        function setupTableSort(tableId) {
            const table = document.getElementById(tableId);
            if (!table) return;
            Array.from(table.tHead.rows[0].cells).forEach((th, idx) => {
                th.style.cursor = 'pointer';
                th.addEventListener('click', function() {
                    const rows = Array.from(table.tBodies[0].rows);
                    const asc = th.dataset.asc === 'true';
                    rows.sort((a, b) => {
                        const aText = a.cells[idx].textContent.trim();
                        const bText = b.cells[idx].textContent.trim();
                        return asc ? aText.localeCompare(bText, undefined, {numeric:true}) : bText.localeCompare(aText, undefined, {numeric:true});
                    });
                    rows.forEach(row => table.tBodies[0].appendChild(row));
                    th.dataset.asc = (!asc).toString();
                });
            });
        }

        document.addEventListener('DOMContentLoaded', function(){
            setupTableSearch('rendezvousTable', 'searchRendezvous');
            setupTableSort('rendezvousTable');
            setupTableSearch('ficheTable', 'searchFiche');
            setupTableSort('ficheTable');
            setupTableSearch('prescriptionTable', 'searchPrescription');
            setupTableSort('prescriptionTable');


        });
    </script>
{% endblock %}