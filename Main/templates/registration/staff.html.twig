{% extends 'base_auth.html.twig' %}

{% block title %}Inscription Staff Medical{% endblock %}

{% block body %}
<div class="auth-page">
  <div class="container py-5">
    <div class="row justify-content-center w-100">
      <div class="col-12 col-lg-10 col-xl-9">
        <div class="glass-card p-4 p-md-5">

          <div class="auth-brand">
            <a class="auth-brand__logo" href="{{ path('app_home') }}" aria-label="Aller à l'accueil">
              <img src="{{ asset('assets/img/img.png') }}" alt="MedFlow">
            </a>
            <div class="flex-grow-1">
              <p class="auth-brand__title">MedFlow</p>
              <p class="auth-brand__subtitle">Accès Staff : demande sécurisée et vérifiée.</p>
            </div>
            <a href="{{ path('app_home') }}" class="btn btn-sm btn-outline-secondary">Accueil</a>
          </div>

          <div class="d-flex justify-content-between align-items-center mb-4">
            <span class="brand-pill"><i class="bi bi-shield-check"></i>Inscription Staff</span>
            <div class="d-flex gap-2 align-items-center">
              <a class="small-link text-decoration-none" href="{{ path('app_register') }}">
                <i class="bi bi-person"></i> Je suis patient
              </a>
              <button type="button" class="btn btn-sm btn-outline-secondary" id="themeToggle" aria-label="Basculer le thème">
                <i class="bi bi-sun-fill" id="themeIconSun" aria-hidden="true"></i>
                <i class="bi bi-moon-stars-fill d-none" id="themeIconMoon" aria-hidden="true"></i>
              </button>
            </div>
          </div>

          <h2 class="fw-bold mb-1">Créer un compte Staff</h2>
          <p class="help-text mb-4">Votre compte sera activé après vérification de l’email et validation par un administrateur.</p>

          {% for label, messages in app.flashes %}
            {% for m in messages %}
              {% set bs = (label == 'error') ? 'danger' : label %}
              <div class="alert alert-{{ bs }} py-2 mb-3" style="border-radius:14px;">
                {{ m }}
              </div>
            {% endfor %}
          {% endfor %}

          <div class="alert alert-info py-2 mb-4" style="border-radius:14px;">
            <div class="fw-semibold mb-1"><i class="bi bi-info-circle me-2"></i>Validation obligatoire</div>
            <div class="small">Votre demande est traitée en best-effort. Plus vos documents sont lisibles, plus la validation est rapide.</div>
          </div>

          {{ form_start(form, { attr: { novalidate: 'novalidate' }, enctype: 'multipart/form-data' }) }}

          <div class="row g-2 auth-form-has-sticky">
            <div class="col-12">
              <h3 class="h6 mb-1">1) Informations du compte</h3>
              <p class="help-text mb-0">Données de base pour créer votre compte.</p>
            </div>

            <div class="col-md-4">
              {{ form_label(form.cin, 'CIN', { label_attr: { class: 'form-label' } }) }}
              {{ form_widget(form.cin, { attr: { class: 'form-control ' ~ (form.cin.vars.errors|length ? 'is-invalid' : ''), placeholder: '8 chiffres' } }) }}
              {% if form.cin.vars.errors|length %}<div class="err">{{ form_errors(form.cin) }}</div>{% endif %}
            </div>
            {% if form.nom is defined %}
              <div class="col-md-4">
                {{ form_label(form.nom, 'Nom', { label_attr: { class: 'form-label' } }) }}
                {{ form_widget(form.nom, { attr: { class: 'form-control ' ~ (form.nom.vars.errors|length ? 'is-invalid' : ''), placeholder: 'Votre nom' } }) }}
                {% if form.nom.vars.errors|length %}<div class="err">{{ form_errors(form.nom) }}</div>{% endif %}
              </div>
            {% endif %}
            {% if form.prenom is defined %}
              <div class="col-md-4">
                {{ form_label(form.prenom, 'Prénom', { label_attr: { class: 'form-label' } }) }}
                {{ form_widget(form.prenom, { attr: { class: 'form-control ' ~ (form.prenom.vars.errors|length ? 'is-invalid' : ''), placeholder: 'Votre prénom' } }) }}
                {% if form.prenom.vars.errors|length %}<div class="err">{{ form_errors(form.prenom) }}</div>{% endif %}
              </div>
            {% endif %}

            {% if form.emailUser is defined %}
              <div class="col-md-6">
                {{ form_label(form.emailUser, 'Adresse e-mail', { label_attr: { class: 'form-label' } }) }}
                {{ form_widget(form.emailUser, { attr: { class: 'form-control ' ~ (form.emailUser.vars.errors|length ? 'is-invalid' : ''), placeholder: 'exemple@email.com', autocomplete: 'email', inputmode: 'email', autocapitalize: 'none', spellcheck: 'false' } }) }}
                {% if form.emailUser.vars.errors|length %}<div class="err">{{ form_errors(form.emailUser) }}</div>{% endif %}
              </div>
            {% endif %}
            <div class="col-md-6">
              {{ form_label(form.telephoneUser, 'Téléphone', { label_attr: { class: 'form-label' } }) }}
              {{ form_widget(form.telephoneUser, { attr: { class: 'form-control ' ~ (form.telephoneUser.vars.errors|length ? 'is-invalid' : ''), placeholder: '54430709 ou +21654430709' } }) }}
              {% if form.telephoneUser.vars.errors|length %}<div class="err">{{ form_errors(form.telephoneUser) }}</div>{% endif %}
            </div>

            <div class="col-md-6">
              {{ form_label(form.dateNaissance, 'Date de naissance', { label_attr: { class: 'form-label' } }) }}
              {{ form_widget(form.dateNaissance, { attr: { class: 'form-control ' ~ (form.dateNaissance.vars.errors|length ? 'is-invalid' : '') } }) }}
              {% if form.dateNaissance.vars.errors|length %}<div class="err">{{ form_errors(form.dateNaissance) }}</div>{% endif %}
            </div>
            <div class="col-md-6">
              {% set pwdInvalid = (form.plainPassword.vars.errors|length or form.plainPassword.first.vars.errors|length or form.plainPassword.second.vars.errors|length) %}
              {{ form_label(form.plainPassword.first, null, { label_attr: { class: 'form-label' } }) }}
              <div class="input-group">
                {{ form_widget(form.plainPassword.first, { attr: { class: 'form-control ' ~ (pwdInvalid ? 'is-invalid' : ''), placeholder: '••••••••', autocomplete: 'new-password' } }) }}
                <button type="button" class="btn btn-outline-secondary" data-password-toggle="{{ form.plainPassword.first.vars.id }}" aria-label="Afficher le mot de passe">
                  <i class="bi bi-eye"></i>
                </button>
              </div>
              {% if form.plainPassword.first.vars.errors|length %}<div class="err">{{ form_errors(form.plainPassword.first) }}</div>{% endif %}

              <div class="d-flex justify-content-end mt-2">
                <button type="button" class="btn btn-outline-secondary btn-auth-compact" data-password-suggest data-password-api="{{ path('api_password_suggest') }}">
                  <i class="bi bi-magic me-2"></i>Suggérer un mot de passe
                </button>
              </div>
              <div class="mt-3">
                {{ form_label(form.plainPassword.second, null, { label_attr: { class: 'form-label' } }) }}
                <div class="input-group">
                  {{ form_widget(form.plainPassword.second, { attr: { class: 'form-control ' ~ (pwdInvalid ? 'is-invalid' : ''), placeholder: '••••••••', autocomplete: 'new-password' } }) }}
                  <button type="button" class="btn btn-outline-secondary" data-password-toggle="{{ form.plainPassword.second.vars.id }}" aria-label="Afficher le mot de passe">
                    <i class="bi bi-eye"></i>
                  </button>
                </div>
                {% if form.plainPassword.second.vars.errors|length %}<div class="err">{{ form_errors(form.plainPassword.second) }}</div>{% endif %}
              </div>

              {% if form.plainPassword.vars.errors|length %}<div class="err mt-2">{{ form_errors(form.plainPassword) }}</div>{% endif %}
            </div>

            <div class="col-12">
              {{ form_label(form.adresseUser, 'Adresse (optionnel)', { label_attr: { class: 'form-label' } }) }}
              {{ form_widget(form.adresseUser, { attr: { class: 'form-control ' ~ (form.adresseUser.vars.errors|length ? 'is-invalid' : ''), placeholder: 'Votre adresse' } }) }}
              {% if form.adresseUser.vars.errors|length %}<div class="err">{{ form_errors(form.adresseUser) }}</div>{% endif %}
            </div>

            {% if form.profilePictureFile is defined %}
              <div class="col-12">
                {{ form_label(form.profilePictureFile, 'Photo de profil (optionnel)', { label_attr: { class: 'form-label' } }) }}
                {{ form_widget(form.profilePictureFile, { attr: { class: 'form-control ' ~ (form.profilePictureFile.vars.errors|length ? 'is-invalid' : '') } }) }}
                {% if form.profilePictureFile.vars.errors|length %}<div class="err">{{ form_errors(form.profilePictureFile) }}</div>{% endif %}
              </div>
            {% endif %}

            <div class="col-12 mt-2">
              <hr class="my-3" style="border-color: rgba(var(--bs-body-color-rgb), .15);">
            </div>

            <div class="col-12">
              <h3 class="h6 mb-1">2) Informations professionnelles</h3>
              <p class="help-text mb-0">Ces informations aident l’administrateur à valider votre accès.</p>
            </div>

            <div class="col-md-6">
              <label class="form-label">Type Staff *</label>
              <select name="type_staff" class="form-select">
                <option value="">Choisir…</option>
                <option value="MEDECIN">Médecin</option>
                <option value="PHARMACIEN">Pharmacien</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Spécialité (optionnel)</label>
              <select name="doc_specialite" class="form-select">
                <option value="">Choisir…</option>
                <option value="Médecine générale">Médecine générale</option>
                <option value="Cardiologie">Cardiologie</option>
                <option value="Pédiatrie">Pédiatrie</option>
                <option value="Gynécologie">Gynécologie</option>
                <option value="Dermatologie">Dermatologie</option>
                <option value="Radiologie">Radiologie</option>
                <option value="Laboratoire">Laboratoire</option>
                <option value="Pharmacie">Pharmacie</option>
                <option value="Infirmier">Infirmier</option>
                <option value="Autre">Autre</option>
              </select>
            </div>

            <div class="col-md-4">
              <label class="form-label">Années d’expérience</label>
              <input type="number" name="doc_experience" class="form-control" placeholder="Ex: 5">
            </div>
            <div class="col-md-4">
              <label class="form-label">Établissement actuel</label>
              <input type="text" name="doc_etablissement" class="form-control" placeholder="Clinique / Hôpital / Pharmacie">
            </div>
            <div class="col-md-4">
              <label class="form-label">N° autorisation d'exercice *</label>
              <input type="text" name="doc_numero" class="form-control" placeholder="N° d'autorisation">
            </div>

            <div class="col-12">
              <label class="form-label">Message (optionnel)</label>
              <textarea name="message" class="form-control" rows="3" placeholder="Décrivez brièvement votre expérience et le besoin d'accès."></textarea>
            </div>

            <div class="col-12 mt-2">
              <hr class="my-3" style="border-color: rgba(var(--bs-body-color-rgb), .15);">
            </div>

            <div class="col-12">
              <h3 class="h6 mb-1">3) Pièces justificatives</h3>
              <p class="help-text mb-0">Formats : PDF/JPG/PNG (best-effort).</p>
            </div>

            <div class="col-md-6">
              <label class="form-label">Carte d'identité (CIN / passeport) *</label>
              <input type="file" name="id_doc" class="form-control" accept="image/*,.pdf">
            </div>
            <div class="col-md-6">
              <label class="form-label">Diplôme médical *</label>
              <input type="file" name="diploma" class="form-control" accept="image/*,.pdf">
            </div>
            <div class="col-md-6">
              <label class="form-label">Attestation ordre professionnel *</label>
              <input type="file" name="attestation" class="form-control" accept="image/*,.pdf">
            </div>
            <div class="col-md-6">
              <label class="form-label">Photo professionnelle *</label>
              <input type="file" name="pro_photo" class="form-control" accept="image/*">
            </div>
            <div class="col-12">
              <label class="form-label">Autres documents (optionnel)</label>
              <input type="file" name="proofs[]" class="form-control" accept="image/*,.pdf" multiple>
              <div class="form-text">Vous pouvez envoyer plusieurs fichiers.</div>
            </div>
          </div>

          {% if form.acceptTerms is defined %}
            <div class="mt-3">
              <div class="form-check">
                {{ form_widget(form.acceptTerms, { attr: { class: 'form-check-input' } }) }}
                <label class="form-check-label" for="{{ form.acceptTerms.vars.id }}">
                  J’accepte les
                  <a href="#" class="text-decoration-none" data-bs-toggle="modal" data-bs-target="#mfTermsModal">Conditions d’utilisation</a>
                  de MedFlow.
                </label>
              </div>
              {% if form.acceptTerms.vars.errors|length %}
                <div class="err">{{ form_errors(form.acceptTerms) }}</div>
              {% endif %}
            </div>
          {% endif %}

          {% if recaptcha_site_key %}
            <div class="d-flex justify-content-center mt-3">
              <div class="g-recaptcha" data-sitekey="{{ recaptcha_site_key }}"></div>
            </div>
          {% endif %}

          <div class="auth-sticky-actions">
            <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-2">
              <div class="d-flex align-items-center gap-2 flex-wrap">
                <span class="text-muted small">Déjà un compte ?</span>
                <a href="{{ path('app_login') }}" class="btn btn-outline-primary btn-auth-compact">
                  <i class="bi bi-box-arrow-in-right me-2"></i>Se connecter
                </a>
              </div>
              <button class="btn btn-primary btn-glow btn-auth-compact" type="submit">
                <i class="bi bi-send me-2"></i>Envoyer la demande
              </button>
            </div>
          </div>

          {{ form_row(form._token) }}
          {{ form_end(form, { render_rest: false }) }}

          <div class="text-muted small mt-3">
            OCR automatique : si vous uploadez une image (JPG/PNG), le texte peut être extrait automatiquement pour aider l’admin (best-effort).
          </div>

        </div>
      </div>
    </div>
  </div>
</div>
{% include 'registration/_terms_modal.html.twig' %}
{% endblock %}
