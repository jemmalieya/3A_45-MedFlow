{% extends 'base_auth.html.twig' %}

{% block title %}{{ title|default('Inscription') }}{% endblock %}

{% block body %}
<div class="auth-page">
  <div class="container py-5">
    <div class="row justify-content-center w-100">
      <div class="col-12 col-lg-9 col-xl-8">
        <div class="glass-card p-4 p-md-5">

        <div class="auth-brand">
          <a class="auth-brand__logo" href="{{ path('app_home') }}" aria-label="Aller à l'accueil">
            <img src="{{ asset('assets/img/img.png') }}" alt="MedFlow">
          </a>
          <div class="flex-grow-1">
            <p class="auth-brand__title">MedFlow</p>
            <p class="auth-brand__subtitle">Créer votre compte en quelques secondes.</p>
          </div>
          <a href="{{ path('app_home') }}" class="btn btn-sm btn-outline-secondary">Accueil</a>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-4">
          <span class="brand-pill"><i class="bi bi-shield-lock me-2"></i>Inscription</span>
          <div class="d-flex gap-2 align-items-center">
            <a class="small-link text-decoration-none" href="{{ path('app_login') }}">
              <i class="bi bi-box-arrow-in-right"></i> Connexion
            </a>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="themeToggle" aria-label="Basculer le thème">
              <i class="bi bi-sun-fill" id="themeIconSun" aria-hidden="true"></i>
              <i class="bi bi-moon-stars-fill d-none" id="themeIconMoon" aria-hidden="true"></i>
            </button>
          </div>
        </div>

        <h2 class="fw-bold mb-1">Créer un compte</h2>

        {% if isGoogleSignup|default(false) %}
          <div class="alert alert-info py-2 mb-4" style="border-radius:14px;">
            <div class="fw-semibold"><i class="bi bi-google me-2"></i>Inscription via Google</div>
            <div class="small">Nom, prénom et email sont pré-remplis. Le mot de passe est optionnel (vous pouvez vous connecter via Google). Vous pourrez définir/modifier un mot de passe plus tard si besoin.</div>
          </div>
        {% endif %}

        {% for label, messages in app.flashes %}
          {% for message in messages %}
            {% set bs = (label == 'error') ? 'danger' : label %}
            <div class="alert alert-{{ bs }} py-2 mb-3" style="border-radius:14px;">
              {{ message }}
            </div>
          {% endfor %}
        {% endfor %}

        {# ✅ ERREURS GLOBALES (ex: email déjà utilisé, CSRF, etc.) #}
        {% if form.vars.errors|length > 0 %}
          <div class="alert alert-glass mb-4">
            <div class="fw-bold mb-1"><i class="bi bi-exclamation-triangle me-2"></i>Veuillez corriger les erreurs :</div>
            {{ form_errors(form) }}
          </div>
        {% endif %}

        {{ form_start(form, { attr: { novalidate: 'novalidate' }, enctype: 'multipart/form-data' }) }}

        <div class="row g-3">

          <div class="col-md-6">
            {{ form_label(form.cin, 'CIN', { label_attr: { class: 'form-label' } }) }}
            {{ form_widget(form.cin, {
              attr: {
                class: 'form-control ' ~ (form.cin.vars.errors|length ? 'is-invalid' : ''),
                placeholder: '8 chiffres'
              }
            }) }}
            {% if form.cin.vars.errors|length %}
              <div class="err">{{ form_errors(form.cin) }}</div>
            {% endif %}
          </div>

          {% if form.profilePictureFile is defined %}
            <div class="col-md-6">
              {{ form_label(form.profilePictureFile, 'Photo de profil (optionnel)', { label_attr: { class: 'form-label' } }) }}
              {{ form_widget(form.profilePictureFile, {
                attr: { class: 'form-control ' ~ (form.profilePictureFile.vars.errors|length ? 'is-invalid' : '') }
              }) }}
              {% if form.profilePictureFile.vars.errors|length %}
                <div class="err">{{ form_errors(form.profilePictureFile) }}</div>
              {% endif %}
            </div>
          {% endif %}

          {% if form.nom is defined %}
            <div class="col-md-6">
              {{ form_label(form.nom, 'Nom', { label_attr: { class: 'form-label' } }) }}
              {{ form_widget(form.nom, {
                attr: {
                  class: 'form-control ' ~ (form.nom.vars.errors|length ? 'is-invalid' : ''),
                  placeholder: 'Votre nom'
                }
              }) }}
              {% if form.nom.vars.errors|length %}
                <div class="err">{{ form_errors(form.nom) }}</div>
              {% endif %}
            </div>
          {% endif %}

          {% if form.prenom is defined %}
            <div class="col-md-6">
              {{ form_label(form.prenom, 'Prénom', { label_attr: { class: 'form-label' } }) }}
              {{ form_widget(form.prenom, {
                attr: {
                  class: 'form-control ' ~ (form.prenom.vars.errors|length ? 'is-invalid' : ''),
                  placeholder: 'Votre prénom'
                }
              }) }}
              {% if form.prenom.vars.errors|length %}
                <div class="err">{{ form_errors(form.prenom) }}</div>
              {% endif %}
            </div>
          {% endif %}

          <div class="col-md-6">
            {{ form_label(form.dateNaissance, 'Date de naissance', { label_attr: { class: 'form-label' } }) }}
            {{ form_widget(form.dateNaissance, {
              attr: { class: 'form-control ' ~ (form.dateNaissance.vars.errors|length ? 'is-invalid' : '') }
            }) }}
            {% if form.dateNaissance.vars.errors|length %}
              <div class="err">{{ form_errors(form.dateNaissance) }}</div>
            {% endif %}
          </div>

          <div class="col-md-6">
            {{ form_label(form.telephoneUser, 'Téléphone', { label_attr: { class: 'form-label' } }) }}
            {{ form_widget(form.telephoneUser, {
              attr: {
                class: 'form-control ' ~ (form.telephoneUser.vars.errors|length ? 'is-invalid' : ''),
                placeholder: '54430709 ou +21654430709'
              }
            }) }}
            {% if form.telephoneUser.vars.errors|length %}
              <div class="err">{{ form_errors(form.telephoneUser) }}</div>
            {% endif %}
          </div>

          {% if form.emailUser is defined %}
            <div class="col-md-6">
              {{ form_label(form.emailUser, 'Adresse e-mail', { label_attr: { class: 'form-label' } }) }}
              {{ form_widget(form.emailUser, {
                attr: {
                  class: 'form-control ' ~ (form.emailUser.vars.errors|length ? 'is-invalid' : ''),
                  placeholder: 'exemple@email.com',
                  autocomplete: 'email',
                  inputmode: 'email',
                  autocapitalize: 'none',
                  spellcheck: 'false'
                }
              }) }}
              {% if form.emailUser.vars.errors|length %}
                <div class="err">{{ form_errors(form.emailUser) }}</div>
              {% endif %}
            </div>
          {% endif %}

          <div class="col-md-6">
            {{ form_label(form.adresseUser, 'Adresse (optionnel)', { label_attr: { class: 'form-label' } }) }}
            {{ form_widget(form.adresseUser, {
              attr: {
                class: 'form-control ' ~ (form.adresseUser.vars.errors|length ? 'is-invalid' : ''),
                placeholder: 'Votre adresse'
              }
            }) }}
            {% if form.adresseUser.vars.errors|length %}
              <div class="err">{{ form_errors(form.adresseUser) }}</div>
            {% endif %}
          </div>

          {% if form.plainPassword is defined %}
            <div class="col-md-6">
              {% set pwdInvalid = (form.plainPassword.vars.errors|length or form.plainPassword.first.vars.errors|length or form.plainPassword.second.vars.errors|length) %}

              {{ form_label(form.plainPassword.first, null, { label_attr: { class: 'form-label' } }) }}
              <div class="input-group">
                {{ form_widget(form.plainPassword.first, {
                  attr: {
                    class: 'form-control ' ~ (pwdInvalid ? 'is-invalid' : ''),
                    placeholder: '••••••••',
                    autocomplete: 'new-password'
                  }
                }) }}
                <button type="button" class="btn btn-outline-secondary" data-password-toggle="{{ form.plainPassword.first.vars.id }}" aria-label="Afficher le mot de passe">
                  <i class="bi bi-eye"></i>
                </button>
              </div>
              {% if form.plainPassword.first.vars.errors|length %}
                <div class="err">{{ form_errors(form.plainPassword.first) }}</div>
              {% endif %}

              <div class="d-flex justify-content-end mt-2">
                <button type="button" class="btn btn-outline-secondary btn-auth-compact" data-password-suggest data-password-api="{{ path('api_password_suggest') }}">
                  <i class="bi bi-magic me-2"></i>Suggérer un mot de passe
                </button>
              </div>

              <div class="mt-3">
                {{ form_label(form.plainPassword.second, null, { label_attr: { class: 'form-label' } }) }}
                <div class="input-group">
                  {{ form_widget(form.plainPassword.second, {
                    attr: {
                      class: 'form-control ' ~ (pwdInvalid ? 'is-invalid' : ''),
                      placeholder: '••••••••',
                      autocomplete: 'new-password'
                    }
                  }) }}
                  <button type="button" class="btn btn-outline-secondary" data-password-toggle="{{ form.plainPassword.second.vars.id }}" aria-label="Afficher le mot de passe">
                    <i class="bi bi-eye"></i>
                  </button>
                </div>
                {% if form.plainPassword.second.vars.errors|length %}
                  <div class="err">{{ form_errors(form.plainPassword.second) }}</div>
                {% endif %}
              </div>

              {% if form.plainPassword.vars.errors|length %}
                <div class="err mt-2">{{ form_errors(form.plainPassword) }}</div>
              {% endif %}
            </div>
          {% endif %}

          {% if form.acceptTerms is defined %}
            <div class="col-12">
              <div class="form-check">
                {{ form_widget(form.acceptTerms, { attr: { class: 'form-check-input' } }) }}
                <label class="form-check-label" for="{{ form.acceptTerms.vars.id }}">
                  J’accepte les
                  <a href="#" class="text-decoration-none" data-bs-toggle="modal" data-bs-target="#mfTermsModal">Conditions d’utilisation</a>
                  de MedFlow.
                </label>
              </div>
              {% if form.acceptTerms.vars.errors|length %}
                <div class="err">{{ form_errors(form.acceptTerms) }}</div>
              {% endif %}
            </div>
          {% endif %}

        </div>

        {% if recaptcha_site_key %}
          <div class="d-flex justify-content-center mt-3">
            <div class="g-recaptcha" data-sitekey="{{ recaptcha_site_key }}"></div>
          </div>
        {% endif %}

        <div class="d-grid mt-4">
          <button class="btn btn-primary btn-glow" type="submit">
            <i class="bi bi-person-plus"></i> S’inscrire
          </button>
        </div>

        {{ form_row(form._token) }}
        {{ form_end(form, { render_rest: false }) }}

        <div class="text-center mt-4">
          <div class="text-muted mb-2">Vous avez déjà un compte ?</div>
          <a href="{{ path('app_login') }}" class="btn btn-outline-primary">
            <i class="bi bi-box-arrow-in-right me-2"></i>Se connecter
          </a>
        </div>

        <div class="text-center mt-3">
          <div class="text-muted mb-2">Vous êtes personnel médical ?</div>
          <a href="{{ path('app_register_staff') }}" class="btn btn-outline-secondary">
            <i class="bi bi-shield-check me-2"></i>Demander un accès Staff
          </a>
        </div>

        </div>
      </div>
    </div>
  </div>
</div>
{% include 'registration/_terms_modal.html.twig' %}
{% endblock %}