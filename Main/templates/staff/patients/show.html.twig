{% extends 'base_dashboard.html.twig' %}

{% block title %}Fiche Patient{% endblock %}

{% block body %}
<div class="container mw-1120">
  <div class="page-header text-center mb-4">
    <h1><i class="bi bi-person me-3"></i>Fiche Patient</h1>
    <p>Informations administratives et suivi.</p>
  </div>
  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <ul>
        <li>Nom: {{ p.getNom() }}</li>
        <li>Email: {{ p.getEmailUser() }}</li>
        <li>Date d'inscription: {{ p.getTokenExpiresAt() ? p.getTokenExpiresAt()|date('d/m/Y') : 'N/A' }}</li>
        <li>Statut: {% if not quality.incomplete %}<span class="badge bg-success">Complet</span>{% else %}<span class="badge bg-warning text-dark">Incomplet</span>{% endif %}</li>
        <li>Documents manquants:
          {% set missingDocs = '' %}
          {% for detail in quality.details %}
            {% if 'manquant' in detail|lower %}
              {% if missingDocs != '' %}{% set missingDocs = missingDocs ~ ', ' %}{% endif %}
              {% set missingDocs = missingDocs ~ detail %}
            {% endif %}
          {% endfor %}
          {% if missingDocs != '' %}
            {{ missingDocs }}
          {% else %}
            Aucun
          {% endif %}
        </li>
      </ul>
      <hr>
      <h5>Historique administratif</h5>
      <ul>
        <li>Dernière connexion:
          {% if p.getLastLoginAt() %}
            <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i> Connecté le {{ p.getLastLoginAt()|date('d/m/Y H:i') }}</span>
          {% elseif p.getTokenExpiresAt() %}
            <span class="badge bg-info text-dark"><i class="bi bi-person-plus me-1"></i> Inscrit le {{ p.getTokenExpiresAt()|date('d/m/Y H:i') }}</span>
          {% else %}
            <span class="badge bg-secondary"><i class="bi bi-x-circle me-1"></i> Jamais connecté</span>
          {% endif %}
        </li>
        <li>Dernière mise à jour:
          {% if p.getTokenExpiresAt() %}
            <span class="badge bg-warning text-dark"><i class="bi bi-arrow-repeat me-1"></i> Mise à jour le {{ p.getTokenExpiresAt()|date('d/m/Y H:i') }}</span>
          {% elseif p.getLastLoginAt() %}
            <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i> Connexion le {{ p.getLastLoginAt()|date('d/m/Y H:i') }}</span>
          {% else %}
            <span class="badge bg-secondary"><i class="bi bi-x-circle me-1"></i> Jamais mis à jour</span>
          {% endif %}
        </li>
      </ul>
      <form method="post" action="{{ path('staff_patients_remind', {id: p.getId()}) }}">
        <button type="submit" class="btn btn-warning mt-3">Demander mise à jour</button>
      </form>
    </div>
  </div>
</div>
<style>
:root{
  --primary: #00BFA6;
  --primary-dark: #0097B2;
  --danger: #BC0B09;
  --success: #10b981;
  --warning: #f59e0b;
  --gray-50:#f9fafb;
  --gray-100:#f3f4f6;
  --gray-200:#e5e7eb;
  --gray-700:#374151;
  --gray-800:#1f2937;
  --shadow-sm:0 2px 10px rgba(0,0,0,.06);
  --shadow-md:0 10px 26px rgba(0,0,0,.10);
  --shadow-lg:0 18px 42px rgba(0,0,0,.14);
  --ring: 0 0 0 .22rem rgba(0,151,178,.18);
}
body{ background: #f6fbfb !important; }
.mw-1120{ max-width:1120px; }
.page-header{ background: var(--primary-dark); color:#fff; padding: 42px 0; margin: 26px auto 18px auto; border-radius: 20px; box-shadow: 0 18px 40px rgba(0,151,178,.22); overflow:hidden; position:relative; }
.page-header h1{ font-size: 2.6rem; font-weight: 900; margin:0 0 8px 0; }
.quick-actions{ background:#fff; border-radius: 18px; box-shadow: var(--shadow-sm); border: 1px solid rgba(0,151,178,.10); padding: 14px 16px; }
.btn-orders{ display:inline-flex; align-items:center; gap:10px; padding: 12px 16px; border-radius: 14px; border: none; background: var(--primary-dark); color:#fff; font-weight: 900; text-decoration:none; box-shadow: 0 12px 26px rgba(0,151,178,.18); transition:.2s ease; }
.btn-orders:hover{ transform: translateY(-1px); color:#fff; box-shadow: 0 16px 34px rgba(0,151,178,.26); }
.btn-contact{ display:inline-flex; align-items:center; gap:10px; padding: 12px 16px; border-radius: 14px; border: 2px solid rgba(0,151,178,.25); background: #fff; color: var(--primary-dark); font-weight: 900; transition:.2s ease; }
.btn-contact:hover{ background: #0097B2; color:#fff; }
.stat-box{ box-shadow: 0 2px 10px rgba(0,0,0,.06); border-radius: 12px; }
</style>

{% endblock %}