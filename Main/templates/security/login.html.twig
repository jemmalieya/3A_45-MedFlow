{% extends 'base_auth.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<div class="auth-page">
  <div class="container py-5">
    <div class="row justify-content-center w-100">
      <div class="col-12 col-md-8 col-lg-6">
        <div class="glass-card p-4 p-md-5">

        <div class="auth-brand">
          <a class="auth-brand__logo" href="{{ path('app_home') }}" aria-label="Aller à l'accueil">
            <img src="{{ asset('assets/img/img.png') }}" alt="MedFlow">
          </a>
          <div class="flex-grow-1">
            <p class="auth-brand__title">MedFlow</p>
            <p class="auth-brand__subtitle">Votre espace santé, simple et sécurisé.</p>
          </div>
          <a href="{{ path('app_home') }}" class="btn btn-sm btn-outline-secondary">Accueil</a>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-4">
          <h2 class="fw-bold mb-0"><i class="bi bi-box-arrow-in-right me-2"></i>Connexion</h2>
          <div class="d-flex gap-2 align-items-center">
            <a class="small-link text-decoration-none" href="{{ path('app_register') }}">
              <i class="bi bi-person-plus"></i> Inscription
            </a>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="themeToggle" aria-label="Basculer le thème">
              <i class="bi bi-sun-fill" id="themeIconSun" aria-hidden="true"></i>
              <i class="bi bi-moon-stars-fill d-none" id="themeIconMoon" aria-hidden="true"></i>
            </button>
          </div>
        </div>

        {# ✅ Flash messages #}
        {% for message in app.flashes('success') %}
          <div class="alert alert-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('warning') %}
          <div class="alert alert-warning">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('danger') %}
          <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}

        {# ✅ Errors from login / UserChecker #}
        {% if error %}
          <div class="alert alert-danger">
            {{ error.messageKey|trans(error.messageData, 'security') }}
          </div>
        {% endif %}

        {# ✅ Resend verification only when you show that specific error #}
        {% if error and 'vérifier votre email' in error.messageKey %}
          <form method="post" action="{{ path('app_resend_verification') }}" class="mb-3">
            <div class="input-group">
              <input type="email" name="email" class="form-control" required placeholder="Votre email">
              <button class="btn btn-warning">Renvoyer l’email</button>
            </div>
          </form>
        {% endif %}

        <p class="text-muted mb-4">
          Connectez-vous pour accéder à votre espace.
        </p>

        {# ✅ ONE SINGLE FORM (Symfony Security form_login expects these names) #}
        <form method="post" novalidate>
          <div class="mb-3">
            <label class="form-label">Adresse e-mail</label>
            <input
              type="text"
              name="emailUser"
              class="form-control"
              value="{{ last_username }}"
              placeholder="exemple@email.com"
              autocomplete="email"
            >
          </div>

          <div class="mb-3">
            <label class="form-label">Mot de passe</label>
            <div class="input-group">
              <input
                type="password"
                id="login_password"
                name="password"
                class="form-control"
                placeholder="••••••••"
                autocomplete="current-password"
              >
              <button type="button" class="btn btn-outline-secondary" data-password-toggle="login_password" aria-label="Afficher le mot de passe">
                <i class="bi bi-eye"></i>
              </button>
            </div>
            <div class="text-end mt-2">
              <a href="{{ path('forgot_password') }}" class="small-link text-decoration-none">
                Mot de passe oublié ?
              </a>
            </div>

          </div>

          <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
          <input type="hidden" name="faceEmbedding" value="" data-face-embedding>

          {% if recaptcha_site_key %}
            <div class="d-flex justify-content-center mt-3">
              <div class="g-recaptcha" data-sitekey="{{ recaptcha_site_key }}"></div>
            </div>
          {% endif %}

          <div class="d-grid mt-4">
            <button class="btn btn-primary btn-glow" type="submit">
              <i class="bi bi-box-arrow-in-right me-2"></i>Se connecter
            </button>
          </div>

          {# ✅ Face login (same form, posts to /login/face via JS) #}
          <div class="text-center my-3 text-muted">— ou —</div>
          <div class="d-grid">
            <button type="button" class="btn btn-outline-primary" data-face-login-open>
              <i class="bi bi-camera me-2"></i> Se connecter par visage
            </button>
          </div>

          <div class="mt-3" data-face-login-box hidden>
            <div class="auth-surface rounded-3 p-3">
              <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap mb-2">
                <div class="fw-semibold">
                  <i class="bi bi-camera me-1"></i> Connexion par visage
                </div>
                <button type="button" class="btn btn-sm btn-outline-secondary" data-face-login-cancel>
                  Fermer
                </button>
              </div>

              <div class="border rounded-3 p-2 bg-white">
                <div class="rounded-3 overflow-hidden" style="height: 260px;">
                  <video data-face-video class="w-100" playsinline autoplay muted style="width:100%;height:100%;object-fit:cover;"></video>
                </div>
              </div>

              <div class="d-flex gap-2 mt-3">
                <button type="button" class="btn btn-primary btn-glow" data-face-login-capture>
                  <i class="bi bi-shield-check me-1"></i> Vérifier mon visage
                </button>
                <button type="button" class="btn btn-outline-secondary" data-face-login-retry hidden>
                  Réessayer
                </button>
              </div>

              <div class="small text-muted mt-2" data-face-login-status aria-live="polite"></div>
              <div class="alert alert-success mt-3 d-none" data-face-login-success role="alert" aria-live="polite"></div>
              <div class="alert alert-danger mt-3 d-none" data-face-login-error role="alert" aria-live="polite"></div>
            </div>
          </div>

          {# ✅ Google button (no second form!) #}
          <div class="d-grid mt-3">
            <a href="{{ path('google_login') }}" class="btn btn-outline-secondary btn-google">
              <i class="bi bi-google me-2"></i> Se connecter avec Google
            </a>
          </div>
        </form>

        <div class="text-center mt-4">
          <span class="text-muted">Vous n’avez pas de compte ?</span>
          <a href="{{ path('app_register') }}" class="fw-bold text-decoration-none link-primary">
            Inscrivez-vous
          </a>
        </div>

        </div>
      </div>
    </div>
  </div>
</div>

{% endblock %}

{% block page_scripts %}
<script>
  (function () {
    const form = document.querySelector('form');
    if (!form) return;

    const openBtn = form.querySelector('[data-face-login-open]');
    const box = form.querySelector('[data-face-login-box]');
    const video = form.querySelector('[data-face-video]');
    const captureBtn = form.querySelector('[data-face-login-capture]');
    const cancelBtn = form.querySelector('[data-face-login-cancel]');
    const retryBtn = form.querySelector('[data-face-login-retry]');
    const errBox = form.querySelector('[data-face-login-error]');
            const okBox = form.querySelector('[data-face-login-success]');
    const statusBox = form.querySelector('[data-face-login-status]');
    const faceInput = form.querySelector('[data-face-embedding]');
    const emailInput = form.querySelector('input[name="emailUser"]');

    if (!openBtn || !box || !video || !captureBtn || !cancelBtn || !retryBtn || !faceInput || !emailInput) return;

    let stream = null;
    const initialAction = form.getAttribute('action') || '';

    const showErr = (msg) => {
      if (!errBox) return;
      errBox.textContent = msg || 'Erreur.';
      errBox.classList.remove('d-none');
    };

    const hideErr = () => {
      if (!errBox) return;
      errBox.textContent = '';
      errBox.classList.add('d-none');
    };

    const showOk = (msg) => {
      if (!okBox) return;
      okBox.textContent = msg || 'Succès.';
      okBox.classList.remove('d-none');
    };

    const hideOk = () => {
      if (!okBox) return;
      okBox.textContent = '';
      okBox.classList.add('d-none');
    };

    const setStatus = (msg) => {
      if (!statusBox) return;
      statusBox.textContent = msg || '';
    };

    const showRetry = (show) => {
      retryBtn.hidden = !show;
    };

    const detachStream = () => {
      try { video.pause(); } catch (e) {}
      try { video.srcObject = null; } catch (e) {}
    };

    const hardStopStream = () => {
      try {
        if (stream) {
          stream.getTracks().forEach(t => t.stop());
        }
      } catch (e) {}
      stream = null;
      detachStream();
    };

    const startCamera = async () => {
      if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
        throw new Error('Caméra indisponible sur ce navigateur.');
      }

      // Reuse the same stream while the page is open to avoid repeated permission prompts.
      const isUsable = (s) => {
        try {
          return !!s && s.getTracks().some(t => t.readyState === 'live');
        } catch (e) {
          return false;
        }
      };

      if (!isUsable(stream)) {
        try {
          stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' }, audio: false });
        } catch (e) {
          const name = (e && e.name) ? String(e.name) : '';
          if (name === 'NotAllowedError' || name === 'PermissionDeniedError') {
            throw new Error('Accès caméra refusé. Autorisez la caméra puis réessayez.');
          }
          if (name === 'NotFoundError' || name === 'DevicesNotFoundError') {
            throw new Error('Aucune caméra détectée.');
          }
          throw e;
        }
      }
      video.srcObject = stream;
      await video.play().catch(() => {});
    };

    // ===== MediaPipe (FaceDetector + ImageEmbedder) =====
    const mediapipeWasmRoot = 'https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.0/wasm';
    const mediapipeModuleUrl = 'https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.0';

    const faceDetectorModelUrl = 'https://storage.googleapis.com/mediapipe-models/face_detector/blaze_face_short_range/float16/1/blaze_face_short_range.tflite';
    const imageEmbedderModelUrl = 'https://storage.googleapis.com/mediapipe-models/image_embedder/mobilenet_v3_small/float32/1/mobilenet_v3_small.tflite';

    let mpPromise = null;
    const getMp = async () => {
      if (mpPromise) return mpPromise;
      mpPromise = (async () => {
        const vision = await import(mediapipeModuleUrl);
        const fileset = await vision.FilesetResolver.forVisionTasks(mediapipeWasmRoot);

        const createWithDelegate = async (delegate) => {
          const faceDetector = await vision.FaceDetector.createFromOptions(fileset, {
            baseOptions: { modelAssetPath: faceDetectorModelUrl, ...(delegate ? { delegate } : {}) },
            runningMode: 'VIDEO',
          });

          const embedder = await vision.ImageEmbedder.createFromOptions(fileset, {
            baseOptions: { modelAssetPath: imageEmbedderModelUrl, ...(delegate ? { delegate } : {}) },
            runningMode: 'IMAGE',
          });

          return { faceDetector, embedder };
        };

        try {
          return await createWithDelegate('GPU');
        } catch (e) {
          return await createWithDelegate(null);
        }

      })();
      return mpPromise;
    };

    const l2Normalize = (vec) => {
      let norm = 0;
      for (let i = 0; i < vec.length; i++) norm += vec[i] * vec[i];
      norm = Math.sqrt(norm);
      if (!Number.isFinite(norm) || norm <= 0) throw new Error('Capture impossible.');
      for (let i = 0; i < vec.length; i++) vec[i] = vec[i] / norm;
      return vec;
    };

    const averageAndNormalize = (vectors) => {
      if (!Array.isArray(vectors) || vectors.length === 0) {
        throw new Error('Capture impossible.');
      }
      const dim = vectors[0].length;
      if (!dim || dim < 64) {
        throw new Error('Capture impossible.');
      }

      const sum = new Array(dim).fill(0);
      for (const v of vectors) {
        if (!Array.isArray(v) || v.length !== dim) {
          throw new Error('Capture impossible.');
        }
        for (let i = 0; i < dim; i++) sum[i] += Number(v[i]) || 0;
      }

      const avg = sum.map(x => x / vectors.length);
      return l2Normalize(avg);
    };

    const getSingleFaceBbox = (detections) => {
      if (!Array.isArray(detections) || detections.length !== 1) {
        throw new Error('Veuillez cadrer un seul visage.');
      }
      const d = detections[0];
      const score = d && d.categories && d.categories[0] && typeof d.categories[0].score === 'number'
        ? Number(d.categories[0].score)
        : null;
      if (score !== null && score < 0.6) {
        throw new Error('Veuillez cadrer un seul visage (détection faible).');
      }
      const bb = d && d.boundingBox ? d.boundingBox : null;
      if (!bb) throw new Error('Veuillez cadrer un seul visage.');
      const x = Number(bb.originX);
      const y = Number(bb.originY);
      const w = Number(bb.width);
      const h = Number(bb.height);
      if (![x, y, w, h].every(Number.isFinite) || w <= 0 || h <= 0) {
        throw new Error('Veuillez cadrer un seul visage.');
      }
      const vw = video.videoWidth || 0;
      const vh = video.videoHeight || 0;
      if (vw && vh) {
        const minSide = Math.min(vw, vh);
        if (Math.min(w, h) < minSide * 0.18) {
          throw new Error('Rapprochez-vous de la caméra (visage trop petit).');
        }
      }
      return { x, y, w, h };
    };

    const cropFaceToCanvas = (bbox) => {
      const vw = video.videoWidth || 0;
      const vh = video.videoHeight || 0;
      if (!vw || !vh) throw new Error('Caméra non prête.');

      const pad = 0.35 * Math.max(bbox.w, bbox.h);
      let sx = bbox.x - pad;
      let sy = bbox.y - pad;
      let sw = bbox.w + pad * 2;
      let sh = bbox.h + pad * 2;

      sx = Math.max(0, Math.min(vw - 1, sx));
      sy = Math.max(0, Math.min(vh - 1, sy));
      sw = Math.max(1, Math.min(vw - sx, sw));
      sh = Math.max(1, Math.min(vh - sy, sh));

      const canvas = document.createElement('canvas');
      canvas.width = 224;
      canvas.height = 224;
      const ctx = canvas.getContext('2d', { willReadFrequently: true });
      if (!ctx) throw new Error('Capture impossible.');

      ctx.drawImage(video, sx, sy, sw, sh, 0, 0, canvas.width, canvas.height);
      return canvas;
    };

    const extractEmbeddingFromResult = (res) => {
      const embs = res && res.embeddings ? res.embeddings : null;
      if (!Array.isArray(embs) || embs.length < 1) throw new Error('Capture impossible.');
      const e0 = embs[0];
      const floats = e0 && e0.floatEmbedding ? e0.floatEmbedding : null;
      if (!floats || typeof floats.length !== 'number') throw new Error('Capture impossible.');
      const vec = Array.from(floats, v => Number(v));
      if (vec.length < 64) throw new Error('Capture impossible.');
      return l2Normalize(vec);
    };

    const captureEmbeddingOnce = async () => {
      const w = video.videoWidth || 0;
      const h = video.videoHeight || 0;
      if (!w || !h) {
        throw new Error('Caméra non prête.');
      }

      const mp = await getMp();
      const det = mp.faceDetector.detectForVideo(video, performance.now());
      const bbox = getSingleFaceBbox(det && det.detections ? det.detections : []);
      const faceCanvas = cropFaceToCanvas(bbox);
      const embRes = mp.embedder.embed(faceCanvas);
      return extractEmbeddingFromResult(embRes);
    };

    const sleep = (ms) => new Promise((r) => setTimeout(r, ms));

    const captureEmbedding = async (onProgress) => {
      const samples = [];
      const count = 10;
      for (let i = 0; i < count; i++) {
        if (typeof onProgress === 'function') onProgress(i + 1, count);
        samples.push(await captureEmbeddingOnce());
        if (i < count - 1) await sleep(90);
      }
      if (typeof onProgress === 'function') onProgress(count, count);
      return averageAndNormalize(samples);
    };

    const faceLoginAjax = async (payload) => {
      const fd = new FormData();
      fd.set('_csrf_token', String(form.querySelector('input[name="_csrf_token"]')?.value || ''));
      fd.set('emailUser', (emailInput.value || '').trim());
      fd.set('faceEmbedding', JSON.stringify(payload));

      // Forward reCAPTCHA token as well.
      const captchaVal = String(form.querySelector('textarea[name="g-recaptcha-response"]')?.value || '');
      if (captchaVal) fd.set('g-recaptcha-response', captchaVal);

      const res = await fetch('{{ path('app_login_face') }}', {
        method: 'POST',
        body: fd,
        credentials: 'same-origin',
        headers: {
          'Accept': 'application/json',
          'X-Requested-With': 'XMLHttpRequest'
        },
      });

      const ct = (res.headers.get('content-type') || '').toLowerCase();
      if (!ct.includes('application/json')) {
        throw new Error('Réponse inattendue. Réessayez.');
      }
      const data = await res.json().catch(() => ({}));
      return { ok: !!data.ok, error: data.error || null, redirectTo: data.redirectTo || null };
    };

    openBtn.addEventListener('click', async () => {
      hideErr();
      hideOk();
      faceInput.value = '';
      setStatus('');
      showRetry(false);

      const email = (emailInput.value || '').trim();
      if (!email) {
        showErr('Veuillez saisir votre email avant.');
        emailInput.focus();
        return;
      }

      box.hidden = false;
      openBtn.disabled = true;
      try {
        setStatus('Activation de la caméra…');
        await startCamera();

        setStatus('Chargement du modèle…');
        await getMp();
        setStatus('Prêt.');
      } catch (e) {
        hardStopStream();
        box.hidden = true;
        setStatus('');
        showErr(e.message || 'Impossible d’activer la caméra.');
      } finally {
        openBtn.disabled = false;
      }
    });

    cancelBtn.addEventListener('click', () => {
      hideErr();
      hideOk();
      detachStream();
      box.hidden = true;
      faceInput.value = '';
      setStatus('');
      showRetry(false);
      if (initialAction) form.setAttribute('action', initialAction); else form.removeAttribute('action');
    });

    retryBtn.addEventListener('click', () => {
      hideErr();
      hideOk();
      faceInput.value = '';
      setStatus('Prêt.');
      showRetry(false);
    });

    captureBtn.addEventListener('click', () => {
      hideErr();
      hideOk();
      showRetry(false);
      (async () => {
        try {
          captureBtn.disabled = true;
          cancelBtn.disabled = true;
          setStatus('Détection du visage…');
          const vec = await captureEmbedding((i, total) => setStatus(`Capture ${i}/${total}…`));
          const payload = { v: 2, type: 'mp_image_embedder_face_crop_v1', vec };
          faceInput.value = JSON.stringify(payload);
          setStatus('Vérification…');

          const res = await faceLoginAjax(payload);
          if (res.ok && res.redirectTo) {
            showOk('Visage vérifié. Connexion…');
            setStatus('');
            // Give a short moment for the user to see success.
            setTimeout(() => {
              hardStopStream();
              window.location.assign(res.redirectTo);
            }, 350);
            return;
          }

          showErr(res.error || 'Échec de la connexion. Réessayez.');
          setStatus('');
          showRetry(true);
        } catch (e) {
          showErr((e && e.message) ? e.message : 'Capture impossible.');
          setStatus('');
          showRetry(true);
        } finally {
          captureBtn.disabled = false;
          cancelBtn.disabled = false;
        }
      })();
    });

    window.addEventListener('beforeunload', hardStopStream);
  })();
</script>
{% endblock %}