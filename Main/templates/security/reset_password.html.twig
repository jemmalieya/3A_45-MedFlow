{% extends 'base.html.twig' %}

{% block title %}Réinitialiser le mot de passe{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    body{
      background:
        radial-gradient(1200px circle at 10% 10%, rgba(13,110,253,.25), transparent 45%),
        radial-gradient(900px circle at 90% 20%, rgba(32,201,151,.18), transparent 40%),
        #0b1220;
      min-height: 100vh;
    }
    .glass-card{
      background: rgba(15, 23, 42, 0.85);
      border: 1px solid rgba(255,255,255,.12);
      box-shadow: 0 30px 90px rgba(0,0,0,.45);
      backdrop-filter: blur(10px);
      border-radius: 18px;
    }
    .form-label{ 
      color: #fff !important; 
      font-weight: 500;
    }
    .form-control{
      background: rgba(255,255,255,.08) !important;
      border: 1px solid rgba(255,255,255,.18) !important;
      color: #fff !important;
      border-radius: 12px;
      padding: .85rem .95rem;
    }
    .form-control::placeholder{ color: rgba(255,255,255,.45); }
    .form-control:focus{
      box-shadow: 0 0 0 .2rem rgba(13,110,253,.25);
      border-color: rgba(13,110,253,.60) !important;
      background: rgba(255,255,255,.12) !important;
      color: #fff !important;
    }
    .invalid-feedback {
      color: #ff6b6b !important;
      display: block;
      font-weight: 500;
      margin-top: 0.5rem;
    }
    .form-control.is-invalid {
      border-color: #ff6b6b !important;
    }
  </style>
{% endblock %}

{% block body %}
<div class="container-fluid d-flex align-items-center justify-content-center" style="min-height: 100vh;">
  <div class="glass-card p-5" style="width: 100%; max-width: 420px;">
    
    <h2 class="text-white mb-4 text-center">Réinitialiser votre mot de passe</h2>
    <p class="text-center mb-4" style="color: rgba(255,255,255,.85);">Entrez votre nouveau mot de passe</p>

    {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}
      <div class="mb-3">
        {{ form_label(form.plainPassword.first) }}
        <div class="input-group">
          {{ form_widget(form.plainPassword.first, { attr: { autocomplete: 'new-password' } }) }}
          <button type="button" class="btn btn-outline-light" data-password-toggle="{{ form.plainPassword.first.vars.id }}" aria-label="Afficher le mot de passe">
            <i class="bi bi-eye"></i>
          </button>
        </div>
        {{ form_errors(form.plainPassword.first) }}
      </div>

      <div class="d-flex justify-content-end mb-3">
        <button type="button" class="btn btn-outline-light" data-password-suggest data-password-api="{{ path('api_password_suggest') }}">
          Suggérer un mot de passe
        </button>
      </div>

      <div class="mb-3">
        {{ form_label(form.plainPassword.second) }}
        <div class="input-group">
          {{ form_widget(form.plainPassword.second, { attr: { autocomplete: 'new-password' } }) }}
          <button type="button" class="btn btn-outline-light" data-password-toggle="{{ form.plainPassword.second.vars.id }}" aria-label="Afficher le mot de passe">
            <i class="bi bi-eye"></i>
          </button>
        </div>
        {{ form_errors(form.plainPassword.second) }}
      </div>

      <div>
        {{ form_errors(form.plainPassword) }}
      </div>

      {{ form_widget(form.submit) }}
    {{ form_end(form) }}

    <div class="text-center mt-4">
      <p style="color: rgba(255,255,255,.80);">
        <a href="{{ path('app_login') }}" class="text-decoration-none" style="color: #0d6efd;">Retour à la connexion</a>
      </p>
    </div>

  </div>
</div>

<script>
  (function () {
    function fillPasswords(form, value) {
      if (!form) return;
      var inputs = form.querySelectorAll('input[autocomplete="new-password"]');
      if (!inputs || !inputs.length) inputs = form.querySelectorAll('input[type="password"]');
      inputs.forEach(function (el) {
        el.value = value;
        try { el.dispatchEvent(new Event('input', { bubbles: true })); } catch (e) {}
        try { el.dispatchEvent(new Event('change', { bubbles: true })); } catch (e) {}
      });
    }

    document.addEventListener('click', function (e) {
      var btn = e.target && e.target.closest ? e.target.closest('[data-password-suggest]') : null;
      if (!btn) return;
      e.preventDefault();

      var apiUrl = btn.getAttribute('data-password-api') || '/api/password/suggest';
      var form = btn.closest('form');
      var prev = btn.textContent;

      btn.disabled = true;
      btn.textContent = 'Génération…';

      fetch(apiUrl, { method: 'GET', credentials: 'same-origin', headers: { 'Accept': 'application/json' } })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          var pwd = data && data.password ? String(data.password) : '';
          if (!pwd) throw new Error('Mot de passe manquant');
          fillPasswords(form, pwd);
        })
        .catch(function () {})
        .finally(function () {
          btn.disabled = false;
          btn.textContent = prev;
        });
    });
  })();
</script>
{% endblock %}

