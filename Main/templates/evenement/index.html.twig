{% extends 'base.html.twig' %}

{% block title %}Événements - MedFlow{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('assets/css/evenements-index.css') }}">
{% endblock %}

{% block body %}
<main class="main ev-page">

  <section class="section ev-section">
    <div class="container">

     {# ================= HERO (Style Réclamation - FIRST BLUE) ================= #}
<div class="ev-hero-blue">
  <h1 class="ev-hero-title-blue">Événements</h1>
  <p class="ev-hero-subtitle-blue">
    Découvrez nos événements santé, ateliers et conférences.
  </p>

  <div class="ev-hero-btn">
    <a href="{{ path('app_evenements_calendar') }}" class="btn ev-btn-outline-blue">
      <i class="bi bi-calendar3 me-2"></i> Agenda
    </a>
  </div>
</div>

      {# =========================
         BAR INFO / ACTIONS (style “card” comme les autres pages)
         ========================= #}
      {# =========================
   TOPBAR PRO (better)
   ========================= #}
<div class="ev-tipbar">
  <div class="ev-tip-left">
    <div class="ev-tip-icon">
      <i class="bi bi-info-lg"></i>
    </div>

    <div class="ev-tip-text">
      <div class="ev-tip-title">Conseil</div>
      <div class="ev-tip-sub">
        Consultez la liste des événements disponibles et ouvrez un événement pour voir les détails.
      </div>
    </div>
  </div>

  <div class="ev-tip-actions">
    <a href="#events-list" class="ev-tip-btn">
      <i class="bi bi-arrow-down-circle me-2"></i> Voir la liste
    </a>
  </div>
</div>

      {# =========================
         NOTIF BANDEAU
         ========================= #}
      {% if hasNew %}
        <div class="ev-alert">
          <div class="ev-alert-left">
            <strong>🎉 Nouvel événement ajouté !</strong>
            {% if latestNewTitle %}
              <span class="ms-2">Dernier : <b>{{ latestNewTitle }}</b></span>
            {% endif %}
          </div>
          <a href="#events-list" class="btn ev-btn-outline btn-sm">Voir ↓</a>
        </div>
      {% endif %}

      {# FLASH #}
      {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
          {{ message }}
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      {% endfor %}

      

      <div id="events-list"></div>

      {# =========================
         EMPTY STATE
         ========================= #}
      {% if evenements is empty %}
        <div class="ev-empty">
          <div class="ev-empty-icon">
            <i class="bi bi-calendar-x"></i>
          </div>
          <h3 class="ev-empty-title">Aucun événement pour le moment</h3>
          <p class="ev-empty-text">Revenez bientôt, de nouveaux événements seront ajoutés.</p>
          <a href="{{ path('app_evenements_calendar') }}" class="btn ev-btn-outline">
            <i class="bi bi-calendar3 me-2"></i> Voir l’agenda
          </a>
        </div>
      {% else %}

        {# =========================
           GRID CARDS (style blanc + shadow comme Pharmacie)
           ========================= #}
        <div class="row g-4 mt-2">
          {% for e in evenements %}
            <div class="col-lg-4 col-md-6">

              <article class="ev-card h-100">

                {# Cover #}
                <div class="ev-card-cover">
                  {% set cover = e.imageCouvertureEvent %}
                  {% if cover and cover starts with 'http' %}
                    <img src="{{ cover }}" alt="cover">
                  {% else %}
                    <img src="{{ asset('assets/img/health/showcase-1.webp') }}" alt="cover">
                  {% endif %}

                  {# Statut #}
                  {% set statut = e.statutEvent|lower %}
                  <span class="ev-badge
                    {% if 'pub' in statut %}ev-badge-success
                    {% elseif 'annul' in statut %}ev-badge-danger
                    {% else %}ev-badge-neutral{% endif %}">
                    {{ e.statutEvent }}
                  </span>

                  {# NEW #}
                  {% if e.dateCreationEvent is not null and e.dateCreationEvent > date('-2 days') %}
                    <span class="ev-new">NEW</span>
                  {% endif %}

                  {# Date pill #}
                  <span class="ev-date-pill">
                    {{ e.dateDebutEvent|date('d M') }} → {{ e.dateFinEvent|date('d M') }}
                  </span>
                </div>

                {# Body #}
                <div class="ev-card-body">
                  <h3 class="ev-card-title">{{ e.titreEvent }}</h3>

                  <div class="ev-meta">
                    <div class="ev-meta-item">
                      <i class="bi bi-geo-alt"></i>
                      <span>{{ e.nomLieuEvent }}, {{ e.villeEvent }}</span>
                    </div>
                    <div class="ev-meta-item">
                      <i class="bi bi-calendar-event"></i>
                      <span>{{ e.dateDebutEvent|date('d/m/Y') }}</span>
                    </div>
                  </div>

                  <p class="ev-card-desc">
                    {{ e.descriptionEvent|slice(0, 120) }}{% if e.descriptionEvent|length > 120 %}...{% endif %}
                  </p>
                </div>

                {# Footer #}
                <div class="ev-card-footer">
                  <a class="btn ev-btn-primary" href="{{ path('app_evenement_show', {id: e.id}) }}">
                    Détails <i class="bi bi-arrow-right ms-1"></i>
                  </a>

                  <span class="ev-chip">
                    <i class="bi bi-tag me-1"></i>{{ e.typeEvent }}
                  </span>
                </div>

              </article>

            </div>
          {% endfor %}
        </div>

      {% endif %}

    </div>
  </section>

</main>
{% endblock %}