{% extends 'base.html.twig' %}
{% block title %}Accessibilité Live{% endblock %}

{% block body %}
<div class="container py-4" style="padding-top:120px;">

  <h3 class="fw-bold mb-3">🎥 Mode Accessibilité — Traduction LS en direct</h3>

  <div class="position-relative mx-auto" style="max-width: 820px;">
    <video id="video" autoplay playsinline class="w-100 rounded-4 shadow-sm" style="background:#000;"></video>

    {# Sous-titres en bas de la vidéo #}
    <div id="subtitleOverlay"
         class="position-absolute start-0 end-0 bottom-0 p-3"
         style="background: linear-gradient(180deg, rgba(0,0,0,0), rgba(0,0,0,.75));
                color:#fff; font-size: 1.2rem; font-weight:600;
                border-bottom-left-radius: 16px; border-bottom-right-radius:16px;">
      <span id="subtitleText">…</span>
    </div>
  </div>

  <div class="d-flex gap-2 mt-3" style="max-width:820px; margin:auto;">
    <button id="btnClear" class="btn btn-outline-secondary">Effacer</button>
    <button id="btnSave" class="btn btn-primary">Enregistrer la transcription</button>
  </div>

  <textarea id="transcript" class="form-control mt-3"
            style="max-width:820px; margin:auto; min-height:120px;"
            placeholder="Transcription capturée..."></textarea>
</div>

<script>
  window.EVENT_ID = {{ evenement.id }};
  window.SAVE_URL = "{{ path('app_evenement_access_save', {id: evenement.id}) }}";
</script>

<script src="https://cdn.jsdelivr.net/npm/@mediapipe/hands/hands.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@mediapipe/camera_utils/camera_utils.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@tensorflow/tfjs@4.9.0/dist/tf.min.js"></script>

{# 👇 THIS WAS MISSING 👇 #}
<script src="{{ asset('assets/js/access-live.js') }}"></script>

{% endblock %}
