{% extends 'base_dashboard.html.twig' %}

{% block title %}Statistiques Blog{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
  /* ===== KPI color cards (même design que Réclamations) ===== */
  .kpi-card{
    color:#fff;
    border-radius: 14px;
    overflow: hidden;
    position: relative;
  }
  .kpi-card .text-xs{ opacity:.85; letter-spacing:.4px; }
  .kpi-card .kpi-value{ font-weight: 900; font-size: 2rem; line-height: 1; }
  .kpi-card::after{
    content:"";
    position:absolute;
    right:-40px; top:-40px;
    width:160px; height:160px;
    background: rgba(255,255,255,.12);
    border-radius: 999px;
  }

  /* Couleurs (alignées au style KPI réclamations) */
  .kpi-total { background: linear-gradient(135deg, #4f46e5, #6366f1); }
  .kpi-react { background: linear-gradient(135deg, #16a34a, #22c55e); }
  .kpi-comm  { background: linear-gradient(135deg, #f59e0b, #fbbf24); }
  .kpi-rate  { background: linear-gradient(135deg, #06b6d4, #22d3ee); }

  .period-chip{
    background: rgba(79,70,229,.08);
    border: 1px solid rgba(79,70,229,.18);
    color:#4f46e5;
    font-weight: 700;
    border-radius: 999px;
    padding: .35rem .65rem;
  }

  .chart-card{ border-radius: 14px; }
  .chart-card h6{ font-weight: 800; color:#111827; }

  /* ✅ FIX: stable chart height (comme Réclamations) */
  .chart-wrap{
    position: relative;
    height: 320px;
    width: 100%;
  }
  .chart-wrap.sm{ height: 300px; }

  canvas{
    width: 100% !important;
    height: 100% !important;
  }

  /* Table card nice */
  .table thead th{ font-weight: 800; color:#111827; }
</style>
{% endblock %}

{% block body %}
<div class="container-fluid py-4">

  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h1 class="h3 mb-1 text-gray-800">
        <i class="bi bi-graph-up-arrow me-2"></i> Statistiques Blog
      </h1>
      <div class="small text-muted">
        <span class="period-chip">
          Période : {{ from|date('d/m/Y') }} → {{ to|date('d/m/Y') }}
        </span>
        <span class="ms-2">({{ days }} jours)</span>
      </div>
    </div>

    <div class="d-flex gap-2 flex-wrap">
      <a class="btn btn-sm btn-outline-primary {{ days == 7 ? 'active' : '' }}" href="{{ path('admin_blog_stats', {days: 7}) }}">7j</a>
      <a class="btn btn-sm btn-outline-primary {{ days == 14 ? 'active' : '' }}" href="{{ path('admin_blog_stats', {days: 14}) }}">14j</a>
      <a class="btn btn-sm btn-outline-primary {{ days == 30 ? 'active' : '' }}" href="{{ path('admin_blog_stats', {days: 30}) }}">30j</a>
    </div>
  </div>

  {# ===== KPI (même style que Réclamations) ===== #}
  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card shadow-sm border-0 kpi-card kpi-total">
        <div class="card-body">
          <div class="text-xs text-uppercase">TOTAL POSTS</div>
          <div class="kpi-value mt-2">{{ kpis.total ?? 0 }}</div>
          <div class="small mt-2 opacity-75">Posts sur la période</div>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card shadow-sm border-0 kpi-card kpi-react">
        <div class="card-body">
          <div class="text-xs text-uppercase">RÉACTIONS</div>
          <div class="kpi-value mt-2">{{ kpis.reactions ?? 0 }}</div>
          <div class="small mt-2 opacity-75">Moyenne : {{ kpis.avg_reactions ?? 0 }} / post</div>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card shadow-sm border-0 kpi-card kpi-comm">
        <div class="card-body">
          <div class="text-xs text-uppercase">COMMENTAIRES</div>
          <div class="kpi-value mt-2">{{ kpis.comments ?? 0 }}</div>
          <div class="small mt-2 opacity-75">Engagement total</div>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card shadow-sm border-0 kpi-card kpi-rate">
        <div class="card-body">
          <div class="text-xs text-uppercase">TAUX PUBLIC</div>
          <div class="kpi-value mt-2">{{ kpis.public_rate ?? 0 }}%</div>
          <div class="small mt-2 opacity-75">Visibilité des posts</div>
        </div>
      </div>
    </div>
  </div>

  {# ===== Charts (même style cartes + chart-wrap stable) ===== #}
  <div class="row g-4">
    <div class="col-lg-8">
      <div class="card shadow-sm border-0 chart-card">
        <div class="card-body">
          <h6 class="mb-3">Évolution quotidienne</h6>
          <div class="chart-wrap">
            <canvas id="blogLine"></canvas>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card shadow-sm border-0 chart-card">
        <div class="card-body">
          <h6 class="mb-3">Catégories</h6>
          <div class="chart-wrap sm">
            <canvas id="catBar"></canvas>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card shadow-sm border-0 chart-card">
        <div class="card-body">
          <h6 class="mb-3">Humeurs</h6>
          <div class="chart-wrap sm">
            <canvas id="moodDonut"></canvas>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-8">
      <div class="card shadow-sm border-0 chart-card">
        <div class="card-body">
          <h6 class="mb-3">Top posts (réactions)</h6>
          <div class="table-responsive">
            <table class="table align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>Titre</th>
                  <th>Catégorie</th>
                  <th class="text-end">Réactions</th>
                  <th class="text-end">Commentaires</th>
                </tr>
              </thead>
              <tbody>
                {% for p in topPosts %}
                  <tr>
                    <td class="fw-semibold">{{ p.titre }}</td>
                    <td><span class="badge bg-primary">{{ p.categorie ?: '—' }}</span></td>
                    <td class="text-end">{{ p.nbrReactions ?? 0 }}</td>
                    <td class="text-end">{{ p.nbrCommentaires ?? 0 }}</td>
                  </tr>
                {% else %}
                  <tr><td colspan="4" class="text-muted">Aucun post sur la période.</td></tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

  </div>

</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  const byDay = {{ byDay|json_encode|raw }};
  const labels = (Array.isArray(byDay) ? byDay : []).map(r => r.day);
  const posts = (Array.isArray(byDay) ? byDay : []).map(r => Number(r.total || 0));
  const reacts = (Array.isArray(byDay) ? byDay : []).map(r => Number(r.reactions || 0));
  const comments = (Array.isArray(byDay) ? byDay : []).map(r => Number(r.comments || 0));

  const byCat = {{ byCategorie|json_encode|raw }};
  const byMood = {{ byHumeur|json_encode|raw }};

  // SB Admin peut être Chart.js v2
  const isV2 = !!(window.Chart && Chart.defaults && Chart.defaults.global);

  // ===== Global defaults (même logique que Réclamations) =====
  if (isV2) {
    Chart.defaults.global.defaultFontFamily = "Nunito, system-ui, -apple-system, Segoe UI, Roboto, Arial";
    Chart.defaults.global.legend.labels.boxWidth = 12;
  } else {
    Chart.defaults.font.family = "Nunito, system-ui, -apple-system, Segoe UI, Roboto, Arial";
    Chart.defaults.plugins.legend.labels.boxWidth = 12;
  }

  // ===== Line: gradient (comme Réclamations, sans changer tes datasets) =====
  const ctxLine = document.getElementById('blogLine').getContext('2d');
  const grad = ctxLine.createLinearGradient(0, 0, 0, 240);
  grad.addColorStop(0, 'rgba(79,70,229,0.28)');
  grad.addColorStop(1, 'rgba(79,70,229,0.05)');

  new Chart(ctxLine, {
    type: 'line',
    data: {
      labels,
      datasets: [
        { label: 'Posts', data: posts, tension: 0.35, borderColor: '#4f46e5', pointBackgroundColor:'#4f46e5', fill: true, backgroundColor: grad },
        { label: 'Réactions', data: reacts, tension: 0.35, borderColor: '#22c55e', pointBackgroundColor:'#22c55e', fill: false },
        { label: 'Commentaires', data: comments, tension: 0.35, borderColor: '#f59e0b', pointBackgroundColor:'#f59e0b', fill: false },
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      tooltips: isV2 ? { mode: 'index', intersect: false } : undefined,
      plugins: isV2 ? undefined : {
        legend: { position: 'top' },
        tooltip: { mode: 'index', intersect: false }
      },
      legend: isV2 ? { display: true, position: 'top' } : undefined,
      scales: isV2 ? {
        yAxes: [{ ticks: { beginAtZero: true, precision: 0 } }],
        xAxes: [{ ticks: { autoSkip: true, maxTicksLimit: 12 } }]
      } : {
        y: { beginAtZero: true, ticks: { precision: 0 } },
        x: { ticks: { autoSkip: true, maxTicksLimit: 12 } }
      }
    }
  });

  // ===== Bar: catégories =====
  const catRows = Array.isArray(byCat) ? byCat : [];
  new Chart(document.getElementById('catBar'), {
    type: 'bar',
    data: {
      labels: catRows.map(r => r.label),
      datasets: [
        { label: 'Posts', data: catRows.map(r => Number(r.total || 0)), backgroundColor: '#4f46e5' }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      legend: isV2 ? { display: false } : undefined,
      plugins: isV2 ? undefined : { legend: { display:false } },
      scales: isV2 ? {
        yAxes: [{ ticks: { beginAtZero: true, precision: 0 } }]
      } : {
        y: { beginAtZero: true, ticks: { precision: 0 } }
      }
    }
  });

  // ===== Donut: humeurs (v2/v3 cutout) =====
  const moodRows = Array.isArray(byMood) ? byMood : [];

  const donutOpts = {
    responsive: true,
    maintainAspectRatio: false,
    legend: isV2 ? { position: 'bottom' } : undefined,
    plugins: isV2 ? undefined : { legend: { position:'bottom' } }
  };
  if (isV2) donutOpts.cutoutPercentage = 65;
  else donutOpts.cutout = '65%';

  new Chart(document.getElementById('moodDonut'), {
    type: 'doughnut',
    data: {
      labels: moodRows.map(r => r.label),
      datasets: [{
        data: moodRows.map(r => Number(r.total || 0)),
        backgroundColor: ['#4f46e5', '#06b6d4', '#a855f7', '#f97316', '#22c55e', '#ef4444', '#64748b'],
        borderWidth: 0,
        hoverOffset: 6
      }]
    },
    options: donutOpts
  });
</script>
{% endblock %}