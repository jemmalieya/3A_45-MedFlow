{# templates/produits/admin_index.html.twig #}
{% extends 'base_dashboard.html.twig' %}

{% block title %}Gestion des Produits{% endblock %}

{% block body %}

<style>
/* ======== (TON CSS INCHANGÉ) ======== */
:root{
  --blue-50:#eff6ff;
  --blue-100:#dbeafe;
  --blue-200:#bfdbfe;
  --blue-300:#93c5fd;
  --blue-400:#60a5fa;
  --blue-500:#3b82f6;
  --blue-600:#2563eb;
  --blue-700:#1d4ed8;
  --blue-800:#1e40af;
  --blue-900:#1e3a8a;

  --success:#10b981;
  --danger:#ef4444;
  --warning:#f59e0b;

  --bg:#f6f9ff;
  --card:#ffffff;
  --text:#0f172a;
  --muted:#64748b;

  --shadow-sm: 0 2px 10px rgba(15, 23, 42, .06);
  --shadow-md: 0 10px 30px rgba(15, 23, 42, .10);
  --radius: 18px;
}

.section-page{
  background: linear-gradient(135deg, #f9fafb 0%, var(--blue-50) 100%);
  min-height: 100vh;
  padding: 28px 0 60px;
}
.container-fluid{ max-width: 1400px; }

/* Header */
.hero{
  border-radius: var(--radius);
  background: linear-gradient(135deg, #0891b2 0%, #3b82f6 55%, #2563eb 100%);
  box-shadow: var(--shadow-md);
  overflow: hidden;
  position: relative;
}
.hero::after{
  content:"";
  position:absolute;
  inset:-60px -60px auto auto;
  width:220px;height:220px;
  background: radial-gradient(circle, rgba(255,255,255,.22) 0%, rgba(255,255,255,0) 70%);
  transform: rotate(20deg);
}
.hero-inner{
  padding: 26px 28px;
  display:flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}
.hero-left{ display:flex; align-items:center; gap:14px; color:#fff; }
.hero-icon{
  width:54px;height:54px;
  border-radius: 16px;
  background: rgba(255,255,255,.18);
  border: 1px solid rgba(255,255,255,.25);
  display:flex;align-items:center;justify-content:center;
  box-shadow: 0 10px 24px rgba(0,0,0,.12);
}
.hero-title{
  margin:0;
  font-weight: 800;
  letter-spacing: .2px;
  font-size: 32px;
  text-shadow: 0 3px 10px rgba(0,0,0,.15);
}
.hero-sub{
  margin:6px 0 0;
  color: rgba(255,255,255,.88);
  font-weight: 600;
  display:flex;
  align-items:center;
  gap:10px;
  flex-wrap: wrap;
}
.pill{
  display:inline-flex;
  align-items:center;
  gap:8px;
  padding: 6px 12px;
  border-radius: 999px;
  font-weight: 800;
  font-size: 12px;
  letter-spacing: .2px;
  background: rgba(255,255,255,.18);
  border: 1px solid rgba(255,255,255,.25);
}
.pill-dark{
  background: rgba(15, 23, 42, .18);
  border: 1px solid rgba(255,255,255,.20);
}
.hero-right{ display:flex; gap:10px; align-items:center; flex-wrap: wrap; }

.btn-hero{
  border: none !important;
  border-radius: 14px !important;
  padding: 12px 16px !important;
  font-weight: 800 !important;
  box-shadow: 0 10px 24px rgba(0,0,0,.12);
  transition: .2s ease;
}
.btn-hero:hover{ transform: translateY(-2px); }
.btn-add{
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%) !important;
  color: #111827 !important;
}
.btn-orders{ background:#fff !important; color: var(--blue-800) !important; }

/* Panel */
.panel{
  margin-top: 18px;
  background: linear-gradient(135deg, #0ea5b8 0%, #60a5fa 60%, #3b82f6 100%);
  border-radius: var(--radius);
  box-shadow: var(--shadow-md);
  overflow: hidden;
}
.panel-inner{
  padding: 16px 18px;
  display:flex;
  justify-content: space-between;
  align-items:center;
  gap: 12px;
  flex-wrap: wrap;
}
.panel-title{
  color:#fff;
  font-weight: 900;
  margin:0;
  display:flex;
  align-items:center;
  gap:10px;
}
.toolbar{ display:flex; align-items:center; gap: 10px; flex-wrap: wrap; }
.tool{
  border-radius: 14px !important;
  border: 1px solid rgba(255,255,255,.35) !important;
  background: rgba(255,255,255,.18) !important;
  color: #fff !important;
  padding: 10px 12px !important;
  font-weight: 700 !important;
  outline: none !important;
  box-shadow: 0 8px 18px rgba(0,0,0,.10);
}
.tool::placeholder{ color: rgba(255,255,255,.78); }
.tool option{ color:#111827; }

.btn-tool{
  border-radius: 14px !important;
  border: 1px solid rgba(255,255,255,.35) !important;
  background: rgba(255,255,255,.18) !important;
  color:#fff !important;
  font-weight: 900 !important;
  padding: 10px 14px !important;
  box-shadow: 0 8px 18px rgba(0,0,0,.10);
  transition:.2s ease;
}
.btn-tool:hover{ transform: translateY(-2px); }

/* Content */
.content-card{
  margin-top: 16px;
  background: var(--card);
  border-radius: var(--radius);
  box-shadow: var(--shadow-md);
  overflow:hidden;
}

/* Stats */
.stats-row{ padding: 16px 18px 0; }
.stat{
  background:#fff;
  border-radius: 16px;
  border: 1px solid #eaf0ff;
  box-shadow: var(--shadow-sm);
  padding: 14px;
  height: 100%;
  transition: .2s ease;
}
.stat:hover{ transform: translateY(-4px); box-shadow: var(--shadow-md); }
.stat .n{
  font-size: 28px;
  font-weight: 900;
  margin: 8px 0 2px;
  background: linear-gradient(135deg, var(--blue-600) 0%, var(--blue-800) 100%);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
}
.stat .l{ color: var(--muted); font-weight: 700; }

/* Inventory alert */
.inv-alert{
  margin: 14px 18px 0;
  border-radius: 18px;
  background: linear-gradient(135deg, #fff7ed 0%, #fffbeb 100%);
  border-left: 6px solid var(--warning);
  box-shadow: var(--shadow-sm);
  padding: 14px 16px;
  display:flex;
  justify-content: space-between;
  align-items:center;
  gap: 12px;
  flex-wrap: wrap;
}
.inv-left{ display:flex; align-items:center; gap: 12px; }
.inv-bell{
  width:52px;height:52px;
  border-radius: 999px;
  background:#fff;
  border: 2px solid #fde68a;
  display:flex;align-items:center;justify-content:center;
  box-shadow: var(--shadow-sm);
}
.inv-title{ margin:0; font-weight: 900; color:#111827; }
.inv-meta{ color: var(--muted); font-weight: 700; }
.btn-inv{
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%) !important;
  border:none !important;
  border-radius: 999px !important;
  font-weight: 900 !important;
  padding: 10px 14px !important;
}

/* Table */
.table-wrap{ padding: 12px 0 0; }
.table{ margin:0; }
.table thead th{
  background: #eef6ff !important;
  color: #0f2a5f !important;
  font-weight: 900 !important;
  text-transform: uppercase;
  font-size: .82rem;
  letter-spacing: .6px;
  border: none !important;
  padding: 14px 14px !important;
}
.table tbody td{
  padding: 16px 14px !important;
  border-top: 1px solid #eef2ff !important;
  vertical-align: middle;
}
.tr-row{ transition: .2s ease; }
.tr-row:hover{
  background: linear-gradient(135deg, var(--blue-50) 0%, #fff 70%);
  transform: translateX(4px);
}
.pimg{
  width:64px;height:64px;
  border-radius: 14px;
  border: 3px solid var(--blue-100);
  object-fit: cover;
  box-shadow: 0 6px 16px rgba(15, 23, 42, .10);
  transition:.2s ease;
}
.tr-row:hover .pimg{
  transform: scale(1.10) rotate(2deg);
  border-color: var(--blue-500);
  box-shadow: 0 14px 28px rgba(59,130,246,.20);
}

/* Badges blancs */
.pill-white{
  display:inline-flex;
  align-items:center;
  gap: 8px;
  padding: 8px 12px;
  border-radius: 999px;
  background: #fff;
  border: 2px solid #e5e7eb;
  font-weight: 900;
  line-height: 1;
  box-shadow: 0 8px 18px rgba(15, 23, 42, .06);
  white-space: nowrap;
}
.qty-ok{ border-color: rgba(37,99,235,.35); color: var(--blue-800); }
.qty-low{ border-color: rgba(239,68,68,.35); color: #991b1b; }
.qty-num{
  min-width: 28px;
  text-align:center;
  padding: 4px 10px;
  border-radius: 999px;
  font-weight: 900;
  background: rgba(37,99,235,.10);
  color: var(--blue-800);
}
.qty-low .qty-num{ background: rgba(239,68,68,.12); color:#991b1b; }

.st-dispo{ border-color: rgba(16,185,129,.35); color: #065f46; }
.st-rupture{ border-color: rgba(245,158,11,.45); color: #92400e; }
.st-indispo{ border-color: rgba(239,68,68,.35); color: #991b1b; }
.st-dot{
  width:10px;height:10px;border-radius:999px;
  background: currentColor;
  box-shadow: 0 0 0 4px rgba(0,0,0,0.03);
}

.btn-action{
  width:40px;height:40px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  border-radius: 12px;
  border:none;
  transition:.2s ease;
  box-shadow: 0 10px 20px rgba(15,23,42,.10);
  position: relative;
  overflow:hidden;
}
.btn-action:hover{ transform: translateY(-2px); }
.btn-edit{
  background: linear-gradient(135deg, var(--blue-500) 0%, var(--blue-700) 100%) !important;
  color:#fff !important;
}
.btn-del{
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%) !important;
  color:#fff !important;
}

/* Flash */
#flash-messages-container{
  position: fixed;
  top: 20px;
  right: 20px;
  z-index: 9999;
  max-width: 420px;
}
.flash-message{
  border:none;
  border-radius: 14px;
  box-shadow: var(--shadow-md);
  margin-bottom: 10px;
  animation: slideInRight .35s ease;
}
@keyframes slideInRight{ from{opacity:0;transform:translateX(80px)} to{opacity:1;transform:translateX(0)} }
@keyframes slideOutRight{ from{opacity:1;transform:translateX(0)} to{opacity:0;transform:translateX(80px)} }
.flash-message.slide-out{ animation: slideOutRight .35s ease forwards; }

.confirm-overlay{
  position: fixed;
  inset: 0;
  background: rgba(30,58,138,0.78);
  backdrop-filter: blur(8px);
  display:flex;
  align-items:center;
  justify-content:center;
  z-index: 10000;
}
.confirm-box{
  background:#fff;
  width: min(560px, 92vw);
  border-radius: 22px;
  padding: 26px;
  border: 3px solid var(--blue-200);
  box-shadow: 0 30px 70px rgba(0,0,0,.25);
  animation: pop .35s cubic-bezier(.2,1,.2,1);
}
@keyframes pop{ from{opacity:0;transform:scale(.9) translateY(12px)} to{opacity:1;transform:scale(1) translateY(0)} }
.d-none{ display:none !important; }

@media (max-width: 768px){
  .hero-title{ font-size: 24px; }
  .tool{ width: 100%; }
}
</style>

{# ====== PAGINATION META (de ton controller Doctrine native) ====== #}
{% set page = pagination.page %}
{% set pages = pagination.pages %}
{% set totalCount = pagination.total %}

{# ====== STATS (sur la page actuelle seulement - c'est OK visuellement) ====== #}
{% set dispoCount = 0 %}
{% set ruptureStatCount = 0 %}
{% set indispoCount = 0 %}

{% for p in produits %}
  {% if p.statusProduit == 'Disponible' %}
    {% set dispoCount = dispoCount + 1 %}
  {% elseif p.statusProduit == 'Rupture' %}
    {% set ruptureStatCount = ruptureStatCount + 1 %}
  {% else %}
    {% set indispoCount = indispoCount + 1 %}
  {% endif %}
{% endfor %}

{# ====== INVENTORY ALERT ====== #}
{% set ruptureCount = ruptureList is defined ? ruptureList|length : 0 %}
{% set lowCount = lowStockList is defined ? lowStockList|length : 0 %}
{% set seuil = seuilFaible is defined ? seuilFaible : 10 %}
{% set hasAlerts = (ruptureCount > 0) or (lowCount > 0) %}

<section class="section-page">
  <div class="container-fluid">

    <div class="hero">
      <div class="hero-inner">
        <div class="hero-left">
          <div class="hero-icon">
            <i class="bi bi-box-seam text-white" style="font-size: 24px;"></i>
          </div>
          <div>
            <h1 class="hero-title">Gestion des Produits</h1>
            <div class="hero-sub">
              <span>{{ totalCount }} produit(s) dans votre inventaire</span>
              <span class="pill pill-dark"><i class="bi bi-shield-check"></i> Admin</span>
            </div>
          </div>
        </div>

        <div class="hero-right">
          <a href="{{ path('admin_produit_new') }}" class="btn btn-hero btn-add">
            <i class="bi bi-plus-circle me-2"></i>Nouveau Produit
          </a>
          <a href="{{ path('admin_commandes_index') }}" class="btn btn-hero btn-orders">
            <i class="bi bi-receipt-cutoff me-2"></i>Voir les Commandes
          </a>
        </div>
      </div>
    </div>

    <div id="flash-messages-container">
      {% for message in app.flashes('success') %}
        <div class="alert alert-success flash-message" role="alert">
          <i class="bi bi-check-circle-fill me-2"></i>{{ message }}
        </div>
      {% endfor %}
      {% for message in app.flashes('error') %}
        <div class="alert alert-danger flash-message" role="alert">
          <i class="bi bi-x-circle-fill me-2"></i>{{ message }}
        </div>
      {% endfor %}
      {% for message in app.flashes('warning') %}
        <div class="alert alert-warning flash-message" role="alert">
          <i class="bi bi-exclamation-triangle-fill me-2"></i>{{ message }}
        </div>
      {% endfor %}
    </div>

    <div class="panel">
      <div class="panel-inner">
        <h3 class="panel-title"><i class="bi bi-list-ul"></i> Liste des Produits</h3>

        <div class="toolbar">
          <button type="button" class="btn btn-tool" id="btnInvDetailsTop" {% if not hasAlerts %}disabled{% endif %}>
            <i class="bi bi-bell"></i> Alerte Inventaire
            <span class="ms-1 pill" style="padding:4px 10px; font-size:12px;">
              {{ ruptureCount + lowCount }}
            </span>
          </button>

          <select id="sortSelect" class="form-select tool" style="min-width: 180px;">
            <option value="">Trier...</option>
            <option value="name_asc">Nom (A→Z)</option>
            <option value="name_desc">Nom (Z→A)</option>
            <option value="qty_asc">Quantité (↑)</option>
            <option value="qty_desc">Quantité (↓)</option>
            <option value="price_asc">Prix (↑)</option>
            <option value="price_desc">Prix (↓)</option>
          </select>

          <input id="searchInput" type="text" class="form-control tool" style="min-width: 260px;"
                 placeholder="Rechercher...">
        </div>
      </div>
    </div>

    <div class="content-card">

      <div class="stats-row">
        <div class="row g-3">
          <div class="col-md-3">
            <div class="stat">
              <i class="bi bi-box text-primary" style="font-size: 26px;"></i>
              <div class="n">{{ totalCount }}</div>
              <div class="l">Total Produits</div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="stat">
              <i class="bi bi-check-circle text-success" style="font-size: 26px;"></i>
              <div class="n">{{ dispoCount }}</div>
              <div class="l">Disponibles (page)</div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="stat">
              <i class="bi bi-exclamation-triangle text-warning" style="font-size: 26px;"></i>
              <div class="n">{{ ruptureStatCount }}</div>
              <div class="l">En Rupture (page)</div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="stat">
              <i class="bi bi-x-circle text-danger" style="font-size: 26px;"></i>
              <div class="n">{{ indispoCount }}</div>
              <div class="l">Indisponibles (page)</div>
            </div>
          </div>
        </div>
      </div>

      {% if hasAlerts %}
        <div class="inv-alert">
          <div class="inv-left">
            <div class="inv-bell"><i class="bi bi-bell-fill text-warning" style="font-size: 20px;"></i></div>
            <div>
              <p class="inv-title">Alerte inventaire</p>
              <div class="inv-meta">
                <strong>{{ ruptureCount }}</strong> en rupture •
                <strong>{{ lowCount }}</strong> stock faible (≤ {{ seuil }})
              </div>
            </div>
          </div>

          <button id="btnInvDetails" type="button" class="btn btn-inv">
            <i class="bi bi-eye me-2"></i>Voir détails
          </button>
        </div>
      {% endif %}

      <div class="table-wrap">
        <div class="table-responsive">
          <table class="table align-middle" id="produitsTable">
            <thead>
              <tr>
                <th>Image</th>
                <th>Nom</th>
                <th>Prix</th>
                <th class="text-center">Quantité</th>
                <th>Catégorie</th>
                <th class="text-center">Statut</th>
                <th>Description</th>
                <th class="text-center">Actions</th>
              </tr>
            </thead>

            <tbody>
              {% for produit in produits %}
                <tr class="tr-row"
                    data-name="{{ produit.nomProduit|lower }}"
                    data-qty="{{ produit.quantiteProduit }}"
                    data-price="{{ produit.prixProduit }}">

                  <td>
                    {% set img = produit.imageProduit %}
                    {% set imgUrl = 'https://via.placeholder.com/70?text=No+Img' %}

                    {% if img %}
                      {% if img starts with 'http' %}
                        {% set imgUrl = img %}
                      {% elseif img starts with '/' %}
                        {% set imgUrl = img %}
                      {% else %}
                        {% set imgUrl = asset('uploads/produits/' ~ img) %}
                      {% endif %}
                    {% endif %}

                    <img src="{{ imgUrl }}"
                         alt="{{ produit.nomProduit }}"
                         class="pimg"
                         onerror="this.onerror=null;this.src='https://via.placeholder.com/70?text=No+Img';" />
                  </td>

                  <td><div class="fw-bold text-dark">{{ produit.nomProduit }}</div></td>

                  <td>
                    <span class="fw-bold" style="color: var(--success);">
                      {{ produit.prixProduit|number_format(2, '.', '') }} DT
                    </span>
                  </td>

                  <td class="text-center">
                    {% set isLow = produit.quantiteProduit < seuil %}
                    <span class="pill-white {{ isLow ? 'qty-low' : 'qty-ok' }}">
                      <span class="qty-num">{{ produit.quantiteProduit }}</span>
                      <span>Qté</span>
                    </span>
                  </td>

                  <td>
                    <span class="pill-white" style="border-color: rgba(37,99,235,.20); color:#0f2a5f;">
                      <i class="bi bi-tag"></i> {{ produit.categorieProduit }}
                    </span>
                  </td>

                  <td class="text-center">
                    {% if produit.statusProduit == 'Disponible' %}
                      <span class="pill-white st-dispo">
                        <span class="st-dot"></span>
                        <i class="bi bi-check-circle"></i> Disponible
                      </span>
                    {% elseif produit.statusProduit == 'Rupture' %}
                      <span class="pill-white st-rupture">
                        <span class="st-dot"></span>
                        <i class="bi bi-exclamation-triangle"></i> Rupture
                      </span>
                    {% else %}
                      <span class="pill-white st-indispo">
                        <span class="st-dot"></span>
                        <i class="bi bi-x-circle"></i> Indisponible
                      </span>
                    {% endif %}
                  </td>

                  <td>
                    <span class="text-muted">
                      {{ produit.descriptionProduit|slice(0, 70) }}{% if produit.descriptionProduit|length > 70 %}...{% endif %}
                    </span>
                  </td>

                  <td class="text-center">
                    <div class="d-flex gap-2 justify-content-center">
                      <a href="{{ path('admin_produit_edit', {'id': produit.id_produit}) }}"
                         class="btn btn-action btn-edit"
                         data-bs-toggle="tooltip"
                         title="Modifier">
                        <i class="bi bi-pencil-fill"></i>
                      </a>

                      <form method="post"
                            action="{{ path('admin_produit_delete', {'id': produit.id_produit}) }}"
                            class="d-inline delete-form">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ produit.id_produit) }}">

                        <button type="button"
                                class="btn btn-action btn-del btn-open-delete"
                                data-nom="{{ produit.nomProduit|e('html_attr') }}"
                                data-bs-toggle="tooltip"
                                title="Supprimer">
                          <i class="bi bi-trash-fill"></i>
                        </button>
                      </form>
                    </div>
                  </td>

                </tr>
              {% else %}
                <tr>
                  <td colspan="8" class="text-center py-5">
                    <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
                    <p class="text-muted mt-3 mb-0">Aucun produit trouvé</p>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>

        {# ===== PAGINATION (SANS KNP) ===== #}
        <div class="p-3">
          <nav class="d-flex justify-content-center">
            <ul class="pagination mb-0">
              <li class="page-item {{ page <= 1 ? 'disabled' : '' }}">
                <a class="page-link"
                   href="{{ path('admin_produits_index', app.request.query.all | merge({'page': page-1})) }}">
                  Précédent
                </a>
              </li>

              <li class="page-item disabled">
                <span class="page-link">Page {{ page }} / {{ pages }}</span>
              </li>

              <li class="page-item {{ page >= pages ? 'disabled' : '' }}">
                <a class="page-link"
                   href="{{ path('admin_produits_index', app.request.query.all | merge({'page': page+1})) }}">
                  Suivant
                </a>
              </li>
            </ul>
          </nav>
        </div>

      </div>
    </div>
  </div>
</section>

{# ===== MODAL DÉTAILS INVENTAIRE ===== #}
<div class="modal fade" id="inventoryAlertModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
      <div class="modal-header" style="background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%);">
        <h5 class="modal-title fw-bold text-dark">
          <i class="bi bi-bell-fill me-2"></i>Détails Alerte Inventaire
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body p-4">
        <div class="row g-3">
          <div class="col-lg-6">
            <div class="p-3 rounded-4 border" style="background:#fff1f2; border-color:#fecaca !important;">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="fw-bold">
                  <i class="bi bi-exclamation-octagon-fill text-danger me-2"></i>En rupture
                </div>
                <span class="badge bg-danger rounded-pill">{{ ruptureCount }}</span>
              </div>

              {% if ruptureCount == 0 %}
                <div class="text-muted small">Aucun produit en rupture ✅</div>
              {% else %}
                <ul class="mb-0 small">
                  {% for p in ruptureList %}
                    <li class="mb-1"><strong>{{ p.nomProduit }}</strong> <span class="text-muted">— Stock: {{ p.quantiteProduit }}</span></li>
                  {% endfor %}
                </ul>
              {% endif %}
            </div>
          </div>

          <div class="col-lg-6">
            <div class="p-3 rounded-4 border" style="background:#fffbeb; border-color:#fde68a !important;">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="fw-bold">
                  <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>Stock faible (≤ {{ seuil }})
                </div>
                <span class="badge bg-warning text-dark rounded-pill">{{ lowCount }}</span>
              </div>

              {% if lowCount == 0 %}
                <div class="text-muted small">Aucun stock faible ✅</div>
              {% else %}
                <ul class="mb-0 small">
                  {% for p in lowStockList %}
                    <li class="mb-1">
                      <strong>{{ p.nomProduit }}</strong>
                      <span class="text-muted">— Stock: {{ p.quantiteProduit }}</span>
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
            </div>
          </div>
        </div>
      </div>

      <div class="modal-footer bg-light">
        <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Fermer</button>
      </div>
    </div>
  </div>
</div>

{# ===== CONFIRM DELETE OVERLAY ===== #}
<div id="adminConfirmOverlay" class="confirm-overlay d-none">
  <div class="confirm-box">
    <div class="text-center">
      <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 58px;"></i>
      <h4 class="mt-3 fw-bold">Confirmer la suppression</h4>
      <p id="adminConfirmMessage" class="text-muted mb-0"></p>
    </div>

    <div class="d-flex gap-2 justify-content-center mt-4 flex-wrap">
      <button class="btn btn-outline-secondary px-4 rounded-pill" id="adminConfirmNo" type="button">
        <i class="bi bi-x-circle me-2"></i>Annuler
      </button>
      <button class="btn btn-danger px-4 rounded-pill" id="adminConfirmYes" type="button">
        <i class="bi bi-trash-fill me-2"></i>Supprimer
      </button>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {

  // 1) Auto-hide flash
  document.querySelectorAll('.flash-message').forEach(msg => {
    setTimeout(() => {
      msg.classList.add('slide-out');
      setTimeout(() => msg.remove(), 350);
    }, 3000);
  });

  // 2) Tooltips
  if (window.bootstrap && bootstrap.Tooltip) {
    [...document.querySelectorAll('[data-bs-toggle="tooltip"]')].forEach(el => new bootstrap.Tooltip(el));
  }

  // 3) Inventory modal
  const invModalEl = document.getElementById('inventoryAlertModal');

  function openInvModal(){
    if (!invModalEl) return;
    if (!window.bootstrap || !bootstrap.Modal) return;
    bootstrap.Modal.getOrCreateInstance(invModalEl).show();
  }

  const btnInv = document.getElementById('btnInvDetails');
  const btnInvTop = document.getElementById('btnInvDetailsTop');
  if (btnInv) btnInv.addEventListener('click', (e)=>{ e.preventDefault(); openInvModal(); });
  if (btnInvTop) btnInvTop.addEventListener('click', (e)=>{ e.preventDefault(); openInvModal(); });

  // 4) Search (client-side)
  const searchInput = document.getElementById('searchInput');
  const table = document.getElementById('produitsTable');
  const tbody = table ? table.querySelector('tbody') : null;

  function applyFilter(){
    if (!tbody) return;
    const filter = (searchInput?.value || '').toLowerCase().trim();
    const rows = [...tbody.querySelectorAll('tr')];

    rows.forEach(row => {
      if (row.querySelector('td[colspan]')) return;
      row.style.display = row.textContent.toLowerCase().includes(filter) ? '' : 'none';
    });
  }

  if (searchInput) searchInput.addEventListener('input', applyFilter);

  // 5) Sort (client-side on current page)
  const sortSelect = document.getElementById('sortSelect');

  function sortRows(mode){
    if (!tbody) return;
    const rows = [...tbody.querySelectorAll('tr')].filter(r => !r.querySelector('td[colspan]'));

    const get = (r, key) => (r.dataset[key] ?? '');

    const compare = (a, b) => {
      switch(mode){
        case 'name_asc': return get(a,'name').localeCompare(get(b,'name'));
        case 'name_desc': return get(b,'name').localeCompare(get(a,'name'));
        case 'qty_asc': return (+get(a,'qty')) - (+get(b,'qty'));
        case 'qty_desc': return (+get(b,'qty')) - (+get(a,'qty'));
        case 'price_asc': return (+get(a,'price')) - (+get(b,'price'));
        case 'price_desc': return (+get(b,'price')) - (+get(a,'price'));
        default: return 0;
      }
    };

    rows.sort(compare).forEach(r => tbody.appendChild(r));
  }

  if (sortSelect) {
    sortSelect.addEventListener('change', function(){
      sortRows(this.value);
      applyFilter();
    });
  }

  // 6) Confirm delete (overlay)
  const overlay = document.getElementById('adminConfirmOverlay');
  const msg = document.getElementById('adminConfirmMessage');
  const btnNo = document.getElementById('adminConfirmNo');
  const btnYes = document.getElementById('adminConfirmYes');

  let formToSubmit = null;

  document.querySelectorAll('.btn-open-delete').forEach(btn => {
    btn.addEventListener('click', () => {
      const nom = btn.dataset.nom || 'ce produit';
      formToSubmit = btn.closest('form');
      msg.textContent = `Êtes-vous sûr de vouloir supprimer "${nom}" ? Cette action est irréversible.`;
      overlay.classList.remove('d-none');
    });
  });

  if (btnNo) {
    btnNo.addEventListener('click', () => {
      overlay.classList.add('d-none');
      formToSubmit = null;
    });
  }

  if (btnYes) {
    btnYes.addEventListener('click', () => {
      overlay.classList.add('d-none');
      if (formToSubmit) formToSubmit.submit();
    });
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay && !overlay.classList.contains('d-none')) {
      overlay.classList.add('d-none');
      formToSubmit = null;
    }
  });

});
</script>

{% endblock %}