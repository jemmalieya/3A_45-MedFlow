{% extends 'base_dashboard.html.twig' %}

{% block title %}Modération IA - Statistiques{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
  /* ===== KPI color cards (même design que Réclamations) ===== */
  .kpi-card{
    color:#fff;
    border-radius: 14px;
    overflow: hidden;
    position: relative;
  }
  .kpi-card .text-xs{ opacity:.85; letter-spacing:.4px; }
  .kpi-card .kpi-value{ font-weight: 900; font-size: 2rem; line-height: 1; }
  .kpi-card::after{
    content:"";
    position:absolute;
    right:-40px; top:-40px;
    width:160px; height:160px;
    background: rgba(255,255,255,.12);
    border-radius: 999px;
  }

  /* Couleurs KPI */
  .kpi-total { background: linear-gradient(135deg, #4f46e5, #6366f1); }
  .kpi-bad   { background: linear-gradient(135deg, #ef4444, #f97316); }
  .kpi-good  { background: linear-gradient(135deg, #16a34a, #22c55e); }
  .kpi-rate  { background: linear-gradient(135deg, #06b6d4, #22d3ee); }

  .period-chip{
    background: rgba(79,70,229,.08);
    border: 1px solid rgba(79,70,229,.18);
    color:#4f46e5;
    font-weight: 700;
    border-radius: 999px;
    padding: .35rem .65rem;
  }

  .chart-card{ border-radius: 14px; }
  .chart-card h6{ font-weight: 800; color:#111827; }

  /* ✅ FIX: stable chart height */
  .chart-wrap{
    position: relative;
    height: 320px;
    width: 100%;
  }
  .chart-wrap.sm{ height: 300px; }

  canvas{
    width: 100% !important;
    height: 100% !important;
  }
</style>
{% endblock %}

{% block body %}
<div class="container-fluid py-4">

  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h1 class="h3 mb-1 text-gray-800">
        <i class="bi bi-graph-up-arrow me-2"></i> Statistiques commentaires bloqués
      </h1>
      <div class="small text-muted">
        <span class="period-chip">Suivi de performance & indicateurs</span>
      </div>
    </div>

    <div class="d-flex gap-2 flex-wrap">
      <a class="btn btn-sm btn-primary" href="{{ path('admin_moderation_comments') }}">
        <i class="bi bi-arrow-left me-1"></i> Retour commentaires bloqués
      </a>
    </div>
  </div>

  {# ===== KPI ===== #}
  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card shadow-sm border-0 kpi-card kpi-total">
        <div class="card-body">
          <div class="text-xs text-uppercase">TOTAL COMMENTAIRES</div>
          <div class="kpi-value mt-2">{{ total }}</div>
          <div class="small mt-2 opacity-75">Tous les commentaires</div>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card shadow-sm border-0 kpi-card kpi-bad">
        <div class="card-body">
          <div class="text-xs text-uppercase">BLOQUÉS</div>
          <div class="kpi-value mt-2">{{ blocked }}</div>
          <div class="small mt-2 opacity-75">Détectés par IA</div>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card shadow-sm border-0 kpi-card kpi-good">
        <div class="card-body">
          <div class="text-xs text-uppercase">PUBLIÉS</div>
          <div class="kpi-value mt-2">{{ published }}</div>
          <div class="small mt-2 opacity-75">Acceptés</div>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card shadow-sm border-0 kpi-card kpi-rate">
        <div class="card-body">
          <div class="text-xs text-uppercase">TAUX DE BLOCAGE</div>
          <div class="kpi-value mt-2">{{ rate }}%</div>
          <div class="small mt-2 opacity-75">Ratio bloqués / total</div>
        </div>
      </div>
    </div>
  </div>

  {# ===== Chart + Tags ===== #}
  <div class="row g-4">
    <div class="col-lg-6">
      <div class="card shadow-sm border-0 chart-card">
        <div class="card-body">
          <h6 class="mb-3">Top mots dans les commentaires bloqués</h6>

          {% if topWords is empty %}
            <div class="text-muted">Aucun mot détecté.</div>
          {% else %}
            <div class="chart-wrap sm">
              <canvas id="topWordsChart"></canvas>
            </div>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="col-lg-6">
      <div class="card shadow-sm border-0 chart-card">
        <div class="card-body">
          <h6 class="mb-3">Tags détectés</h6>

          {% if topWords is empty %}
            <div class="text-muted">Aucun mot détecté.</div>
          {% else %}
            <div class="d-flex flex-wrap gap-2">
              {% for w, n in topWords %}
                <span class="badge bg-light text-dark border" style="border-radius:999px;">
                  #{{ w }} ({{ n }})
                </span>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  (function(){
    const topWords = {{ topWords|json_encode|raw }};
    const labels = Object.keys(topWords || {});
    const values = Object.values(topWords || {});

    const canvas = document.getElementById('topWordsChart');
    if (!canvas || labels.length === 0) return;

    // SB Admin peut être Chart.js v2
    const isV2 = !!(window.Chart && Chart.defaults && Chart.defaults.global);

    // defaults (comme Réclamations)
    if (isV2) {
      Chart.defaults.global.defaultFontFamily = "Nunito, system-ui, -apple-system, Segoe UI, Roboto, Arial";
      Chart.defaults.global.legend.labels.boxWidth = 12;
    } else {
      Chart.defaults.font.family = "Nunito, system-ui, -apple-system, Segoe UI, Roboto, Arial";
      Chart.defaults.plugins.legend.labels.boxWidth = 12;
    }

    new Chart(canvas, {
      type: 'bar',
      data: {
        labels,
        datasets: [{
          label: 'Occurrences',
          data: values,
          backgroundColor: '#4f46e5'
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        legend: isV2 ? { display: true, position: 'top' } : undefined,
        plugins: isV2 ? undefined : {
          legend: { display: true, position: 'top' }
        },
        scales: isV2 ? {
          yAxes: [{ ticks: { beginAtZero: true, precision: 0 } }]
        } : {
          y: { beginAtZero: true, ticks: { precision: 0 } }
        }
      }
    });
  })();
</script>
{% endblock %}