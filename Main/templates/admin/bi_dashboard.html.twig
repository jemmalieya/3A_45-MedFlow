{% extends 'base_dashboard.html.twig' %}
{% block title %}Tableau de bord BI{% endblock %}

{% block stylesheets %}
<style>
  /* ── KPI cards colorées ── */
  .bi-kpi {
    border-radius: 16px !important;
    padding: 1.4rem 1.6rem;
    color: #fff;
    position: relative;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0,0,0,0.13) !important;
    transition: transform .2s, box-shadow .2s;
    border: none !important;
  }
  .bi-kpi:hover { transform: translateY(-3px); box-shadow: 0 14px 32px rgba(0,0,0,0.18) !important; }
  .bi-kpi::after {
    content:''; position:absolute; right:-18px; bottom:-18px;
    width:90px; height:90px; border-radius:50%;
    background:rgba(255,255,255,0.12);
  }
  .bi-kpi::before {
    content:''; position:absolute; right:22px; bottom:22px;
    width:54px; height:54px; border-radius:50%;
    background:rgba(255,255,255,0.08);
  }
  .bi-kpi.blue   { background: linear-gradient(135deg,#4e73df,#2e59d9); }
  .bi-kpi.green  { background: linear-gradient(135deg,#1cc88a,#13a673); }
  .bi-kpi.orange { background: linear-gradient(135deg,#f6c23e,#c99e00); }
  .bi-kpi.purple { background: linear-gradient(135deg,#6f42c1,#5a32a3); }
  .bi-kpi-label  { font-size:10.5px; font-weight:800; text-transform:uppercase; letter-spacing:1.5px; opacity:.85; margin-bottom:8px; }
  .bi-kpi-value  { font-size:32px; font-weight:900; line-height:1; margin-bottom:4px; }
  .bi-kpi-sub    { font-size:12.5px; font-weight:600; opacity:.8; }
  .bi-kpi-var {
    display:inline-flex; align-items:center; gap:4px;
    margin-top:10px; background:rgba(255,255,255,0.20);
    border-radius:20px; padding:3px 11px;
    font-size:11.5px; font-weight:700;
  }

  /* ── KPI secondaires ── */
  .bi-sm {
    background:#fff; border-radius:14px !important;
    padding:1.1rem 1.3rem;
    border: none !important;
    box-shadow: 0 4px 18px rgba(78,115,223,0.09) !important;
    transition:transform .2s;
    height: 100%;
  }
  .bi-sm:hover { transform:translateY(-2px); }
  .bi-sm-icon {
    width:36px; height:36px; border-radius:9px;
    display:flex; align-items:center; justify-content:center;
    font-size:17px; margin-bottom:8px;
  }
  .bi-sm-label { font-size:10px; font-weight:800; color:#8892a4; text-transform:uppercase; letter-spacing:1px; }
  .bi-sm-value { font-size:24px; font-weight:900; color:#1a1f36; }
  .bi-sm-sub   { font-size:11.5px; color:#8892a4; font-weight:600; }

  /* ── Chart cards ── */
  .bi-chart-card {
    background:#fff; border-radius:16px !important;
    border:none !important;
    box-shadow:0 4px 18px rgba(78,115,223,0.09) !important;
    padding:1.4rem 1.6rem;
    height:100%;
  }
  .bi-card-title { font-size:15px; font-weight:800; color:#1a1f36; margin-bottom:2px; }
  .bi-card-sub   { font-size:12px; color:#8892a4; font-weight:600; margin-bottom:14px; }

  /* ── Filters ── */
  .bi-filters {
    background:#fff; border-radius:14px;
    padding:1rem 1.4rem; margin-bottom:1.5rem;
    box-shadow:0 4px 18px rgba(78,115,223,0.08);
    border:none !important;
  }
  .bi-flabel { font-size:10px; font-weight:800; color:#8892a4; text-transform:uppercase; letter-spacing:1px; display:block; margin-bottom:4px; }
  .bi-finput, .bi-fselect {
    height:36px; padding:0 12px;
    border:1.5px solid #e3e8f0 !important; border-radius:9px;
    font-size:13px; font-weight:600; color:#1a1f36;
    background:#f4f6fc; outline:none;
    transition:border-color .18s;
    width:100%;
  }
  .bi-finput:focus, .bi-fselect:focus { border-color:#4e73df !important; outline:none; box-shadow:none; }
  .bi-fbtn {
    height:36px; padding:0 18px; border-radius:9px;
    font-size:13px; font-weight:700; border:none; cursor:pointer;
    display:inline-flex; align-items:center; gap:6px;
    background: linear-gradient(135deg,#0097B2,#00BFA6);
    color:#fff; box-shadow:0 4px 12px rgba(0,151,178,0.28);
    transition:all .18s;
  }
  .bi-fbtn:hover { transform:translateY(-1px); box-shadow:0 6px 16px rgba(0,151,178,0.36); }

  /* ── Period tabs ── */
  .bi-tab {
    padding:6px 16px; border-radius:8px; font-size:13px; font-weight:700;
    border:1.5px solid #e3e8f0; background:#fff; color:#8892a4;
    text-decoration:none; transition:all .18s; display:inline-block;
  }
  .bi-tab:hover, .bi-tab.active {
    background:#4e73df; color:#fff; border-color:#4e73df;
    box-shadow:0 4px 12px rgba(78,115,223,0.25);
  }

  /* ── Alerts ── */
  .bi-alert {
    border-radius:10px; padding:10px 16px;
    font-size:13.5px; font-weight:600;
    display:flex; align-items:center; gap:9px;
    margin-bottom:8px;
  }
  .bi-alert.warning { background:#fff8e1; border-left:4px solid #f6c23e; color:#7a5200; }
  .bi-alert.danger  { background:#fdecea; border-left:4px solid #e74a3b; color:#8b1a1a; }
  .bi-alert.success { background:#e8faf3; border-left:4px solid #1cc88a; color:#0e5c3a; }
  .bi-alert.info    { background:#e8f4fd; border-left:4px solid #36b9cc; color:#0b4f6c; }

  /* ── Tables ── */
  .bi-table thead th {
    font-size:10.5px; font-weight:800; color:#8892a4;
    text-transform:uppercase; letter-spacing:1px;
    border-bottom:2px solid #e3e8f0 !important; border-top:none !important;
    padding:8px 12px;
  }
  .bi-table tbody td {
    font-size:13.5px; font-weight:600; color:#1a1f36;
    padding:10px 12px; border-color:#e3e8f0 !important; vertical-align:middle;
  }
  .bi-table tbody tr:hover td { background:#f4f6fc; }

  .bi-tag {
    display:inline-flex; align-items:center;
    padding:3px 10px; border-radius:20px;
    font-size:11px; font-weight:800;
  }
  .stock-ok       { background:rgba(28,200,138,0.12); color:#13a673; }
  .stock-mid      { background:rgba(246,194,62,0.15);  color:#9a7000; }
  .stock-low      { background:rgba(231,74,59,0.12);   color:#c0392b; }
  .status-rupture { background:rgba(231,74,59,0.12);   color:#c0392b; }
  .status-dispo   { background:rgba(28,200,138,0.12);  color:#13a673; }
  .status-autre   { background:rgba(111,66,193,0.12);  color:#5a32a3; }

  /* ── Tips ── */
  .bi-tips {
    background:linear-gradient(135deg,#1a1f36,#2d3f6b);
    border-radius:16px; padding:1.6rem 1.8rem; color:#fff;
    box-shadow:0 8px 28px rgba(30,42,74,0.28); border:none !important;
  }
  .bi-tips-title { font-size:15px; font-weight:800; margin-bottom:14px; display:flex; align-items:center; gap:8px; }
  .bi-tip {
    background:rgba(255,255,255,0.08); border-radius:9px;
    padding:11px 15px; font-size:13.5px; font-weight:600;
    display:flex; align-items:flex-start; gap:9px;
    color:rgba(255,255,255,0.88); border-left:3px solid #4e73df;
    height:100%;
  }
  .bi-tip-dot { color:#4e73df; font-size:17px; line-height:1.3; flex-shrink:0; }

  .bi-empty { text-align:center; padding:24px; color:#8892a4; font-size:13.5px; font-weight:600; }

  .bi-period-badge {
    display:inline-block; background:rgba(78,115,223,0.10);
    color:#4e73df; padding:3px 12px; border-radius:20px;
    font-size:12px; font-weight:700; margin-top:4px;
  }
</style>
{% endblock %}

{% block body %}

<!-- PAGE HEADER -->
<div class="d-flex align-items-center justify-content-between flex-wrap mb-4 gap-2">
  <div>
    <h1 class="h4 mb-0 text-gray-800 font-weight-bold">📊 Tableau de bord BI</h1>
    <div class="mt-1">
      <span class="bi-period-badge">
        Période : {{ from }} → {{ to }}{% if cat %} | {{ cat }}{% endif %}
      </span>
    </div>
  </div>
  <div class="d-flex gap-2">
    <a href="?days=7"  class="bi-tab {% if days == 7  %}active{% endif %}">7j</a>
    <a href="?days=30" class="bi-tab {% if days == 30 %}active{% endif %}">30j</a>
    <a href="?days=90" class="bi-tab {% if days == 90 %}active{% endif %}">90j</a>
  </div>
</div>

<!-- FILTRES -->
<div class="bi-filters mb-4">
  <form method="get" class="d-flex align-items-end flex-wrap gap-3">
    <div>
      <label class="bi-flabel">Date de début</label>
      <input type="date" name="from" value="{{ from }}" class="bi-finput">
    </div>
    <div>
      <label class="bi-flabel">Date de fin</label>
      <input type="date" name="to" value="{{ to }}" class="bi-finput">
    </div>
    <div>
      <label class="bi-flabel">Catégorie</label>
      <select name="cat" class="bi-fselect">
        <option value="">Toutes les catégories</option>
        {% for c in categories %}
          <option value="{{ c }}" {% if c == cat %}selected{% endif %}>{{ c }}</option>
        {% endfor %}
      </select>
    </div>
    <button type="submit" class="bi-fbtn">🔍 Filtrer</button>
  </form>
</div>

<!-- ALERTES -->
{% if alerts is not empty %}
<div class="mb-3">
  {% for a in alerts %}
  <div class="bi-alert {{ a.type }}">
    {% if a.type == 'danger' %}🔴{% elseif a.type == 'success' %}🟢{% elseif a.type == 'info' %}🔵{% else %}🟡{% endif %}
    <strong>{{ a.title }}</strong> — {{ a.message }}
  </div>
  {% endfor %}
</div>
{% endif %}

<!-- KPI PRINCIPAUX -->
<div class="row mb-3">
  <div class="col-xl-3 col-md-6 mb-3">
    <div class="bi-kpi blue h-100">
      <div class="bi-kpi-label">Chiffre d'affaires</div>
      <div class="bi-kpi-value">{{ kpi.ca|number_format(2, ',', ' ') }}</div>
      <div class="bi-kpi-sub">DT</div>
      {% if kpi.variationCA is not null %}
      <div class="bi-kpi-var">
        {% if kpi.variationCA >= 0 %}↑{% else %}↓{% endif %}
        {{ kpi.variationCA|abs|number_format(1, ',', ' ') }}% vs préc.
      </div>
      {% endif %}
    </div>
  </div>
  <div class="col-xl-3 col-md-6 mb-3">
    <div class="bi-kpi green h-100">
      <div class="bi-kpi-label">Commandes</div>
      <div class="bi-kpi-value">{{ kpi.nbCommandes }}</div>
      <div class="bi-kpi-sub">total période</div>
      {% if kpi.variationCommandes is not null %}
      <div class="bi-kpi-var">
        {% if kpi.variationCommandes >= 0 %}↑{% else %}↓{% endif %}
        {{ kpi.variationCommandes|abs|number_format(1, ',', ' ') }}% vs préc.
      </div>
      {% endif %}
    </div>
  </div>
  <div class="col-xl-3 col-md-6 mb-3">
    <div class="bi-kpi orange h-100">
      <div class="bi-kpi-label">Panier moyen</div>
      <div class="bi-kpi-value">{{ kpi.panierMoyen|number_format(2, ',', ' ') }}</div>
      <div class="bi-kpi-sub">DT / commande</div>
      {% if kpi.variationPanier is not null %}
      <div class="bi-kpi-var">
        {% if kpi.variationPanier >= 0 %}↑{% else %}↓{% endif %}
        {{ kpi.variationPanier|abs|number_format(1, ',', ' ') }}% vs préc.
      </div>
      {% endif %}
    </div>
  </div>
  <div class="col-xl-3 col-md-6 mb-3">
    <div class="bi-kpi purple h-100">
      <div class="bi-kpi-label">Taux de conversion</div>
      <div class="bi-kpi-value">{{ kpi.tauxConversion|number_format(1, ',', ' ') }}%</div>
      <div class="bi-kpi-sub">{{ kpi.nbValidees }} / {{ kpi.nbCommandes }} validées</div>
    </div>
  </div>
</div>

<!-- KPI SECONDAIRES -->
<div class="row mb-4">
  <div class="col-xl-3 col-md-6 mb-3">
    <div class="bi-sm">
      <div class="bi-sm-icon" style="background:rgba(54,185,204,0.12)">📦</div>
      <div class="bi-sm-label">Qté totale vendue</div>
      <div class="bi-sm-value">{{ kpi.quantiteTotale }}</div>
      <div class="bi-sm-sub">unités</div>
    </div>
  </div>
  <div class="col-xl-3 col-md-6 mb-3">
    <div class="bi-sm">
      <div class="bi-sm-icon" style="background:rgba(246,194,62,0.15)">⏳</div>
      <div class="bi-sm-label">En attente</div>
      <div class="bi-sm-value">{{ kpi.nbEnAttente }}</div>
      <div class="bi-sm-sub">commandes</div>
    </div>
  </div>
  <div class="col-xl-3 col-md-6 mb-3">
    <div class="bi-sm">
      <div class="bi-sm-icon" style="background:rgba(231,74,59,0.12)">🚫</div>
      <div class="bi-sm-label">Taux de rupture</div>
      <div class="bi-sm-value">{{ kpi.tauxRupture|number_format(1, ',', ' ') }}%</div>
      <div class="bi-sm-sub">produits en rupture</div>
    </div>
  </div>
  <div class="col-xl-3 col-md-6 mb-3">
    <div class="bi-sm">
      <div class="bi-sm-icon" style="background:rgba(78,115,223,0.12)">📅</div>
      <div class="bi-sm-label">Période analysée</div>
      <div class="bi-sm-value">{{ days }}</div>
      <div class="bi-sm-sub">jours</div>
    </div>
  </div>
</div>

<!-- GRAPHIQUES LIGNE 1 -->
<div class="row mb-4">
  <div class="col-xl-8 mb-3">
    <div class="bi-chart-card">
      <div class="bi-card-title">📈 Évolution quotidienne des ventes</div>
      <div class="bi-card-sub">CA et quantités par jour{% if cat %} — {{ cat }}{% endif %}</div>
      <canvas id="mainChart" style="max-height:250px"></canvas>
    </div>
  </div>
  <div class="col-xl-4 mb-3">
    <div class="bi-chart-card">
      <div class="bi-card-title">🍩 Répartition par statut</div>
      <div class="bi-card-sub">Distribution des commandes</div>
      <canvas id="statusChart" style="max-height:250px"></canvas>
    </div>
  </div>
</div>

<!-- GRAPHIQUES LIGNE 2 -->
<div class="row mb-4">
  <div class="col-xl-6 mb-3">
    <div class="bi-chart-card">
      <div class="bi-card-title">🏷️ Performance par catégorie</div>
      <div class="bi-card-sub">Quantités et CA par catégorie</div>
      <canvas id="catChart" style="max-height:240px"></canvas>
    </div>
  </div>
  <div class="col-xl-6 mb-3">
    <div class="bi-chart-card">
      <div class="bi-card-title">📊 CA par catégorie</div>
      <div class="bi-card-sub">Chiffre d'affaires comparé</div>
      <canvas id="caChart" style="max-height:240px"></canvas>
    </div>
  </div>
</div>

<!-- TABLES -->
<div class="row mb-4">
  <div class="col-xl-7 mb-3">
    <div class="bi-chart-card">
      <div class="bi-card-title">🏆 Top 10 des produits</div>
      <div class="bi-card-sub">Produits les plus vendus sur la période</div>
      <div class="table-responsive">
        <table class="table bi-table mb-0">
          <thead>
            <tr>
              <th>Produit</th><th>Catégorie</th><th>Qté</th><th>CA (DT)</th><th>Stock</th>
            </tr>
          </thead>
          <tbody>
            {% for p in topProduits %}
            {% set sc = (p.stock_actuel >= 11) ? 'stock-ok' : (p.stock_actuel >= 5 ? 'stock-mid' : 'stock-low') %}
            <tr>
              <td>{{ p.produit }}</td>
              <td>{{ p.categorie }}</td>
              <td>{{ p.quantite }}</td>
              <td>{{ p.ca|number_format(0, ',', ' ') }}</td>
              <td><span class="bi-tag {{ sc }}">{{ p.stock_actuel }}</span></td>
            </tr>
            {% else %}
            <tr><td colspan="5" class="bi-empty">Aucune donnée disponible</td></tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="col-xl-5 mb-3">
    <div class="bi-chart-card">
      <div class="bi-card-title">⚠️ Stock critique</div>
      <div class="bi-card-sub">Produits à réapprovisionner</div>
      {% if stocksBas is empty %}
        <div class="bi-empty">✅ Aucun produit en stock critique</div>
      {% else %}
      <div class="table-responsive">
        <table class="table bi-table mb-0">
          <thead>
            <tr><th>Produit</th><th>Catégorie</th><th>Stock</th><th>Statut</th></tr>
          </thead>
          <tbody>
            {% for s in stocksBas %}
            {% set sc2 = (s.quantite_produit >= 11) ? 'stock-ok' : (s.quantite_produit >= 5 ? 'stock-mid' : 'stock-low') %}
            {% set stl = s.status_produit|lower %}
            {% set stc = (stl == 'rupture') ? 'status-rupture' : (stl == 'disponible' ? 'status-dispo' : 'status-autre') %}
            <tr>
              <td>{{ s.nom_produit }}</td>
              <td>{{ s.categorie_produit }}</td>
              <td><span class="bi-tag {{ sc2 }}">{{ s.quantite_produit }}</span></td>
              <td><span class="bi-tag {{ stc }}">{{ s.status_produit }}</span></td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% endif %}
    </div>
  </div>
</div>

<!-- RECOMMANDATIONS -->
{% if tips is not empty %}
<div class="bi-tips mb-4">
  <div class="bi-tips-title">💡 Recommandations stratégiques</div>
  <div class="row g-2">
    {% for t in tips %}
    <div class="col-md-6 col-xl-4">
      <div class="bi-tip">
        <span class="bi-tip-dot">›</span>
        <span>{{ t }}</span>
      </div>
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

<!-- CHARTS JS -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
  const _cd = {
    responsive: true,
    maintainAspectRatio: true,
    plugins: { legend: { labels: { font:{family:'Nunito',weight:'700'}, color:'#8892a4' } } },
    scales: {
      x: { grid:{color:'#e3e8f0'}, ticks:{font:{family:'Nunito',weight:'600'},color:'#8892a4'} },
      y: { grid:{color:'#e3e8f0'}, ticks:{font:{family:'Nunito',weight:'600'},color:'#8892a4'} }
    }
  };

  /* Évolution quotidienne */
  new Chart(document.getElementById('mainChart'), {
    type: 'line',
    data: {
      labels: {{ charts.ventesJour|map(v => v.jour)|json_encode|raw }},
      datasets: [
        {
          label:'CA (DT)',
          data: {{ charts.ventesJour|map(v => v.ca)|json_encode|raw }},
          borderColor:'#4e73df', backgroundColor:'rgba(78,115,223,0.10)',
          borderWidth:2.5, pointRadius:4, pointBackgroundColor:'#4e73df',
          fill:true, tension:0.4, yAxisID:'y'
        },
        {
          label:'Quantités',
          data: {{ charts.ventesJour|map(v => v.quantite)|json_encode|raw }},
          borderColor:'#1cc88a', backgroundColor:'rgba(28,200,138,0.08)',
          borderWidth:2.5, pointRadius:4, pointBackgroundColor:'#1cc88a',
          fill:true, tension:0.4, yAxisID:'y1'
        }
      ]
    },
    options: {
      ..._cd,
      scales: {
        x:  _cd.scales.x,
        y:  { ..._cd.scales.y, position:'left' },
        y1: { ..._cd.scales.y, position:'right', grid:{drawOnChartArea:false} }
      }
    }
  });

  /* Statuts donut */
  new Chart(document.getElementById('statusChart'), {
    type: 'doughnut',
    data: {
      labels: {{ charts.statuts|map(s => s.label)|json_encode|raw }},
      datasets: [{
        data: {{ charts.statuts|map(s => s.value)|json_encode|raw }},
        backgroundColor:['#4e73df','#1cc88a','#f6c23e','#e74a3b','#6f42c1','#36b9cc'],
        borderWidth:3, borderColor:'#fff'
      }]
    },
    options: {
      responsive:true, maintainAspectRatio:true,
      plugins:{ legend:{ position:'bottom', labels:{font:{family:'Nunito',weight:'700'},color:'#8892a4',padding:14} } },
      cutout:'65%'
    }
  });

  /* Catégories groupées */
  new Chart(document.getElementById('catChart'), {
    type: 'bar',
    data: {
      labels: {{ charts.categories|map(c => c.categorie)|json_encode|raw }},
      datasets: [
        {
          label:'Quantité',
          data: {{ charts.categories|map(c => c.quantite)|json_encode|raw }},
          backgroundColor:'rgba(78,115,223,0.75)', borderRadius:5, borderSkipped:false
        },
        {
          label:'CA (DT)',
          data: {{ charts.categories|map(c => c.ca)|json_encode|raw }},
          backgroundColor:'rgba(28,200,138,0.75)', borderRadius:5, borderSkipped:false
        }
      ]
    },
    options: _cd
  });

  /* CA horizontal */
  new Chart(document.getElementById('caChart'), {
    type: 'bar',
    data: {
      labels: {{ charts.categories|map(c => c.categorie)|json_encode|raw }},
      datasets: [{
        label:'CA (DT)',
        data: {{ charts.categories|map(c => c.ca)|json_encode|raw }},
        backgroundColor:['#4e73df','#1cc88a','#f6c23e','#e74a3b','#6f42c1','#36b9cc'],
        borderRadius:5, borderSkipped:false
      }]
    },
    options: { ..._cd, indexAxis:'y', plugins:{legend:{display:false}} }
  });
</script>

{% endblock %}
