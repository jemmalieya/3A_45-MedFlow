{% extends 'base_dashboard.html.twig' %}

{% block title %}
  {% if commande is defined and commande %}
    Commande #{{ commande.idCommande }}
  {% else %}
    Gestion des commandes
  {% endif %}
{% endblock %}

{% block body %}

<style>
/* ==============================================
   ADMIN COMMANDES - MODERN TEAL DESIGN (COPY/PASTE)
   ============================================== */
:root{
  --teal-50:#ecfeff;
  --teal-100:#cffafe;
  --teal-200:#a5f3fc;
  --teal-300:#67e8f9;
  --teal-400:#22d3ee;
  --teal-500:#06b6d4;
  --teal-600:#0891b2;
  --teal-700:#0e7490;
  --teal-800:#155e75;
  --teal-900:#164e63;

  --gray-50:#f9fafb;
  --gray-100:#f3f4f6;
  --gray-200:#e5e7eb;
  --gray-600:#4b5563;
  --gray-700:#374151;
  --gray-800:#1f2937;
  --gray-900:#111827;

  --shadow-sm:0 6px 18px rgba(17,24,39,.08);
  --shadow-md:0 14px 36px rgba(17,24,39,.12);
}

.container-fluid{
  background: linear-gradient(135deg, var(--gray-50) 0%, var(--teal-50) 100%);
  min-height: 100vh;
  padding: 2rem !important;
  color: var(--gray-900);
}

/* ne pas casser badges/boutons */
.container-fluid p,
.container-fluid span,
.container-fluid small,
.container-fluid td,
.container-fluid th,
.container-fluid label,
.container-fluid h1,
.container-fluid h2,
.container-fluid h3,
.container-fluid h4,
.container-fluid h5,
.container-fluid h6{
  color: var(--gray-900);
}
.text-muted{ color: var(--gray-600) !important; }
.btn i, .badge i{ color: inherit !important; }

/* Flash */
.alert{
  border:none;
  border-radius:14px;
  padding:1.25rem 1.5rem;
  margin-bottom:1.5rem;
  box-shadow: var(--shadow-sm);
  animation: slideInDown .35s ease-out;
}
@keyframes slideInDown{from{opacity:0;transform:translateY(-18px)}to{opacity:1;transform:translateY(0)}}
.alert-success{
  background: linear-gradient(135deg, var(--teal-100) 0%, var(--teal-200) 100%);
  color: var(--teal-900) !important;
  border-left: 6px solid var(--teal-600);
}
.alert-danger{
  background: linear-gradient(135deg,#fee2e2 0%,#fecaca 100%);
  color:#991b1b !important;
  border-left: 6px solid #ef4444;
}

/* Header title */
.d-flex.justify-content-between.align-items-center.mb-4 h2{
  font-size:2rem;
  font-weight:800;
  background: linear-gradient(135deg, var(--teal-600) 0%, var(--teal-800) 100%);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
}
.d-flex.justify-content-between.align-items-center.mb-4 h2 i{
  color: var(--teal-700) !important;
  -webkit-text-fill-color: var(--teal-700) !important;
}

/* Cards */
.card{
  border:none;
  border-radius:18px;
  background:#fff;
  box-shadow: 0 10px 26px rgba(8,145,178,.12);
  overflow:hidden;
  transition: transform .25s ease, box-shadow .25s ease;
  animation: fadeIn .45s ease-out;
}
.card:hover{
  transform: translateY(-4px);
  box-shadow: 0 18px 44px rgba(8,145,178,.18);
}
@keyframes fadeIn{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}

.card-header{
  border:none !important;
  padding:1.4rem 1.5rem;
  font-weight:800;
}

/* Headers (teal palette) */
.card-header.bg-dark{
  background: linear-gradient(135deg, var(--teal-800) 0%, var(--teal-900) 100%) !important;
}
.card-header.bg-dark *{ color:#fff !important; }

.card-header.bg-primary{
  background: linear-gradient(135deg, var(--teal-600) 0%, var(--teal-800) 100%) !important;
}
.card-header.bg-primary *{ color:#fff !important; }

.card-header.bg-info{
  background: linear-gradient(135deg, var(--teal-500) 0%, var(--teal-700) 100%) !important;
}
.card-header.bg-info *{ color:#fff !important; }

.card-header.bg-warning{
  background: linear-gradient(135deg,#fbbf24 0%,#f59e0b 100%) !important;
  color:#111827 !important;
}
.card-header.bg-warning *{ color:#111827 !important; }

.card-header.bg-danger{
  background: linear-gradient(135deg,#ef4444 0%,#dc2626 100%) !important;
}
.card-header.bg-danger *{ color:#fff !important; }

/* Tables */
.table thead.table-dark{
  background: linear-gradient(135deg, var(--teal-700) 0%, var(--teal-900) 100%) !important;
}
.table thead.table-dark th{
  color:#fff !important;
  font-weight:800;
  text-transform:uppercase;
  font-size:.82rem;
  letter-spacing:.5px;
  padding:1rem;
  border:none;
}
.table tbody tr{
  transition: background .2s ease, transform .2s ease;
  border-bottom:1px solid var(--gray-200);
}
.table tbody tr:hover{
  background: linear-gradient(135deg, var(--teal-50) 0%, var(--teal-100) 100%);
  transform: scale(1.01);
}
.table td{ padding:1rem; vertical-align:middle; }
.table-light{ background: var(--gray-100) !important; }
.table-light th, .table-light td{
  font-weight:800;
  color: var(--gray-700) !important;
}

/* Badges (teal style + lisible) */
.badge{
  padding:.52rem 1rem;
  font-size:.85rem;
  font-weight:900;
  border-radius:999px;
  letter-spacing:.2px;
}
.badge.bg-primary{
  background: linear-gradient(135deg, var(--teal-600) 0%, var(--teal-800) 100%) !important;
  color:#fff !important;
}
.badge.bg-info{
  background: linear-gradient(135deg, var(--teal-500) 0%, var(--teal-700) 100%) !important;
  color:#fff !important;
}
.badge.bg-warning{
  background: linear-gradient(135deg,#fbbf24 0%,#f59e0b 100%) !important;
  color:#111827 !important;
}
.badge.bg-success{
  background: linear-gradient(135deg,#10b981 0%,#059669 100%) !important;
  color:#fff !important;
}
.badge.bg-danger{
  background: linear-gradient(135deg,#ef4444 0%,#dc2626 100%) !important;
  color:#fff !important;
}
.badge.bg-secondary{
  background: linear-gradient(135deg,#6b7280 0%,#4b5563 100%) !important;
  color:#fff !important;
}

/* Buttons */
.btn{
  border-radius:12px;
  padding:.75rem 1.35rem;
  font-weight:900;
  border:none;
  position:relative;
  overflow:hidden;
  transition: transform .2s ease, box-shadow .2s ease;
}
.btn::before{
  content:"";
  position:absolute;
  top:50%; left:50%;
  width:0; height:0;
  border-radius:50%;
  background: rgba(255,255,255,.28);
  transform: translate(-50%,-50%);
  transition: width .55s, height .55s;
}
.btn:hover::before{ width:320px; height:320px; }
.btn:hover{ transform: translateY(-1px); }

.btn-primary{
  background: linear-gradient(135deg, var(--teal-600) 0%, var(--teal-800) 100%);
  color:#fff !important;
  box-shadow: 0 10px 20px rgba(8,145,178,.25);
}
.btn-warning{
  background: linear-gradient(135deg,#fbbf24 0%,#f59e0b 100%);
  color:#111827 !important;
  box-shadow: 0 10px 20px rgba(245,158,11,.22);
}
.btn-success{
  background: linear-gradient(135deg,#10b981 0%,#059669 100%);
  color:#fff !important;
}
.btn-danger{
  background: linear-gradient(135deg,#ef4444 0%,#dc2626 100%);
  color:#fff !important;
}
.btn-outline-secondary{
  background:#fff;
  border:2px solid var(--gray-200) !important;
  color: var(--gray-800) !important;
}
.btn-outline-primary{
  background:#fff;
  border:2px solid var(--teal-600) !important;
  color: var(--teal-700) !important;
}
.btn-sm{ padding:.5rem 1rem; font-size:.875rem; }
.btn-lg{ padding:1rem 2rem; font-size:1.05rem; }
.btn i{ margin-right:.5rem; }

/* Forms */
.form-select, .form-control{
  border:2px solid var(--gray-200);
  border-radius:12px;
  padding:.75rem 1rem;
}
.form-select:focus, .form-control:focus{
  border-color: var(--teal-600);
  box-shadow: 0 0 0 3px rgba(6,182,212,.14);
}

/* zone dangereuse */
.card.border-danger{ border:2px solid #ef4444 !important; }
hr{ border-color: var(--gray-200); opacity:1; margin:1.5rem 0; }

/* Helpers (optionnel) */
.text-primary{ color: var(--teal-700) !important; }
</style>

{# ============================
   FLASH MESSAGES
============================ #}
{% for message in app.flashes('success') %}
  <div class="alert alert-success alert-dismissible fade show">
    <i class="bi bi-check-circle-fill me-2"></i>{{ message }}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
{% endfor %}

{% for message in app.flashes('error') %}
  <div class="alert alert-danger alert-dismissible fade show">
    <i class="bi bi-x-circle-fill me-2"></i>{{ message }}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
{% endfor %}

{# ============================
   LISTE DES COMMANDES
============================ #}
{% if commande is not defined or not commande %}
<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h2 class="mb-1"><i class="bi bi-box-seam"></i> Gestion des commandes</h2>
      <p class="text-muted mb-0">{{ commandes is defined ? commandes|length : 0 }} commande(s) au total</p>
    </div>
  </div>

  <div class="card shadow-sm">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
          <thead class="table-dark">
            <tr>
              <th>#</th>
              <th>Date</th>
              <th>Client</th>
              <th>Montant</th>
              <th>Statut</th>
              <th>Produits</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>

          <tbody>
            {% if commandes is empty %}
              <tr>
                <td colspan="7" class="text-center py-5 text-muted">
                  <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                  <p class="mt-3 mb-0">Aucune commande</p>
                </td>
              </tr>
            {% else %}
              {% for c in commandes %}
                {% set st = c.statutCommande %}
                <tr>
                  <td class="fw-bold">#{{ c.idCommande }}</td>
                  <td>{{ c.dateCreationCommande|date('d/m/Y H:i') }}</td>

                  <td>
                    {% if c.user %}
                      <div class="fw-bold">{{ c.user.nom }} {{ c.user.prenom }}</div>
                      <small class="text-muted">{{ c.user.emailUser }}</small>
                    {% else %}
                      <span class="text-muted">Utilisateur supprimé</span>
                    {% endif %}
                  </td>

                  <td class="fw-bold text-success">{{ c.montantTotal|number_format(2, '.', '') }} Dt</td>

                  <td>
                    {% if st == 'En attente' %}
                      <span class="badge bg-warning text-dark">⏳ {{ st }}</span>
                    {% elseif st == 'En cours' %}
                      <span class="badge bg-info">🔄 {{ st }}</span>
                    {% elseif st == 'En livraison' %}
                      <span class="badge bg-primary">🚚 {{ st }}</span>
                    {% elseif st == 'Expédiée' %}
                      <span class="badge bg-primary">📦 {{ st }}</span>
                    {% elseif st == 'Livrée' %}
                      <span class="badge bg-success">✅ {{ st }}</span>
                    {% else %}
                      <span class="badge bg-danger">❌ {{ st }}</span>
                    {% endif %}
                  </td>

                  <td><span class="badge bg-secondary">{{ c.ligneCommandes|length }} produit(s)</span></td>

                  <td class="text-end">
                    <a href="{{ path('admin_commande_show', {id: c.idCommande}) }}" class="btn btn-sm btn-primary">
                      <i class="bi bi-eye"></i> Détails
                    </a>
                    <a href="{{ path('admin_commande_facture_pdf', {id: c.idCommande}) }}" class="btn btn-sm btn-warning">
                      <i class="bi bi-download"></i> Facture
                    </a>
                  </td>
                </tr>
              {% endfor %}
            {% endif %}
          </tbody>

        </table>
      </div>
    </div>
  </div>
</div>

{# ============================
   DETAILS D'UNE COMMANDE
============================ #}
{% else %}

{% set st = commande.statutCommande %}

<div class="container-fluid py-4">
  <div class="col-lg-10 mx-auto">

    <div class="mb-4">
      <a href="{{ path('admin_commandes_index') }}" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Retour à la liste
      </a>
    </div>

    <div class="card shadow-sm mb-4">
      <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0"><i class="bi bi-receipt"></i> Commande #{{ commande.idCommande }}</h4>
        <small>{{ commande.dateCreationCommande|date('d/m/Y à H:i') }}</small>
      </div>

      <div class="card-body">
        <div class="row mb-4">

          <div class="col-md-4">
            <h6 class="text-muted mb-3"><i class="bi bi-person"></i> Informations client</h6>
            {% if commande.user %}
              <p class="mb-1"><strong>Nom :</strong> {{ commande.user.nom }} {{ commande.user.prenom }}</p>
              <p class="mb-1"><strong>CIN :</strong> {{ commande.user.cin }}</p>
              <p class="mb-1"><strong>Email :</strong> {{ commande.user.emailUser }}</p>
              <p class="mb-1"><strong>Téléphone :</strong> {{ commande.user.telephoneUser }}</p>
              {% if commande.user.adresseUser %}
                <p class="mb-1"><strong>Adresse :</strong> {{ commande.user.adresseUser }}</p>
              {% endif %}
            {% else %}
              <p class="text-muted">Utilisateur supprimé</p>
            {% endif %}
          </div>

          <div class="col-md-4">
            <h6 class="text-muted mb-3"><i class="bi bi-cash-stack"></i> Montant</h6>
            <p class="fw-bold text-success fs-4 mb-0">{{ commande.montantTotal|number_format(2, '.', '') }} Dt</p>
            {% if commande.paidAt %}
              <small class="text-muted">
                <i class="bi bi-check-circle-fill text-success"></i>
                Payé le {{ commande.paidAt|date('d/m/Y à H:i') }}
              </small>
            {% endif %}
          </div>

          <div class="col-md-4">
            <h6 class="text-muted mb-3"><i class="bi bi-info-circle"></i> Statut</h6>
            <p>
              {% if st == 'En attente' %}
                <span class="badge bg-warning text-dark fs-6">⏳ {{ st }}</span>
              {% elseif st == 'En cours' %}
                <span class="badge bg-info fs-6">🔄 {{ st }}</span>
              {% elseif st == 'En livraison' %}
                <span class="badge bg-primary fs-6">🚚 {{ st }}</span>
              {% elseif st == 'Expédiée' %}
                <span class="badge bg-primary fs-6">📦 {{ st }}</span>
              {% elseif st == 'Livrée' %}
                <span class="badge bg-success fs-6">✅ {{ st }}</span>
              {% else %}
                <span class="badge bg-danger fs-6">❌ {{ st }}</span>
              {% endif %}
            </p>

            {% if commande.stripeSessionId %}
              <small class="text-muted d-block mt-2"><i class="bi bi-credit-card"></i> Paiement Stripe</small>
            {% endif %}
          </div>

        </div>

        <hr>

        <h5 class="mb-3"><i class="bi bi-box-seam"></i> Produits commandés</h5>

        <div class="table-responsive">
          <table class="table table-bordered align-middle">
            <thead class="table-light">
              <tr>
                <th>Produit</th>
                <th class="text-center">Quantité</th>
                <th class="text-end">Prix unitaire</th>
                <th class="text-end">Sous-total</th>
              </tr>
            </thead>

            <tbody>
              {% for ligne in commande.ligneCommandes %}
                <tr>
                  <td>
                    <div class="d-flex align-items-center">
                      {% if ligne.produit and ligne.produit.imageProduit %}
                        <img
                          src="{{ asset('uploads/produits/' ~ ligne.produit.imageProduit) }}"
                          alt="{{ ligne.produit.nomProduit }}"
                          style="width:50px;height:50px;object-fit:cover;border-radius:8px"
                          class="me-3"
                        >
                      {% endif %}
                      <div>
                        <div class="fw-bold">{{ ligne.produit.nomProduit }}</div>
                        <small class="text-muted">{{ ligne.produit.categorieProduit }}</small>
                      </div>
                    </div>
                  </td>

                  <td class="text-center">
                    <span class="badge bg-primary">{{ ligne.quantite_commandee }}</span>
                  </td>

                  <td class="text-end">{{ ligne.produit.prixProduit|number_format(2, '.', '') }} Dt</td>
                  <td class="text-end fw-bold">
                    {{ (ligne.produit.prixProduit * ligne.quantite_commandee)|number_format(2, '.', '') }} Dt
                  </td>
                </tr>
              {% endfor %}
            </tbody>

            <tfoot class="table-light">
              <tr class="fw-bold">
                <td colspan="3" class="text-end">TOTAL :</td>
                <td class="text-end text-success fs-5">{{ commande.montantTotal|number_format(2, '.', '') }} Dt</td>
              </tr>
            </tfoot>
          </table>
        </div>

      </div>
    </div>

    {# ============================
       ACTIONS RAPIDES
    ============================ #}
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-info text-white">
        <h5 class="mb-0"><i class="bi bi-lightning"></i> Actions rapides</h5>
      </div>
      <div class="card-body">
        <div class="d-flex gap-2 flex-wrap">
          <a href="{{ path('admin_commande_facture_pdf', {id: commande.idCommande}) }}" class="btn btn-warning">
            <i class="bi bi-download"></i> Télécharger la facture
          </a>

          {% if commande.user and commande.user.emailUser %}
            <a href="mailto:{{ commande.user.emailUser }}" class="btn btn-outline-secondary">
              <i class="bi bi-envelope"></i> Contacter par email
            </a>
          {% endif %}

          {% if commande.user and commande.user.telephoneUser %}
            <a href="tel:{{ commande.user.telephoneUser }}" class="btn btn-success">
              <i class="bi bi-telephone"></i> Appeler le client
            </a>
          {% endif %}
        </div>
      </div>
    </div>

    {# ============================
       LIVRAISON (STAFF)
    ============================ #}
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-warning text-dark">
        <h5 class="mb-0"><i class="bi bi-truck"></i> Livraison (Staff)</h5>
      </div>
      <div class="card-body">

        {% if st == 'En cours' %}
          <form method="post" action="{{ path('admin_commande_start_livraison', {id: commande.idCommande}) }}">
            <button type="submit" class="btn btn-warning w-100 btn-lg">
              🚚 Démarrer la livraison
            </button>
          </form>

        {% elseif st == 'En livraison' %}
          <div class="d-grid gap-2">
            <a class="btn btn-outline-primary btn-lg"
               href="{{ path('commande_livraison_demo', {id: commande.idCommande}) }}">
              🗺️ Ouvrir le suivi livraison (carte)
            </a>

            <form method="post" action="{{ path('admin_commande_statut', {id: commande.idCommande}) }}">
              <input type="hidden" name="statut" value="Livrée">
              <button type="submit" class="btn btn-success w-100 btn-lg">
                ✅ Marquer comme livrée
              </button>
            </form>
          </div>

        {% else %}
          <div class="text-muted">La livraison n'est pas disponible pour ce statut.</div>
        {% endif %}

      </div>
    </div>

    {# ============================
       MODIFIER STATUT
    ============================ #}
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="bi bi-pencil-square"></i> Modifier le statut</h5>
      </div>
      <div class="card-body">
        <form method="post" action="{{ path('admin_commande_statut', {id: commande.idCommande}) }}">
          <div class="row align-items-end">
            <div class="col-md-8">
              <label class="form-label fw-bold">Nouveau statut :</label>
              <select name="statut" class="form-select form-select-lg" required>
                <option value="En attente" {% if st == 'En attente' %}selected{% endif %}>⏳ En attente</option>
                <option value="En cours" {% if st == 'En cours' %}selected{% endif %}>🔄 En cours</option>
                <option value="En livraison" {% if st == 'En livraison' %}selected{% endif %}>🚚 En livraison</option>
                <option value="Expédiée" {% if st == 'Expédiée' %}selected{% endif %}>📦 Expédiée</option>
                <option value="Livrée" {% if st == 'Livrée' %}selected{% endif %}>✅ Livrée</option>
                <option value="Annulée" {% if st == 'Annulée' %}selected{% endif %}>❌ Annulée</option>
              </select>
            </div>
            <div class="col-md-4">
              <button type="submit" class="btn btn-primary btn-lg w-100">
                <i class="bi bi-check-circle"></i> Mettre à jour
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>

    {# ============================
       SUPPRIMER COMMANDE
    ============================ #}
    <div class="card shadow-sm border-danger">
      <div class="card-header bg-danger text-white">
        <h5 class="mb-0"><i class="bi bi-trash"></i> Zone dangereuse</h5>
      </div>
      <div class="card-body">
        <p class="text-muted">Une fois supprimée, cette commande ne pourra pas être récupérée.</p>
        <form method="post"
              action="{{ path('admin_commande_delete', {id: commande.idCommande}) }}"
              onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette commande #{{ commande.idCommande }} ?');">
          <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash"></i> Supprimer cette commande
          </button>
        </form>
      </div>
    </div>

  </div>
</div>

{% endif %}

{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="{{ asset('assets_dash/js/commandes.js') }}"></script>
{% endblock %}