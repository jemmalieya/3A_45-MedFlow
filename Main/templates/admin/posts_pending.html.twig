{% extends 'base_dashboard.html.twig' %}
{% block title %}Posts en attente{% endblock %}

{% block body %}
<style>
  /* ✅ Même charte/design que ta page “Commentaires bloqués” */
  :root{
    --mf-vivid-blue:#003399;
    --mf-main:#0097B2;
    --mf-vivid-turq:#00BFA6;
    --mf-pastel-blue:#6797FF;
    --mf-pastel-azure:#8FD5FF;
    --mf-light-blue:#B3D5FF;
    --mf-white:#FFFFFF;
    --mf-black:#000000;
    --mf-vivid-red:#BC0B09;

    --mf-text:#0f172a;
    --mf-muted: rgba(16,24,40,.68);
    --mf-border:#e2e8f0;
    --mf-bg:#f8f9fc;

    --mf-grad-a: var(--mf-main);
    --mf-grad-b: var(--mf-pastel-blue);
  }

  .page-header{
    background: linear-gradient(135deg, var(--mf-grad-a) 0%, var(--mf-grad-b) 100%);
    color: var(--mf-white);
    padding: 40px 30px;
    border-radius: 12px;
    margin-bottom: 22px;
    box-shadow: 0 10px 30px rgba(0,151,178,.28);
  }
  .page-header h1{
    font-size: 2.15rem;
    font-weight: 900;
    margin-bottom: 8px;
    letter-spacing: -.4px;
  }
  .page-header p{margin:0; font-size:1.05rem; opacity:.95;}

  .card{
    border:none;
    border-radius:12px;
    box-shadow: 0 5px 20px rgba(0,0,0,.08);
    overflow:hidden;
    transition: all .3s ease;
    background: var(--mf-white);
  }
  .card:hover{
    box-shadow: 0 10px 35px rgba(0,0,0,.15);
    transform: translateY(-2px);
  }
  .card-header{
    background: linear-gradient(135deg, var(--mf-grad-a) 0%, var(--mf-grad-b) 100%);
    color: var(--mf-white);
    border:none;
    padding: 18px 22px;
  }
  .card-header h6{
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: .3px;
    margin:0;
  }
  .card-body{ padding: 22px; background: var(--mf-white); }

  .toolbar{
    display:flex;
    gap:10px;
    flex-wrap:wrap;
    align-items:center;
    justify-content:flex-end;
  }
  .toolbar .form-control{
    border:2px solid rgba(255,255,255,.75);
    border-radius: 10px;
    padding: 8px 12px;
    font-size:.92rem;
    background: rgba(255,255,255,.14);
    color: var(--mf-white);
  }
  .toolbar .form-control::placeholder{ color: rgba(255,255,255,.90); }
  .toolbar .form-control:focus{
    outline:none;
    box-shadow: 0 0 0 3px rgba(179,213,255,.35);
    border-color: var(--mf-white);
    background: rgba(255,255,255,.18);
  }
  .toolbar select.form-control option{ color:#111827; }

  .btn-primary{
    background: linear-gradient(135deg, var(--mf-main) 0%, var(--mf-vivid-turq) 100%);
    border:none;
    border-radius: 10px;
    padding: 8px 14px;
    font-weight:800;
    transition: all .3s ease;
    color: var(--mf-white);
    white-space:nowrap;
  }
  .btn-primary:hover{
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0,151,178,.28);
    color: var(--mf-white);
  }

  .btn-success{
    background: linear-gradient(135deg, #16a34a 0%, #22c55e 100%);
    border:none;
    color:#fff;
    border-radius: 10px;
    padding: 8px 14px;
    font-weight:800;
    transition: all .3s ease;
    white-space:nowrap;
  }
  .btn-success:hover{
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(34,197,94,.25);
    color:#fff;
  }

  .btn-danger{
    background: linear-gradient(135deg, #BC0B09 0%, #ef4444 100%);
    border:none;
    color:#fff;
    border-radius: 10px;
    padding: 8px 14px;
    font-weight:800;
    transition: all .3s ease;
    white-space:nowrap;
  }
  .btn-danger:hover{
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(188,11,9,.22);
    color:#fff;
  }

  .btn-outline-light{
    border-radius: 10px;
    padding: 8px 14px;
    font-weight:800;
    white-space:nowrap;
  }

  .table{ margin-bottom:0; table-layout: fixed; }
  .table thead th{
    background: linear-gradient(135deg, rgba(143,213,255,.35) 0%, rgba(179,213,255,.35) 100%);
    color: #063a44;
    font-weight: 900;
    border-bottom: 2px solid var(--mf-border);
    padding: 14px;
    font-size: .82rem;
    text-transform: uppercase;
    letter-spacing: .35px;
    white-space: nowrap;
  }
  .table tbody td{
    padding: 14px;
    vertical-align: top;
    border-color: var(--mf-border);
  }
  .table tbody tr{ transition: all .25s ease; }
  .table tbody tr:hover{
    background-color: var(--mf-bg);
    box-shadow: inset 0 0 0 1px var(--mf-border);
  }

  .pill{
    display:inline-flex;
    align-items:center;
    gap:.45rem;
    padding:.35rem .75rem;
    border-radius:999px;
    font-weight:900;
    font-size:.78rem;
    border: 1px solid transparent;
    white-space: nowrap;
    line-height: 1.1;
  }
  .pill-wait{
    background: rgba(245,158,11,.14);
    color: #8a5a00;
    border-color: rgba(245,158,11,.30);
  }
  .pill-neutral{
    background: rgba(0,0,0,.06);
    color: #111827;
    border-color: rgba(0,0,0,.10);
  }
  .pill-info{
    background: rgba(0,151,178,.14);
    color: #006a7d;
    border-color: rgba(0,151,178,.30);
  }

  .cell-title{ font-weight: 950; color: var(--mf-text); }
  .cell-sub{ color: var(--mf-muted); font-size: .86rem; }
  .truncate-2{
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .alert{
    border:none;
    border-radius:10px;
    border-left:4px solid;
    margin-bottom: 18px;
    animation: slideIn .35s ease;
  }
  .alert-success{
    background: linear-gradient(135deg, rgba(0,191,166,.14) 0%, rgba(0,191,166,.22) 100%);
    border-left-color: var(--mf-vivid-turq);
    color: #055a4f;
  }
  .alert-danger{
    background: linear-gradient(135deg, rgba(188,11,9,.12) 0%, rgba(188,11,9,.18) 100%);
    border-left-color: var(--mf-vivid-red);
    color: #6a0a08;
  }
  .alert-info{
    background: linear-gradient(135deg, rgba(143,213,255,.22) 0%, rgba(179,213,255,.22) 100%);
    border-left-color: var(--mf-main);
    color: #063a44;
  }
  @keyframes slideIn{ from{opacity:0; transform: translateY(-10px);} to{opacity:1; transform: translateY(0);} }
</style>

<section class="section py-4">
  <div class="container-fluid">

    <div class="page-header">
      <h1><i class="bi bi-hourglass-split me-2"></i>Posts en attente</h1>
      <p>
        {{ posts|length }} post(s) •
        <span class="pill pill-neutral"><i class="bi bi-shield-lock"></i> Admin</span>
        <span class="pill pill-wait ms-2"><i class="bi bi-clock-history"></i> En attente</span>
      </p>
    </div>

    {# Flash messages (si tu en as) #}
    {% for msg in app.flashes('success') %}
      <div class="alert alert-success">
        <strong>✅ Succès :</strong> {{ msg }}
      </div>
    {% endfor %}
    {% for msg in app.flashes('error') %}
      <div class="alert alert-danger">
        <strong>❌ Erreur :</strong> {{ msg }}
      </div>
    {% endfor %}

    <div class="card shadow mb-4">
      <div class="card-header d-flex justify-content-between align-items-center flex-wrap" style="gap:10px;">
        <h6 class="m-0 font-weight-bold text-white">
          <i class="bi bi-journal-text me-2"></i>Liste des posts en attente
        </h6>

       

      <div class="card-body">
        {% if posts is empty %}
          <div class="alert alert-success">
            ✅ Aucun post en attente de validation.
          </div>
        {% else %}
          <div class="table-responsive">
            <table id="pendingPostsTable" class="table table-bordered table-hover" width="100%" cellspacing="0">
              <thead>
                <tr>
                  <th style="width:460px;">Titre</th>
                  <th style="width:320px;">Auteur</th>
                  <th style="width:220px;">Date</th>
                  <th style="width:260px;" class="text-end">Actions</th>
                </tr>
              </thead>

              <tbody>
                {% for p in posts %}
                  {% set author = (p.user ? (p.user.emailUser ?? '—') : '—') %}
                  {% set createdAt = p.dateCreation ? p.dateCreation : null %}
                  {% set title = p.titre ?? '' %}

                  <tr class="main-row"
                      data-created="{{ createdAt ? createdAt|date('Y-m-d H:i:s') : '' }}"
                      data-user="{{ author|lower }}"
                      data-title="{{ title|lower }}">

                    <td>
                      <div class="cell-title truncate-2">
                        <i class="bi bi-card-text me-1"></i> {{ p.titre }}
                      </div>
                      <div class="mt-2">
                        <span class="pill pill-wait"><i class="bi bi-hourglass-split"></i> En attente</span>
                        <span class="pill pill-neutral ms-2"><i class="bi bi-key"></i> #{{ p.id }}</span>
                      </div>
                    </td>

                    <td>
                      <div class="cell-title">
                        <i class="bi bi-person-circle me-1"></i> {{ author }}
                      </div>
                      <div class="cell-sub mt-1">
                        Auteur du post
                      </div>
                    </td>

                    <td class="small text-dark">
                      {% if createdAt %}
                        <span class="pill pill-info">
                          <i class="bi bi-clock-history"></i>
                          {{ createdAt|date('d/m/Y H:i') }}
                        </span>
                      {% else %}
                        <span class="text-muted">-</span>
                      {% endif %}
                    </td>

                    <td class="text-end text-nowrap">
                      <div class="d-inline-flex align-items-center" style="gap:8px;">

                        <form method="post" action="{{ path('admin_post_approve', {id: p.id}) }}" class="d-inline">
                          <input type="hidden" name="_token" value="{{ csrf_token('approve_post_' ~ p.id) }}">
                          <button class="btn btn-sm btn-success" title="Approuver">
                            <i class="bi bi-check2-circle me-1"></i>Approuver
                          </button>
                        </form>

                        <form method="post"
                              action="{{ path('admin_post_reject', {id: p.id}) }}"
                              class="d-inline js-reject-form">
                          <input type="hidden" name="_token" value="{{ csrf_token('reject_post_' ~ p.id) }}">
                          <button class="btn btn-sm btn-danger" title="Refuser">
                            <i class="bi bi-x-octagon me-1"></i>Refuser
                          </button>
                        </form>

                      </div>
                    </td>

                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>

          <div class="mt-3 small text-muted">
            <i class="bi bi-shield-exclamation me-1"></i>
            Les posts restent invisibles jusqu’à validation. L’admin peut approuver ou refuser.
          </div>
        {% endif %}
      </div>
    </div>

  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  (function(){
    'use strict';

    // ✅ SweetAlert confirm pour Refuser
    document.addEventListener('submit', async function(e){
      const form = e.target.closest('.js-reject-form');
      if(!form) return;
      e.preventDefault();

      const res = await Swal.fire({
        title: 'Refuser ce post ?',
        text: 'Le post sera refusé (action irréversible).',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Refuser',
        cancelButtonText: 'Annuler',
        reverseButtons: true,
        allowOutsideClick: false
      });

      if(res.isConfirmed) form.submit();
    });

    function sortRows(rows, mode){
      const arr = Array.from(rows);

      const getCreated = (tr) => {
        const s = tr.getAttribute('data-created') || '';
        const d = Date.parse(s.replace(' ', 'T')) || 0;
        return d;
      };
      const getUser  = (tr) => (tr.getAttribute('data-user') || '').toLowerCase();
      const getTitle = (tr) => (tr.getAttribute('data-title') || '').toLowerCase();

      if(mode === 'date_asc')  arr.sort((a,b) => getCreated(a) - getCreated(b));
      if(mode === 'date_desc') arr.sort((a,b) => getCreated(b) - getCreated(a));
      if(mode === 'user_az')   arr.sort((a,b) => getUser(a).localeCompare(getUser(b)));
      if(mode === 'user_za')   arr.sort((a,b) => getUser(b).localeCompare(getUser(a)));
      if(mode === 'title_az')  arr.sort((a,b) => getTitle(a).localeCompare(getTitle(b)));
      if(mode === 'title_za')  arr.sort((a,b) => getTitle(b).localeCompare(getTitle(a)));

      return arr;
    }

    document.addEventListener('DOMContentLoaded', function(){
      const table = document.getElementById('pendingPostsTable');
      if(!table) return;
      const tbody = table.querySelector('tbody');
      if(!tbody) return;

      const sortSelect = document.getElementById('pendingSortSelect');
      const searchInput = document.getElementById('searchPending');

      const originalRows = Array.from(tbody.querySelectorAll('tr.main-row')).map(r => r.cloneNode(true));

      function render(){
        const q = (searchInput && searchInput.value) ? searchInput.value.toLowerCase().trim() : '';
        const mode = sortSelect ? sortSelect.value : 'date_desc';

        let rows = originalRows.map(r => r.cloneNode(true));

        if(q){
          rows = rows.filter(r => r.textContent.toLowerCase().includes(q));
        }

        rows = sortRows(rows, mode);

        tbody.innerHTML = '';
        rows.forEach(r => tbody.appendChild(r));
      }

      if(sortSelect) sortSelect.addEventListener('change', render);
      if(searchInput) searchInput.addEventListener('input', render);

      render();
    });

  })();
</script>
{% endblock %}