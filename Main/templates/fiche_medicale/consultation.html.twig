{% extends 'base_dashboard.html.twig' %}

{% block body %}
<style>
/* Modern Teal Admin Design */
:root{
    --teal-50:#ecfeff;
    --teal-100:#cffafe;
    --teal-200:#a5f3fc;
    --teal-300:#67e8f9;
    --teal-400:#22d3ee;
    --teal-500:#06b6d4;
    --teal-600:#0891b2;
    --teal-700:#0e7490;
    --teal-800:#155e75;
    --teal-900:#164e63;
    --gray-50:#f9fafb;
    --gray-100:#f3f4f6;
    --gray-200:#e5e7eb;
    --gray-600:#4b5563;
    --gray-700:#374151;
    --gray-800:#1f2937;
    --gray-900:#111827;
}
body{
    background: linear-gradient(135deg, var(--gray-50) 0%, var(--teal-50) 100%);
    min-height: 100vh;
    color: var(--gray-900);
}
.card{
    border:none;
    border-radius:18px;
    background:#fff;
    box-shadow: 0 10px 26px rgba(8,145,178,.12);
    overflow:hidden;
    transition: transform .25s ease, box-shadow .25s ease;
}
.card:hover{
    transform: translateY(-4px);
    box-shadow: 0 18px 44px rgba(8,145,178,.18);
}
.btn{
    border-radius:12px;
    padding:.75rem 1.35rem;
    font-weight:900;
    border:none;
    transition: transform .2s ease, box-shadow .2s ease;
}
.btn-primary{
    background: linear-gradient(135deg, var(--teal-600) 0%, var(--teal-800) 100%);
    color:#fff !important;
    box-shadow: 0 10px 20px rgba(8,145,178,.25);
}
.btn-outline-primary{
    background:#fff;
    border:2px solid var(--teal-600) !important;
    color: var(--teal-700) !important;
}
.form-control {
    border: 2px solid var(--gray-200);
    border-radius: 12px;
    padding: 10px 14px;
    font-size: 0.95rem;
    transition: all 0.3s ease;
}
.form-control:focus {
    border-color: var(--teal-600);
    box-shadow: 0 0 0 3px rgba(6,182,212,.14);
}
.page-header{
    background: linear-gradient(135deg, var(--teal-600) 0%, var(--teal-800) 100%);
    color: white;
    padding: 40px 30px;
    border-radius: 18px;
    margin-bottom: 30px;
    box-shadow: 0 10px 30px rgba(8,145,178,0.15);
}
.page-header h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 10px; }
.page-header p { font-size: 1.1rem; opacity: 0.95; margin: 0; }
.text-danger { color: #dc2626 !important; }
</style>

<div class="container-fluid">

  <div class="page-header">
    <h1>🩺 Consultation présentiel</h1>
    <p>Fiche médicale – consultation en cabinet</p>
  </div>

  {# Errors #}
  {% set flashedFieldErrors = app.flashes('fieldErrors') %}
  {% if flashedFieldErrors and flashedFieldErrors[0] is defined %}
    {% set fieldErrors = flashedFieldErrors[0] %}
    {% if fieldErrors.prescriptions is not defined %}
      {% set fieldErrors = fieldErrors|merge({'prescriptions': []}) %}
    {% endif %}
  {% else %}
    {% set fieldErrors = {'diagnostic': [], 'observations': [], 'resultatsExamens': [], 'prescriptions': []} %}
  {% endif %}

  {% set globalErrors = [] %}
  {% for message in app.flashes('error') %}
    {% set globalErrors = globalErrors|merge([message]) %}
  {% endfor %}
  {% if globalErrors %}
    <div class="alert alert-danger alert-dismissible fade show m-3" role="alert">
      <strong>❌ Validation Error:</strong>
      {% for message in globalErrors %}<div>{{ message }}</div>{% endfor %}
      <button type="button" class="close" data-dismiss="alert" aria-label="Close">
        <span aria-hidden="true">&times;</span>
      </button>
    </div>
  {% endif %}

  {% set successMsgs = app.flashes('success') %}
  {% if successMsgs %}
    <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
      <strong>✅ Success:</strong>
      {% for message in successMsgs %}<div>{{ message }}</div>{% endfor %}
      <button type="button" class="close" data-dismiss="alert" aria-label="Close">
        <span aria-hidden="true">&times;</span>
      </button>
    </div>
  {% endif %}

  <form method="POST" action="{{ path('consultation_view') }}" id="consultationForm">

    {# ---- SECTION 1 ---- #}
    <div class="card shadow mb-4">
      <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-black">Fiche médicale</h6>
      </div>

      <div class="card-body">

        <div class="form-group">
          <label for="diagnostic"><strong>Diagnostic</strong></label>
          <textarea class="form-control" id="diagnostic" name="diagnostic" rows="4">{{ app.request.get('diagnostic')|default('') }}</textarea>
          {% for err in fieldErrors.diagnostic %}
            <div class="text-danger">{{ err }}</div>
          {% endfor %}
        </div>

        <div class="form-group">
          <label for="observations"><strong>Observations</strong></label>
          <textarea class="form-control" id="observations" name="observations" rows="4">{{ app.request.get('observations')|default('') }}</textarea>
          {% for err in fieldErrors.observations %}
            <div class="text-danger">{{ err }}</div>
          {% endfor %}
        </div>

        <div class="form-group mt-4">
          <label for="symptoms"><strong>AI Prescription Suggestion (Beta)</strong></label>
          <textarea class="form-control" id="symptoms" name="symptoms" rows="3"></textarea>
          <div id="ai-suggestions" class="mt-2 text-info" style="min-height:2em;"></div>
          <button type="button" class="btn btn-outline-primary btn-sm mt-2" id="add-ai-to-prescription" style="display:none;">
            Add to Prescription
          </button>
        </div>

        <div class="form-group">
          <label for="resultatsExamens"><strong>Exam Results</strong></label>
          <textarea class="form-control" id="resultatsExamens" name="resultatsExamens" rows="4">{{ app.request.get('resultatsExamens')|default('') }}</textarea>
          {% for err in fieldErrors.resultatsExamens %}
            <div class="text-danger">{{ err }}</div>
          {% endfor %}
        </div>

        <div class="form-group">
          <label><strong>Signature (Air Gesture)</strong></label>

          <div style="position:relative; width:640px; height:480px; border-radius:10px; overflow:hidden; border:2px solid #667eea;">
            <video id="video" width="640" height="480" autoplay playsinline style="position:absolute; transform: scaleX(-1);"></video>
            <canvas id="drawCanvas" width="640" height="480" style="position:absolute;"></canvas>
          </div>

          <div class="mt-2">
            <button type="button" class="btn btn-danger btn-sm" id="clearSignature">Clear</button>
            <button type="button" class="btn btn-success btn-sm" id="confirmSignature">Confirm Signature</button>
          </div>

          <div class="mt-3">
            <label><strong>Captured Signature:</strong></label><br>
            <img id="signaturePreview" style="max-width:300px; border:1px solid #ccc; display:none;">
          </div>

          <input type="hidden" name="signature" id="signatureInput">
        </div>

        {# hidden inputs #}
        {% if fiche is defined and fiche %}
          <input type="hidden" name="fiche_id" value="{{ fiche.id }}">
          <input type="hidden" id="startTime" name="startTime" value="{{ fiche.startTime ? fiche.startTime|date('Y-m-d H:i:s') : '' }}">
        {% else %}
          <input type="hidden" name="rendezvous_id" value="{{ rendezvousId }}">
          <input type="hidden" id="startTime" name="startTime" value="{{ startParam }}">
        {% endif %}
        <input type="hidden" name="type" value="Présentiel">

        <div class="form-group">
          <label for="dureeMinutes"><strong>Duration</strong></label>
          <input type="text" class="form-control" id="dureeMinutes" name="dureeMinutes" placeholder="HH:MM:SS" readonly>
        </div>

      </div>
    </div>

    {# ---- SECTION 2 ---- #}
    <div class="card shadow mb-4">
      <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-black">Prescription(s)</h6>
        <button type="button" class="btn btn-sm btn-outline-primary" id="addPrescriptionBtn">+ Add prescription</button>
      </div>

      <div class="card-body">
        <p class="text-muted small mb-3">Add zero or more prescriptions for this consultation.</p>

        <div id="prescriptionRows"></div>

        {% for err in fieldErrors.prescriptions %}
          <div class="text-danger">{{ err }}</div>
        {% endfor %}
      </div>
    </div>

    <div class="form-group">
      <button type="submit" name="save" class="btn btn-primary">Save consultation (fiche + prescriptions)</button>

      {% if idStaff %}
        <button type="button" class="btn btn-outline-secondary" onclick="window.location.href='{{ path('app_fiche_by_staff', {'idStaff': idStaff}) }}'">Cancel</button>
      {% else %}
        <button type="button" class="btn btn-outline-secondary" onclick="window.location.href='{{ path('app_fiche_medicale') }}'">Cancel</button>
      {% endif %}
    </div>

  </form>
</div>

{# JS loaded AFTER form to avoid DOM parse issues #}
<script>
  // Duration timer
  (function() {
    const input = document.getElementById('dureeMinutes');
    if (!input) return;

    let startTime = Date.now();
    const startInput = document.getElementById('startTime');
    if (startInput && startInput.value) {
      const parsed = Date.parse(startInput.value.replace(/-/g, '/'));
      if (!isNaN(parsed)) startTime = parsed;
    }

    function pad(n){ return n < 10 ? '0'+n : ''+n; }
    function update(){
      const diff = Math.max(0, Math.floor((Date.now() - startTime)/1000));
      const h = Math.floor(diff/3600);
      const m = Math.floor((diff%3600)/60);
      const s = diff%60;
      input.value = `${pad(h)}:${pad(m)}:${pad(s)}`;
    }
    setInterval(update, 1000);
    update();
  })();

  // Prescription rows (SAFE HTML)
  let prescriptionIdx = 0;

  function createPrescriptionRow(idx, data = {}) {
    return `
      <div class="border rounded-3 p-3 mb-2 prescription-row" data-index="${idx}">
        <div class="form-row">
          <div class="col-md-3 mb-2">
            <input type="text" class="form-control" name="prescription_rows[${idx}][medicament]" placeholder="Medicament" value="${data.medicament || ''}">
          </div>
          <div class="col-md-2 mb-2">
            <input type="text" class="form-control" name="prescription_rows[${idx}][dosage]" placeholder="Dosage" value="${data.dosage || ''}">
          </div>
          <div class="col-md-2 mb-2">
            <input type="text" class="form-control" name="prescription_rows[${idx}][frequence]" placeholder="Frequence" value="${data.frequence || ''}">
          </div>
          <div class="col-md-2 mb-2">
            <input type="number" class="form-control" name="prescription_rows[${idx}][duree]" placeholder="Duree (days)" value="${data.duree || ''}">
          </div>
          <div class="col-md-3 mb-2 text-right">
            <button type="button" class="btn btn-danger btn-sm remove-prescription-row">Delete</button>
          </div>
        </div>
      </div>
    `;
  }

  function addPrescriptionRow(data) {
    const container = document.getElementById('prescriptionRows');
    if (!container) return;
    container.insertAdjacentHTML('beforeend', createPrescriptionRow(prescriptionIdx++, data));
  }

  document.addEventListener('DOMContentLoaded', function () {
    const addBtn = document.getElementById('addPrescriptionBtn');
    const rows = document.getElementById('prescriptionRows');
    if (addBtn) addBtn.addEventListener('click', () => addPrescriptionRow());
    if (rows) rows.addEventListener('click', (e) => {
      if (e.target.classList.contains('remove-prescription-row')) {
        e.target.closest('.prescription-row')?.remove();
      }
    });

    // add one row by default
    addPrescriptionRow();

    // DEBUG: verify prescriptions are inside form
    setTimeout(() => {
      const first = document.querySelector('input[name="prescription_rows[0][medicament]"]');
      console.log('Prescription input form id:', first?.form?.id);
    }, 200);
  });

  // AI Suggestion (kept as-is, but now it will add rows correctly)
  (function() {
    let timer = null;
    const textarea = document.getElementById('symptoms');
    const suggestionsDiv = document.getElementById('ai-suggestions');
    const addBtn = document.getElementById('add-ai-to-prescription');
    if (!textarea || !suggestionsDiv || !addBtn) return;

    textarea.addEventListener('input', function() {
      clearTimeout(timer);
      timer = setTimeout(function() {
        const text = textarea.value.trim();
        if (!text) { suggestionsDiv.textContent = ''; addBtn.style.display = 'none'; return; }

        suggestionsDiv.textContent = '⏳ AI is thinking...';
        addBtn.style.display = 'none';

        const prompt = text + "\n\nReturn the medication suggestions as a JSON array, where each item has: name, dose, frequence, duree (number of days), and instructions.";
        fetch('/api/suggest-prescription', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text: prompt })
        })
        .then(res => res.json())
        .then(data => {
          if (data.suggestion !== undefined) {
            suggestionsDiv.textContent = data.suggestion;
            addBtn.style.display = 'inline-block';
          } else if (data.error) {
            suggestionsDiv.textContent = '⚠️ ' + data.error;
          } else {
            suggestionsDiv.textContent = 'No suggestion.';
          }
        })
        .catch(() => suggestionsDiv.textContent = '⚠️ AI service unavailable.');
      }, 1000);
    });

    function parseMedications(text) {
      let jsonText = text.trim().replace(/^```json|^```|```$/g, '').trim();
      const arrayMatch = jsonText.match(/\[.*\]/s);
      if (arrayMatch) {
        try { return JSON.parse(arrayMatch[0]); } catch(e) {}
      }
      try { return JSON.parse(jsonText); } catch(e) {}
      return [];
    }

    addBtn.addEventListener('click', function() {
      const meds = parseMedications(suggestionsDiv.textContent || '');
      if (!Array.isArray(meds) || meds.length === 0) return;

      meds.forEach(m => addPrescriptionRow({
        medicament: m.name || '',
        dosage: m.dose || '',
        frequence: m.frequence || '',
        duree: m.duree || ''
      }));
    });
  })();
</script>

{# MediaPipe scripts (keep) #}
<script src="https://cdn.jsdelivr.net/npm/@mediapipe/hands@0.4/hands.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@mediapipe/camera_utils@0.3/camera_utils.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@mediapipe/drawing_utils@0.3/drawing_utils.js"></script>

<script>
console.log('MediaPipe Hands loaded:', typeof Hands !== 'undefined');

let drawingCanvas;
let drawCtx;
let lastX = null, lastY = null;

document.addEventListener("DOMContentLoaded", () => {
  const video = document.getElementById("video");
  const canvas = document.getElementById("drawCanvas");
  const signatureInput = document.getElementById("signatureInput");
  const preview = document.getElementById("signaturePreview");
  if (!video || !canvas) return;

  drawingCanvas = document.createElement("canvas");
  drawingCanvas.width = canvas.width;
  drawingCanvas.height = canvas.height;
  drawCtx = drawingCanvas.getContext("2d");

  const ctx = canvas.getContext("2d");

  const hands = new Hands({
    locateFile: (file) => `https://cdn.jsdelivr.net/npm/@mediapipe/hands@0.4/${file}`
  });

  hands.setOptions({
    maxNumHands: 1,
    modelComplexity: 0,
    minDetectionConfidence: 0.7,
    minTrackingConfidence: 0.7
  });

  hands.onResults(results => {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    if (results.multiHandLandmarks && results.multiHandLandmarks.length > 0) {
      const landmarks = results.multiHandLandmarks[0];

      landmarks.forEach(lm => {
        const x = canvas.width - (lm.x * canvas.width);
        const y = lm.y * canvas.height;
        ctx.beginPath(); ctx.arc(x, y, 5, 0, 2 * Math.PI);
        ctx.fillStyle = "black"; ctx.fill();
      });

      const indexTip = landmarks[8];
      const thumbTip = landmarks[4];
      const pinchX = canvas.width - (((indexTip.x + thumbTip.x) / 2) * canvas.width);
      const pinchY = ((indexTip.y + thumbTip.y) / 2) * canvas.height;
      const distance = Math.hypot(indexTip.x - thumbTip.x, indexTip.y - thumbTip.y);
      const pinchThreshold = 0.05;

      if (distance < pinchThreshold) {
        if (lastX !== null && lastY !== null) {
          drawCtx.beginPath();
          drawCtx.moveTo(lastX, lastY);
          drawCtx.lineTo(pinchX, pinchY);
          drawCtx.strokeStyle = "red";
          drawCtx.lineWidth = 4;
          drawCtx.stroke();
        }
        lastX = pinchX; lastY = pinchY;
      } else {
        lastX = null; lastY = null;
      }
    } else {
      lastX = null; lastY = null;
    }

    ctx.drawImage(drawingCanvas, 0, 0);
  });

  const camera = new Camera(video, {
    onFrame: async () => await hands.send({image: video}),
    width: 640,
    height: 480
  });
  camera.start();

  document.getElementById("clearSignature")?.addEventListener("click", () => {
    drawCtx.clearRect(0,0,drawingCanvas.width,drawingCanvas.height);
    ctx.clearRect(0,0,canvas.width,canvas.height);
    preview.style.display = "none";
    signatureInput.value = "";
  });

  document.getElementById("confirmSignature")?.addEventListener("click", () => {
    const targetWidth = 320, targetHeight = 80;
    const tmpCanvas = document.createElement('canvas');
    tmpCanvas.width = targetWidth; tmpCanvas.height = targetHeight;
    const tmpCtx = tmpCanvas.getContext('2d');
    tmpCtx.fillStyle = '#fff';
    tmpCtx.fillRect(0, 0, targetWidth, targetHeight);
    tmpCtx.drawImage(drawingCanvas, 0, 0, drawingCanvas.width, drawingCanvas.height, 0, 0, targetWidth, targetHeight);

    const dataURL = tmpCanvas.toDataURL("image/png");
    signatureInput.value = dataURL.split(',')[1];
    preview.src = dataURL;
    preview.style.display = "block";
  });
});
</script>
{% endblock %}