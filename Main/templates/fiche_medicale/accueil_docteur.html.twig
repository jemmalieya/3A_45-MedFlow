{% extends 'base_dashboard.html.twig' %}

{% block stylesheets %}
<style>
/* Modern Teal Admin Design */
:root{
  --teal-50:#ecfeff;
  --teal-100:#cffafe;
  --teal-200:#a5f3fc;
  --teal-300:#67e8f9;
  --teal-400:#22d3ee;
  --teal-500:#06b6d4;
  --teal-600:#0891b2;
  --teal-700:#0e7490;
  --teal-800:#155e75;
  --teal-900:#164e63;
  --gray-50:#f9fafb;
  --gray-100:#f3f4f6;
  --gray-200:#e5e7eb;
  --gray-600:#4b5563;
  --gray-700:#374151;
  --gray-800:#1f2937;
  --gray-900:#111827;
  --shadow-sm:0 6px 18px rgba(17,24,39,.08);
  --shadow-md:0 14px 36px rgba(17,24,39,.12);
}
body{
  background: linear-gradient(135deg, var(--gray-50) 0%, var(--teal-50) 100%);
  min-height: 100vh;
  color: var(--gray-900);
}
.card{
  border:none;
  border-radius:18px;
  background:#fff;
  box-shadow: 0 10px 26px rgba(8,145,178,.12);
  overflow:hidden;
  transition: transform .25s ease, box-shadow .25s ease;
}
.card:hover{
  transform: translateY(-4px);
  box-shadow: 0 18px 44px rgba(8,145,178,.18);
}
.card-header.bg-dark{
  background: linear-gradient(135deg, var(--teal-800) 0%, var(--teal-900) 100%) !important;
  color:#fff !important;
}
.card-header.bg-primary{
  background: linear-gradient(135deg, var(--teal-600) 0%, var(--teal-800) 100%) !important;
  color:#fff !important;
}
.card-header.bg-info{
  background: linear-gradient(135deg, var(--teal-500) 0%, var(--teal-700) 100%) !important;
  color:#fff !important;
}
.card-header.bg-warning{
  background: linear-gradient(135deg,#fbbf24 0%,#f59e0b 100%) !important;
  color:#111827 !important;
}
.card-header.bg-danger{
  background: linear-gradient(135deg,#ef4444 0%,#dc2626 100%) !important;
  color:#fff !important;
}
.badge{
  padding:.52rem 1rem;
  font-size:.85rem;
  font-weight:900;
  border-radius:999px;
  letter-spacing:.2px;
}
.badge.bg-primary{
  background: linear-gradient(135deg, var(--teal-600) 0%, var(--teal-800) 100%) !important;
  color:#fff !important;
}
.badge.bg-info{
  background: linear-gradient(135deg, var(--teal-500) 0%, var(--teal-700) 100%) !important;
  color:#fff !important;
}
.badge.bg-warning{
  background: linear-gradient(135deg,#fbbf24 0%,#f59e0b 100%) !important;
  color:#111827 !important;
}
.badge.bg-success{
  background: linear-gradient(135deg,#10b981 0%,#059669 100%) !important;
  color:#fff !important;
}
.badge.bg-danger{
  background: linear-gradient(135deg,#ef4444 0%,#dc2626 100%) !important;
  color:#fff !important;
}
.badge.bg-secondary{
  background: linear-gradient(135deg,#6b7280 0%,#4b5563 100%) !important;
  color:#fff !important;
}
.btn{
  border-radius:12px;
  padding:.75rem 1.35rem;
  font-weight:900;
  border:none;
  position:relative;
  overflow:hidden;
  transition: transform .2s ease, box-shadow .2s ease;
}
.btn-primary{
  background: linear-gradient(135deg, var(--teal-600) 0%, var(--teal-800) 100%);
  color:#fff !important;
  box-shadow: 0 10px 20px rgba(8,145,178,.25);
}
.btn-warning{
  background: linear-gradient(135deg,#fbbf24 0%,#f59e0b 100%);
  color:#111827 !important;
  box-shadow: 0 10px 20px rgba(245,158,11,.22);
}
.btn-success{
  background: linear-gradient(135deg,#10b981 0%,#059669 100%);
  color:#fff !important;
}
.btn-danger{
  background: linear-gradient(135deg,#ef4444 0%,#dc2626 100%);
  color:#fff !important;
}
.btn-outline-secondary{
  background:#fff;
  border:2px solid var(--gray-200) !important;
  color: var(--gray-800) !important;
}
.btn-outline-primary{
  background:#fff;
  border:2px solid var(--teal-600) !important;
  color: var(--teal-700) !important;
}
.btn-sm{ padding:.5rem 1rem; font-size:.875rem; }
.btn-lg{ padding:1rem 2rem; font-size:1.05rem; }
.btn i{ margin-right:.5rem; }
.modal-content {
  border-radius: 18px;
  border: none;
}
.dashboard-header{
  background: linear-gradient(135deg, var(--teal-600) 0%, var(--teal-800) 100%);
  padding: 20px 30px;
  border-radius: 18px;
  color: white;
  box-shadow: 0 10px 30px rgba(8,145,178,0.15);
}
.dashboard-header h2 {
  font-weight: 800;
}
.live-clock {
  font-size: 1.6rem;
  font-weight: 600;
  animation: pulse 1s infinite alternate;
}
@keyframes pulse {
  from { opacity: 0.7; }
  to { opacity: 1; }
}
.timeline li {
  transition: all 0.3s ease;
  border-left: 4px solid var(--teal-600);
  padding-left: 15px;
  position: relative;
}
.timeline li::before {
  content: '';
  position: absolute;
  left: -9px;
  top: 15px;
  width: 14px;
  height: 14px;
  background: var(--teal-600);
  border-radius: 50%;
}
.timeline li:hover {
  transform: scale(1.02);
  background: var(--teal-100);
  border-radius: 12px;
}
.bg-deep-purple {
  background: linear-gradient(135deg, #4B006E, #7C1CFF) !important;
}
</style>
{% endblock %}

{% block body %}
<div class="container-fluid px-4">
  <div class="dashboard-header d-flex justify-content-between align-items-center mb-4">
    <h2>Welcome Dr. {{ (doctor.nom ~ ' ' ~ doctor.prenom)|default('Unknown') }}</h2>
    <div id="live-clock" class="live-clock"></div>
    <button id="darkModeToggle" class="btn btn-outline-secondary ms-3">🌙 Dark Mode</button>
  </div>

  <div class="card shadow-lg mb-2 mt-2 news-card w-100" id="news-card" style="background-size:cover;background-position:center;min-height:260px;">
    <div class="card-body text-center" style="background:rgba(255,255,255,0.85);border-radius:18px;min-height:220px;display:flex;flex-direction:column;justify-content:center;">
      <h4 class="fw-bold mb-3">🧠 AI Medical Insight</h4>
      <h5 id="news-title" class="fw-bold"></h5>
      <p id="news-content" class="fs-5"></p>
    </div>
  </div>
<!--
  <div class="card shadow mb-4 w-100">
    <div class="card-header text-white" style="background: linear-gradient(135deg,#00c6ff,#0072ff);">
      <h5 class="mb-0">📊 Consultation Analytics</h5>
    </div>
    <div class="card-body">
      {{ render_chart(chart) }}
    </div>
  </div>
-->
  <div class="card shadow mb-4 w-100">
      <div class="card-header bg-primary text-white">
          <h5 class="mb-0">Today's Appointments — {{ today|date('l, d F Y') }}</h5>
      </div>
      <div class="card-body">
              <ul class="timeline list-unstyled">
                  {% if appointments|length == 0 %}
              <div class="text-center text-muted">No appointments today</div>
                  {% else %}
                    {% for appt in appointments %}
                        {% if appt.statut == 'Confirmé' %}
                            {% set now = "now"|date('Y-m-d H:i:s') %}
                            {% set isCurrent = appt.datetime <= now and appt.endTime >= now %}
                            {% set isNext = appt.datetime > now and loop.first %}
                            <li class="mb-3 p-3 rounded {% if isCurrent %}bg-warning text-dark{% elseif isNext %}bg-info text-white{% endif %}">
                                <div class="d-flex justify-content-between align-items-center">
                                  <span class="fw-bold">{{ appt.datetime|date('H:i') }}</span>
                                  <span><i class="bi bi-person-circle"></i> {{ (appt.patient.nom ~ ' ' ~ appt.patient.prenom)|default('Unknown') }}</span>
                                  <span><i class="bi bi-clock"></i> {{ appt.statut|capitalize }}</span>
                                  <span>
                                    <a href="{{ path('start_consultation', {'id': appt.id}) }}" class="btn btn-sm btn-primary" title="Start a new consultation">
                                      <i class="fas fa-play-circle"></i> Start
                                    </a>
                                  </span>
                                </div>
                                {% if isCurrent %}<span class="badge bg-warning">Current</span>{% elseif isNext %}<span class="badge bg-info">Next</span>{% endif %}
                            </li>
                        {% endif %}
                    {% endfor %}
              </ul>
          {% endif %}
      </div>
  </div>

  <div class="card shadow mb-4 w-100">
      <div class="card-header bg-deep-purple text-white">
        <h5 class="mb-0">All Pending Appointments</h5>
      </div>
      <div class="card-body">
          <ul class="timeline list-unstyled">
              {% if pendingAppointments|length == 0 %}
                  <div class="text-center text-muted">No pending appointments today</div>
              {% else %}
                  {% for appt in pendingAppointments %}
                      <li class="mb-3 p-3 rounded bg-deep-purple text-white">
                          <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-bold">{{ appt.datetime|date('d/m/Y H:i') }}</span>
                            <span><i class="bi bi-person-circle"></i> {{ (appt.patient.nom ~ ' ' ~ appt.patient.prenom)|default('Unknown') }}</span>
                            <span><i class="bi bi-clock"></i> {{ appt.statut|capitalize }}</span>
                            <span>
                              <form method="post" action="{{ path('confirm_appointment', {'id': appt.id}) }}?idStaff={{ appt.staff.id }}" style="display:inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('confirm_appointment' ~ appt.id) }}">
                                <button type="submit" class="btn btn-sm btn-success" title="Confirm this appointment">
                                  <i class="fas fa-check"></i> Confirm
                                </button>
                              </form>
                            </span>
                          </div>
                      </li>
                  {% endfor %}
              {% endif %}
          </ul>
      </div>
  </div>

  <div class="card shadow mb-4 w-100 urgent-card animate-pulse">
      <div class="card-header bg-danger text-white">
        <h5 class="mb-0">🚨 Urgent Appointments – Needs Immediate Attention</h5>
      </div>
      <div class="card-body">
          <ul class="timeline list-unstyled">
              {% if urgentAppointments|length == 0 %}
                  <div class="text-center text-muted">No urgent appointments found</div>
              {% else %}
                  {% for appt in urgentAppointments %}
                      <li class="mb-3 p-3 rounded bg-danger text-white">
                          <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-bold">{{ appt.datetime|date('d/m/Y H:i') }}</span>
                            <span><i class="bi bi-person-circle"></i> {{ (appt.patient.nom ~ ' ' ~ appt.patient.prenom)|default('Unknown') }}</span>
                            <span><i class="bi bi-clipboard"></i> {{ appt.motif|default('No motif') }}</span>
                            <span>
                              <span class="badge urgency-badge {{ appt.urgencyLevel|lower }}">{{ appt.urgencyLevel }}</span>
                            </span>
                          </div>
                          <div class="mt-2 small text-light opacity-75">AI Suggestion — Doctor Validation Required</div>
                      </li>
                  {% endfor %}
              {% endif %}
          </ul>
      </div>
  </div>
<style>
.urgent-card {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%) !important;
  border: none;
  animation: urgentPulse 1.2s infinite alternate;
}
.animate-pulse {
  animation: urgentPulse 1.2s infinite alternate;
}
@keyframes urgentPulse {
  from { box-shadow: 0 0 0 0 rgba(220,38,38,0.15); }
  to { box-shadow: 0 0 24px 8px rgba(220,38,38,0.25); }
}
.urgency-badge {
  font-weight: 700;
  font-size: 1rem;
  border-radius: 999px;
  padding: 0.5rem 1.2rem;
  display: inline-block;
}
.urgency-badge.low { background: #6b7280 !important; color: #fff !important; }
.urgency-badge.normal { background: #3b82f6 !important; color: #fff !important; }
.urgency-badge.high { background: #f59e0b !important; color: #fff !important; }
.urgency-badge.critical { background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%) !important; color: #fff !important; font-size: 1.15rem; letter-spacing: 1px; box-shadow: 0 0 12px 2px rgba(220,38,38,0.25); }
</style>
</div>

<!-- Reminder Modal -->
<div class="modal fade" id="reminderModal" tabindex="-1" aria-labelledby="reminderModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="reminderModalLabel">Appointment Reminder</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" id="reminderModalBody"></div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
// Live Clock
function updateClock() {
  const now = new Date();
  document.getElementById('live-clock').textContent = now.toLocaleTimeString('en-GB', { hour12: false });
}
setInterval(updateClock, 1000);
updateClock();

// Auto refresh every 60 seconds
setInterval(() => { location.reload(); }, 60000);

// Dark Mode Toggle
const darkModeToggle = document.getElementById('darkModeToggle');
const body = document.body;
if (localStorage.getItem('darkMode') === 'true') body.classList.add('dark-mode');
darkModeToggle.addEventListener('click', () => {
  body.classList.toggle('dark-mode');
  localStorage.setItem('darkMode', body.classList.contains('dark-mode'));
});

// Smart Reminder
let remindedAppointments = JSON.parse(localStorage.getItem('remindedAppointments') || '{}');
const appointmentsList = [
  {% for appt in appointments %}
    {
      id: '{{ appt.id }}',
      datetime: '{{ appt.datetime|date('Y-m-d H:i:s') }}',
      patient: '{{ (appt.patient.nom ~ ' ' ~ appt.patient.prenom)|default('Unknown') }}'
    },
  {% endfor %}
];
function checkReminders() {
  const now = new Date();
  appointmentsList.forEach(appt => {
    const apptTime = new Date(appt.datetime);
    const diff = (apptTime - now) / 60000;
    if (diff > 9.5 && diff < 10.5 && !remindedAppointments[appt.id]) {
      remindedAppointments[appt.id] = true;
      localStorage.setItem('remindedAppointments', JSON.stringify(remindedAppointments));
      document.getElementById('reminderModalBody').textContent = 'Reminder: Appointment with ' + appt.patient + ' in 10 minutes';
      new bootstrap.Modal(document.getElementById('reminderModal')).show();
    }
  });
}
setInterval(checkReminders, 30000);
checkReminders();

// AI Medical Insights Auto-Rotate
const newsList = {{ news|json_encode|raw }};
const newsImages = [
  '/assets/news1.jpg',
  '/assets/news2.jpg',
  '/assets/news3.jpg',
  '/assets/news4.jpg',
  '/assets/news5.jpg'
];
let currentIndex = 0;

function showNews(index) {
  document.getElementById('news-title').textContent = newsList[index].title;
  document.getElementById('news-content').textContent = newsList[index].content;
  const imgUrl = newsImages[index % newsImages.length];
  document.getElementById('news-card').style.backgroundImage = `url('${imgUrl}')`;
}

function rotateNews() {
  currentIndex = (currentIndex + 1) % newsList.length;
  showNews(currentIndex);
}

if (newsList.length > 0) {
  showNews(0);
  setInterval(rotateNews, 10000); // 10 sec rotation
}

// Welcome Voice
window.addEventListener('DOMContentLoaded', function() {
  const welcomeText = document.querySelector('.dashboard-header h2')?.textContent;
  if (welcomeText && 'speechSynthesis' in window) {
    const utterance = new SpeechSynthesisUtterance(welcomeText);
    utterance.lang = 'en-US';
    // Try to select a female voice
    function setFemaleVoice() {
      const voices = window.speechSynthesis.getVoices();
      const female = voices.find(v => v.lang.startsWith('en') && v.gender === 'female') || voices.find(v => v.name.toLowerCase().includes('female') || v.name.toLowerCase().includes('woman') || v.name.toLowerCase().includes('girl'));
      utterance.voice = female || voices.find(v => v.lang.startsWith('en')) || null;
      window.speechSynthesis.speak(utterance);
    }
    if (window.speechSynthesis.getVoices().length) {
      setFemaleVoice();
    } else {
      window.speechSynthesis.onvoiceschanged = setFemaleVoice;
    }
  }
});
</script>
{% endblock %}
